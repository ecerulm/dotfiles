emulate -L zsh

# Emit the command-prefix tokens (one per line, newline-separated) for
# invoking dbt across all rlm-dbt-* commands. Callers consume the output
# by splitting on newlines:
#
#   local -a dbt_bin
#   dbt_bin=(${(f)"$(_rlm-dbt-bin)"}) || return 1
#   "${dbt_bin[@]}" ls --select tag:finance
#
# Three modes, checked in order:
#
#   DBT_USE_FUSION=1  → emits a single line: the absolute path the
#                       `dbtf` alias resolves to (typically
#                       $HOME/.local/bin/dbt). Emits a PATH, not the
#                       alias name `dbtf`, because every caller runs
#                       under `emulate -L zsh` (which sets NO_ALIASES
#                       locally) AND invokes the command via quoted
#                       array expansion `"${dbt_bin[@]}"`, which by
#                       itself never triggers alias expansion. Either
#                       condition alone is enough to turn `dbtf` into
#                       a `command not found` — so the helper resolves
#                       the alias once and emits the underlying path.
#                       On the first call per shell, validates that
#                       the alias is defined AND that the resolved
#                       binary's `--version` output mentions "fusion"
#                       (case-insensitive) — so a stray `dbt` named
#                       `dbtf` can't silently masquerade as Fusion.
#                       The resolved path is cached in a typeset -g
#                       shell-global so subsequent calls skip both
#                       the alias lookup and the version probe.
#
#   uv project        → emits two lines: `uv`, `run`, `dbt`
#   (auto-detected)     Detected when the caller passes a project_root
#                       and that directory contains uv.lock, OR when
#                       DBT_USE_UV=1 is set explicitly.
#
#   otherwise         → emits three lines: `poetry`, `run`, `dbt`
#                       (the project-pinned dbt-core invocation that
#                       every rlm-dbt-* command has used historically).
#                       No validation here; _rlm-poetry-ensure-venv is
#                       the caller's job for that path.
#
# Centralizes the fusion/poetry/uv switch so a future rename of the alias
# (e.g. `dbtf` → `dbt-fusion`) or a change to the validation rule
# (e.g. require a minimum Fusion version) has exactly one site to edit
# instead of one per rlm-dbt-* command.
#
# Usage:
#   _rlm-dbt-bin [project_root]
#
#   project_root   optional; absolute path to pyproject.toml dir, used
#                  for uv auto-detection (uv.lock presence check).
#                  When omitted, uv is only used if DBT_USE_UV=1.
#
# Stdout (on success): one token per line.
#
# Return codes:
#   0 — success; stdout populated.
#   1 — DBT_USE_FUSION=1 but the `dbtf` alias is undefined / resolves
#       to a missing file / its --version output does not look like
#       Fusion. Diagnostic on stderr. Subsequent calls in the same
#       shell will re-probe (the cache only stores positive results).

local project_root="${1:-}"

if [[ ${DBT_USE_FUSION:-0} != 1 ]]; then
  # uv path: explicit override or auto-detected via uv.lock in project_root.
  local _use_uv=0
  if [[ ${DBT_USE_UV:-0} == 1 ]]; then
    _use_uv=1
  elif [[ -n $project_root && -f "${project_root}/uv.lock" ]]; then
    _use_uv=1
  fi
  if (( _use_uv )); then
    print -r -- uv
    print -r -- run
    print -r -- dbt
    return 0
  fi
  print -r -- poetry
  print -r -- run
  print -r -- dbt
  return 0
fi

# Cache the resolved Fusion binary path (NOT just an OK flag) so every
# call after the first one is a single env-var read with no PATH /
# alias / --version probe. Re-probing the alias every call would mean
# every rlm-dbt-* command pays a fork-exec for `dbtf --version` even
# on a cache hit.
typeset -g _RLM_DBT_BIN_FUSION_PATH
if [[ -z ${_RLM_DBT_BIN_FUSION_PATH:-} ]]; then
  # The `dbtf` alias is defined in .zshrc and points at the Fusion
  # binary (typically $HOME/.local/bin/dbt). Read the alias body
  # directly with the (e) parameter-expansion flag — `alias dbtf` is
  # of the form `dbtf=/path/to/dbt` so stripping the `dbtf=` prefix
  # gives the path. `command -v dbtf` would also work but only when
  # alias expansion is active in the current scope, which it is NOT
  # inside an `emulate -L zsh` function (the NO_ALIASES option is
  # set locally). Reading the alias table via ${aliases[…]} works
  # regardless of the local NO_ALIASES setting.
  local resolved="${aliases[dbtf]:-}"
  if [[ -z $resolved ]]; then
    print -u2 "_rlm-dbt-bin: DBT_USE_FUSION=1 but the \`dbtf\` alias is not defined"
    print -u2 "  (set in .zshrc; if you're in a non-interactive shell, that's expected — \`dbtf\` is an alias, not a PATH binary)"
    return 1
  fi
  if [[ ! -x $resolved ]]; then
    print -u2 "_rlm-dbt-bin: DBT_USE_FUSION=1 but \`dbtf\` alias resolves to '$resolved' which is not an executable file"
    return 1
  fi
  local version_out
  version_out=$("$resolved" --version 2>&1)
  if ! print -r -- "$version_out" | grep -qi fusion; then
    print -u2 "_rlm-dbt-bin: DBT_USE_FUSION=1 but '$resolved' --version does not mention 'fusion':"
    print -u2 "$version_out"
    return 1
  fi
  _RLM_DBT_BIN_FUSION_PATH="$resolved"
fi

print -r -- "$_RLM_DBT_BIN_FUSION_PATH"
return 0
