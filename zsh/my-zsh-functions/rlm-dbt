emulate -L zsh
set -o pipefail

local usage="dbt <subcommand> [args...]

Generic dbt dispatcher.

Behavior:
  1. If \`rlm-dbt-<subcommand>\` exists as a function or alias, delegate
     to it (passing any remaining args through). Example: \`dbt run\`
     opens the rlm-dbt-run fzf picker; \`dbt run -s tag:foo\` forwards
     \`-s tag:foo\` to rlm-dbt-run.
  2. Otherwise, invoke plain dbt via _rlm-dbt-bin (respects
     DBT_USE_FUSION). Examples: \`dbt parse\`, \`dbt deps\`,
     \`dbt debug\`, \`dbt source freshness\`, etc.

For the plain-dbt path, rlm-dbt auto-injects:
  --project-dir <root>   nearest dbt_project.yml walking up from \$PWD
                         (skipped if --project-dir is already in args)
  --profiles-dir <dir>   \$DBT_PROFILES_DIR if set
                         (skipped if --profiles-dir is already in args)
  --defer --state <dir>  \$DBT_STATE_DIR (via _rlm-dbt-state-info, hard-fails
                         when missing or > 7 days old) — only for subcommands
                         that accept these flags: build, clone, compile, ls,
                         parse, retry, run, seed, show, snapshot, source, test
                         (skipped if --defer / --no-defer / --state already
                         in args)

Examples:
  dbt run                  # delegates to rlm-dbt-run (fzf picker)
  dbt run -s tag:finance   # delegates to rlm-dbt-run with args
  dbt compile -s my_model  # plain dbt compile, --project-dir + --defer/--state auto-injected
  dbt parse                # plain dbt parse, --project-dir auto-injected
  dbt deps                 # plain dbt deps (no defer — not a defer-aware subcommand)
  dbt --help               # plain dbt --help (no auto-injection without subcmd)"

if [[ ${1:-} == (-h|--help) || $# -eq 0 ]]; then
  print -r -- "$usage"
  [[ $# -eq 0 ]] && return 1
  return 0
fi

local subcmd=$1
shift

# Delegate to rlm-dbt-<subcmd> if one exists (function or alias).
local wrapper="rlm-dbt-${subcmd}"
if (( ${+functions[$wrapper]} )) || (( ${+aliases[$wrapper]} )); then
  "$wrapper" "$@"
  return $?
fi

# Plain-dbt path: resolve the dbt invocation.
autoload -Uz _rlm-dbt-bin
local -a dbt_bin
dbt_bin=(${(f)"$(_rlm-dbt-bin "${_proj_dir:-}")"}) || return 1

# Auto-inject --project-dir by walking up from $PWD for dbt_project.yml,
# unless the user already supplied one. The resolved dir is also reused
# below as the cwd for the `_rlm-python-ensure-version` probe; capture it
# from either source.
local -a injected=()
local _proj_dir=""
local _user_proj_idx=${@[(I)--project-dir]}
if (( _user_proj_idx )); then
  # User passed --project-dir <path>; the value is the very next arg.
  _proj_dir=${@[_user_proj_idx + 1]:-}
else
  local dir=$PWD
  while [[ $dir != / && $dir != "" ]]; do
    if [[ -f "$dir/dbt_project.yml" ]]; then
      _proj_dir="$dir"
      injected+=(--project-dir "$dir")
      break
    fi
    dir=${dir:h}
  done
fi

# Auto-inject --profiles-dir, unless the user already supplied one. Prefer a
# `profile/` dir colocated with the resolved dbt project (i.e. the
# dbt_project.yml found by walking up from $PWD) — this keeps the profiles
# dir in lock-step with the project even when $DBT_PROFILES_DIR is stale
# (e.g. left over from a different repo/worktree). Fall back to
# $DBT_PROFILES_DIR only when no colocated profile/ dir exists.
if ! (( ${@[(I)--profiles-dir]} )); then
  if [[ -n $_proj_dir && -d "$_proj_dir/profile" ]]; then
    injected+=(--profiles-dir "$_proj_dir/profile")
  elif [[ -n ${DBT_PROFILES_DIR:-} ]]; then
    injected+=(--profiles-dir "$DBT_PROFILES_DIR")
  fi
fi

# Auto-inject --defer + --state for the subcommands that accept them. The
# allowlist matches the set documented in `dbt <subcmd> --help` as accepting
# both flags. Skipped when the user has already supplied --defer, --no-defer,
# or --state. Uses the shared _rlm-dbt-state-info helper with --require so a
# missing / stale (>7d) DBT_STATE_DIR hard-fails with the same diagnostic
# the rlm-dbt-{run,build,test} wrappers emit — matching their behavior.
local -a defer_aware_subcmds=(
  build clone compile ls parse retry run seed show snapshot source test
)
if (( ${defer_aware_subcmds[(I)$subcmd]} )) \
  && ! (( ${@[(I)--defer]} )) \
  && ! (( ${@[(I)--no-defer]} )) \
  && ! (( ${@[(I)--state]} )); then
  autoload -Uz _rlm-dbt-state-info
  local _state_info
  _state_info=$(_rlm-dbt-state-info --require --max-age-days 7 --label "rlm-dbt $subcmd") || return 1
  eval "$_state_info"
  # state_dir is set by the eval above.
  injected+=(--defer --state "$state_dir")
fi

# Probe pyenv's `python` shim from the dbt project dir before invoking
# poetry-run-dbt, so a missing/misconfigured .python-version surfaces
# with a clear diagnostic instead of bubbling up as a downstream poetry
# error. Skipped under DBT_USE_FUSION=1 (dbtf is a standalone binary
# that does not touch pyenv), when no project dir is resolvable, and
# when the project is uv-managed (uv manages its own Python).
local _is_uv=0
[[ ${DBT_USE_UV:-0} == 1 || ( -n $_proj_dir && -f "${_proj_dir}/uv.lock" ) ]] && _is_uv=1
if [[ ${DBT_USE_FUSION:-0} != 1 && -n $_proj_dir && $_is_uv != 1 ]]; then
  autoload -Uz _rlm-python-ensure-version
  _rlm-python-ensure-version "$_proj_dir" "rlm-dbt $subcmd" || return 1
fi

# Echo the full command to stderr (use ${(q-)x} so args with spaces /
# globs / quotes round-trip safely as something a human can paste back).
local -a full_cmd=("${dbt_bin[@]}" "$subcmd" "${injected[@]}" "$@")
print -r -- "+ ${(j: :)${(@q-)full_cmd}}" >&2

"${dbt_bin[@]}" "$subcmd" "${injected[@]}" "$@"
