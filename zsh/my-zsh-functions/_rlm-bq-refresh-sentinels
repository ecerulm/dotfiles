emulate -L zsh

# Shared --- REFRESH CACHE --- / --- REFRESH SANDBOX CACHE --- sentinel
# logic for every rlm-bq-* / rlm-sandbox-bq-* fzf picker. Each picker
# in the family historically inlined three things:
#
#   1. A verbatim copy of `_bq_cache_age` (mtime → "23s ago" / "4h ago"
#      / "3d ago"). The body was byte-identical across 5 callers.
#   2. The sentinel string itself: "--- REFRESH CACHE (cached <age>) ---"
#      and, for sandbox-capable pickers, the purple-wrapped sibling
#      "${PURPLE}--- REFRESH SANDBOX CACHE (cached <age>) ---${RESET}".
#      Two layouts in use: bare/single-column (rlm-bq-archive,
#      rlm-sandbox-bq-{open,rm}) and tab-prefixed for `--with-nth=2`
#      pickers (rlm-bq-open, rlm-bq-rm-tables).
#   3. A detection branch in the selection-parsing loop:
#        if [[ $sel == "--- REFRESH CACHE"* ]]; then
#          rm -f "$cache" "$sandbox"
#          _rlm-bq-cache refresh || return 1
#          rlm-bq-open
#          return $?
#        fi
#      Plus a sandbox sibling. The `rm -f` + `_rlm-bq-cache refresh`
#      pair and the recursive re-invoke were copy-pasted with only the
#      function name (`rlm-bq-open` → `rlm-bq-archive` → …) differing.
#
# This helper centralizes all three so the bare sentinel literal,
# the cache-file paths, and the age formatter each live in exactly one
# place. Adding a 6th picker — or changing the sentinel wording, or
# adding a freshness threshold to the age formatter — becomes a
# single-site edit instead of a 5-way grep-and-replace.
#
# Internally calls `_rlm-bq-cache paths` so callers don't have to
# thread $cache / $sandbox through. Cache age is read from disk on
# each `emit-*` call (cheap — one stat).
#
# ----------------------------------------------------------------------
# Usage
# ----------------------------------------------------------------------
#
#   _rlm-bq-refresh-sentinels emit-main [--tab]
#       Print the main-cache sentinel line. With `--tab`, the line is
#       prefixed with a literal TAB so it parses as field-2 under fzf
#       `--delimiter=$'\t' --with-nth=2` (the rlm-bq-open layout). The
#       sentinel itself is uncolored.
#       Exit 0 always (no cache file = "(cached <unknown>)").
#
#   _rlm-bq-refresh-sentinels emit-sandbox [--tab] [--no-color]
#       Print the sandbox-cache sentinel line wrapped in the standard
#       PURPLE/RESET pair (matches the sandbox row coloring used by
#       every caller in the family). With `--tab`, the TAB goes
#       *after* the PURPLE opener, so the color escape stays in the
#       hidden field-1 chrome rather than leaking into the visible
#       field-2 display — symmetric to how callers wrap sandbox refs
#       themselves. With `--no-color`, the PURPLE/RESET wrap is
#       omitted (used by rlm-sandbox-bq-{open,rm}, where every row
#       in the picker is sandbox-scoped so the color would be
#       redundant). The "(cached <age>)" suffix is omitted when no
#       sandbox cache file exists yet (first-run behavior, mirrors
#       the historical inline code).
#       Exit 0 always.
#
#   _rlm-bq-refresh-sentinels is-main <ansi-stripped-ref>
#   _rlm-bq-refresh-sentinels is-sandbox <ansi-stripped-ref>
#       Test whether the (already ANSI-stripped, already field-2-
#       extracted) ref string matches the corresponding sentinel.
#       Exit 0 on match, 1 otherwise. Callers pass `$sel_ref`, not
#       `$sel_line`, so the helper does not need to know which
#       layout (tab-prefixed vs bare) the caller used.
#
#   _rlm-bq-refresh-sentinels apply-main
#       Open a multi-select fzf picker over the projects in
#       BQ_SEARCH_PATH (plus an "*** ALL PROJECTS ***" sentinel), then
#       refresh only the chosen projects via
#       `_rlm-bq-cache refresh --main-only --projects p1:p2:…`,
#       merging with the existing cache (entries for un-chosen projects
#       are preserved). Picking the ALL sentinel (or aborting the picker
#       with no selection) refreshes every project. TAB toggles,
#       Enter confirms, Ctrl-G aborts the whole refresh (return 130 —
#       the caller treats that as "user backed out", same as an empty
#       top-level selection). Returns the refresh exit code on success;
#       on success the caller recursively re-invokes itself to reopen
#       the picker. The sandbox half is left untouched (a project-scoped
#       refresh has nothing to do with the single-project sandbox).
#
#   _rlm-bq-refresh-sentinels apply-sandbox
#       Open a multi-select fzf picker over the datasets in
#       SANDBOX_BQ_DATASETS (plus an "*** ALL DATASETS ***" sentinel),
#       then refresh only the chosen datasets via
#       `_rlm-bq-cache refresh --sandbox-only --datasets d1:d2:…`,
#       merging with the existing sandbox cache. Picking ALL (or
#       aborting) refreshes every dataset. Returns the refresh exit
#       code; 130 if the user backed out of the picker.
#
# ----------------------------------------------------------------------
# Return codes
# ----------------------------------------------------------------------
#   0 — success (emit-* always; is-* on match; apply-* on refresh OK).
#   1 — is-* no match; apply-* refresh failed; usage error.
#   2 — unknown subcommand.
#   130 — apply-* user aborted the project/dataset picker (Ctrl-G /
#         empty selection). Caller treats this as "backed out".

autoload -Uz _rlm-bq-cache

# Resolve $key, $cache, $sandbox from the shared cache helper. Same
# eval-the-paths-output trick every other caller in the family uses.
local key cache sandbox
eval "$(_rlm-bq-cache paths)" || return 1

# Verbatim copy of the previously-duplicated _bq_cache_age. Lives here
# now; the 5 inline copies were deleted by their respective migration
# commits. If the file does not exist, mtime is empty and the
# subtraction yields a large negative number — we render that as
# "(unknown)" to avoid leaking a `-2056493213s ago` string into the
# picker.
_rlm_bq_cache_age() {
  local file="$1"
  local mtime now elapsed
  [[ ! -f $file ]] && {
    print "unknown"
    return 0
  }
  mtime=$(stat -f %m "$file" 2>/dev/null || stat -c %Y "$file" 2>/dev/null)
  now=$(date +%s)
  elapsed=$((now - mtime))
  if ((elapsed < 3600)); then
    print "${elapsed}s ago"
  elif ((elapsed < 86400)); then
    print "$((elapsed / 3600))h ago"
  else
    print "$((elapsed / 86400))d ago"
  fi
}

local PURPLE=$'\033[35m'
local RESET=$'\033[0m'

# Multi-select picker over a list of items (projects or datasets) with a
# leading "ALL" sentinel. Args: <all-sentinel> <item...>. Prints the
# chosen items, one per line (the full list when ALL is picked); empty
# output + return 1 when the user aborted with Ctrl-G or made no
# selection. Mirrors _pubsub_open_pick_projects in rlm-pubsub-open.
_rlm_bq_pick_subset() {
  local all_sentinel="$1"; shift
  local -a items=("$@")
  local selection
  selection=$(
    { print -r -- "$all_sentinel"; print -l -- "${items[@]}"; } \
      | fzf --prompt="Refresh which? (TAB to multi-select)> " \
            --multi \
            --height=80% --reverse \
            --no-mouse --ansi \
            --header="TAB: toggle  Enter: confirm  Ctrl-G: abort" \
            --preview-window=hidden \
            --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
            --bind='ctrl-g:abort'
  ) || return 1
  [[ -z $selection ]] && return 1

  # ALL sentinel anywhere in the selection ⇒ refresh everything.
  if print -r -- "$selection" | grep -Fxq -- "$all_sentinel"; then
    print -l -- "${items[@]}"
  else
    print -r -- "$selection"
  fi
}

local subcmd="$1"
shift 2>/dev/null

case "$subcmd" in
  emit-main)
    local prefix=""
    [[ "$1" == "--tab" ]] && prefix=$'\t'
    print -r -- "${prefix}--- REFRESH CACHE (cached $(_rlm_bq_cache_age "$cache")) ---"
    return 0
    ;;
  emit-sandbox)
    local tab="" use_color=1
    while (($#)); do
      case "$1" in
        --tab) tab=$'\t' ;;
        --no-color) use_color=0 ;;
        *) print -u2 "_rlm-bq-refresh-sentinels emit-sandbox: unknown flag: $1"; return 1 ;;
      esac
      shift
    done
    local open="" close=""
    (( use_color )) && { open="$PURPLE"; close="$RESET"; }
    local age_suffix=""
    # Match the historical "omit suffix when the sandbox cache does
    # not yet exist" behavior — every caller's previous inline code
    # gated on `[[ -f $sandbox ]]` before adding the "(cached …)" tail.
    [[ -f $sandbox ]] && age_suffix=" (cached $(_rlm_bq_cache_age "$sandbox"))"
    print -r -- "${open}${tab}--- REFRESH SANDBOX CACHE${age_suffix} ---${close}"
    return 0
    ;;
  is-main)
    [[ "$1" == "--- REFRESH CACHE"* ]]
    return $?
    ;;
  is-sandbox)
    [[ "$1" == "--- REFRESH SANDBOX CACHE"* ]]
    return $?
    ;;
  apply-main)
    local -a all_projects chosen
    all_projects=(${(s[:])BQ_SEARCH_PATH})
    # With 0 or 1 configured project there's nothing to choose — refresh
    # the lot without bothering the user with a one-item picker.
    if (( ${#all_projects} <= 1 )); then
      _rlm-bq-cache refresh --main-only
      return $?
    fi
    chosen=("${(@f)$(_rlm_bq_pick_subset '*** ALL PROJECTS ***' "${all_projects[@]}")}")
    chosen=("${(@)chosen:#}")   # drop the empty element zsh leaves on no output
    (( ${#chosen} == 0 )) && return 130
    _rlm-bq-cache refresh --main-only --projects "${(j[:])chosen}"
    return $?
    ;;
  apply-sandbox)
    local -a all_datasets chosen
    all_datasets=(${(s[:])SANDBOX_BQ_DATASETS})
    if (( ${#all_datasets} <= 1 )); then
      _rlm-bq-cache refresh --sandbox-only
      return $?
    fi
    chosen=("${(@f)$(_rlm_bq_pick_subset '*** ALL DATASETS ***' "${all_datasets[@]}")}")
    chosen=("${(@)chosen:#}")
    (( ${#chosen} == 0 )) && return 130
    _rlm-bq-cache refresh --sandbox-only --datasets "${(j[:])chosen}"
    return $?
    ;;
  "")
    print -u2 "_rlm-bq-refresh-sentinels: missing subcommand"
    print -u2 "usage: _rlm-bq-refresh-sentinels {emit-main|emit-sandbox} [--tab]"
    print -u2 "       _rlm-bq-refresh-sentinels {is-main|is-sandbox} <stripped-ref>"
    print -u2 "       _rlm-bq-refresh-sentinels {apply-main|apply-sandbox}"
    return 1
    ;;
  *)
    print -u2 "_rlm-bq-refresh-sentinels: unknown subcommand: $subcmd"
    return 2
    ;;
esac
