emulate -L zsh
set -o pipefail

if [[ -z $SANDBOX_BQ_PROJECT ]]; then
  print -u2 "sandbox-bq-open: SANDBOX_BQ_PROJECT is not set"
  return 1
fi
if [[ -z $SANDBOX_BQ_DATASETS ]]; then
  print -u2 "sandbox-bq-open: SANDBOX_BQ_DATASETS is not set"
  return 1
fi

for _cmd in bq fzf jq; do
  if ! command -v "$_cmd" >/dev/null 2>&1; then
    print -u2 "sandbox-bq-open: '$_cmd' not found in PATH"
    return 1
  fi
done
unset _cmd

# Shared cache + history wiring. All five rlm-bq-* / rlm-sandbox-bq-*
# commands share one cache pair (~/.cache/bq-open/<md5>.txt and
# -sandbox.txt) and one pooled history TSV (~/.cache/bq-open/history.tsv)
# via these helpers. See zsh/AGENTS.md "Current internal helpers".
autoload -Uz _rlm-bq-cache _rlm-bq-history _rlm-bq-dead-refs-gc

# Garbage-collect any refs that bq-preview marked as dead on a previous
# run. No-op when ~/.cache/bq-open/dead-refs.txt is missing/empty.
_rlm-bq-dead-refs-gc

# Resolve current cache-key, paths.
local key cache sandbox
eval "$(_rlm-bq-cache paths)" || return 1

# Fetch on first run if no sandbox cache exists yet
if [[ ! -f $sandbox ]]; then
  _rlm-bq-cache refresh --sandbox-only || return 1
fi

_bq_cache_age() {
  local file="$1"
  local mtime now elapsed
  mtime=$(stat -f %m "$file" 2>/dev/null || stat -c %Y "$file" 2>/dev/null)
  now=$(date +%s)
  elapsed=$(( now - mtime ))
  if (( elapsed < 3600 )); then
    print "${elapsed}s ago"
  elif (( elapsed < 86400 )); then
    print "$(( elapsed / 3600 ))h ago"
  else
    print "$(( elapsed / 86400 ))d ago"
  fi
}

local refresh_sentinel="--- REFRESH SANDBOX CACHE (cached $(_bq_cache_age "$sandbox")) ---"

# Build set of bq_refs that exist in the current sandbox cache scope.
# Pooled history may contain entries from other scopes or non-sandbox
# refs; we suppress those so the picker only suggests refs the user
# can actually open from here.
local -A in_scope
local _ref
while IFS= read -r _ref; do
  [[ -n $_ref ]] && in_scope[$_ref]=1
done < <(_rlm-bq-cache read --sandbox)

# Pooled history entries (newest first), filtered to refs in the
# current sandbox cache scope. Plain bare refs (single-column layout).
_bq_open_history_lines() {
  local ts cmd ref flags
  while IFS=$'\t' read -r ts cmd ref flags; do
    [[ -z $ref ]] && continue
    [[ -z ${in_scope[$ref]:-} ]] && continue
    print -r -- "$ref"
  done < <(_rlm-bq-history read)
}

local selection
selection=$(
  {
    print -r -- "$refresh_sentinel"
    _bq_open_history_lines
    _rlm-bq-cache read --sandbox
  } \
  | awk '!seen[$0]++' \
  | fzf --prompt="Sandbox BQ table> " \
        --no-mouse \
        --ansi \
        --height=80% --reverse \
        --preview="$HOME/bin/bq-preview {}" \
        --preview-window=bottom:40%:wrap \
        --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
        --bind='ctrl-g:abort'
) || return 130

[[ -z $selection ]] && return 130

if [[ $selection == "--- REFRESH SANDBOX CACHE"* ]]; then
  rm -f "$sandbox"
  _rlm-bq-cache refresh --sandbox-only || return 1
  rlm-sandbox-bq-open
  return $?
fi

# Append to the shared pooled history with the sandbox flag so every
# other rlm-bq-* picker can render this pick in purple too.
_rlm-bq-history append sandbox-bq-open "$selection" sandbox

local sel_project dataset_table sel_dataset sel_table
sel_project=${selection%%:*}
dataset_table=${selection##*:}
sel_dataset=${dataset_table%%.*}
sel_table=${dataset_table##*.}

# GCP console deep-link via the shared `~/bin/bq-console-url` helper
# (single source of truth, shared with rlm-bq-open / rlm-dbt-bq-link /
# dbt-model-preview).
local url
url=$("$HOME/bin/bq-console-url" "${sel_project}:${sel_dataset}.${sel_table}")

print "$url"

if command -v pbcopy >/dev/null 2>&1; then
  print -n "$url" | pbcopy
  print "sandbox-bq-open: URL copied to clipboard" >&2
elif command -v xclip >/dev/null 2>&1; then
  print -n "$url" | xclip -selection clipboard
  print "sandbox-bq-open: URL copied to clipboard" >&2
elif command -v xsel >/dev/null 2>&1; then
  print -n "$url" | xsel --clipboard --input
  print "sandbox-bq-open: URL copied to clipboard" >&2
fi

if command -v open >/dev/null 2>&1; then
  open "$url"
elif command -v xdg-open >/dev/null 2>&1; then
  xdg-open "$url"
fi
