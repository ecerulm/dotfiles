emulate -L zsh
set -o pipefail

if ! command -v gh >/dev/null 2>&1; then
  print -u2 "gh-repo-init: 'gh' not found in PATH"
  return 1
fi
if ! command -v git >/dev/null 2>&1; then
  print -u2 "gh-repo-init: 'git' not found in PATH"
  return 1
fi

# Must be inside a git repo.
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  print -u2 "gh-repo-init: not inside a git repository"
  return 1
fi

# Bail out if a remote already exists (check before complaining about args
# so the user learns the dir is already wired up before being asked for OWNER/REPO).
if git remote | grep -q .; then
  print -u2 "gh-repo-init: remote already configured:"
  git remote -v >&2
  return 1
fi

local repo_slug=$1
if [[ -z $repo_slug ]]; then
  local gh_user
  gh_user=$(gh api user --jq .login) || {
    print -u2 "gh-repo-init: failed to look up GitHub username via 'gh api user'"
    return 1
  }
  local dir_name=${PWD:t}
  repo_slug="${gh_user}/${dir_name}"
  print -u2 "gh-repo-init: no argument provided, defaulting to: ${repo_slug}"
  print -u2 -n "Continue? [y/N] "
  local reply
  read -r reply
  if [[ $reply != [yY] && $reply != [yY][eE][sS] ]]; then
    print -u2 "gh-repo-init: aborted"
    return 1
  fi
fi

gh repo create "$repo_slug" --private --source . --push && gh repo view -w
