emulate -L zsh

# Run a dbt model in local dev mode using deferred state from production.
# See `rlm-dbt-run -h` (or `helpdir/rlm-dbt-run`) for the full description.
#
# Shared implementation lives in _rlm-dbt-cmd; this wrapper just selects
# the dbt subcommand (`run`), the resource type(s) to expose in the picker
# (models only), and the resource type(s) to include in the cost estimate
# (also models). The sibling rlm-dbt-build wraps `dbt build` with models +
# seeds; rlm-dbt-test wraps `dbt test`.

autoload -Uz _rlm-dbt-cmd
_rlm-dbt-cmd run model model "$@"
