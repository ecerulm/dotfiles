emulate -L zsh

# Run a dbt model in local dev mode using deferred state from production.
#
# --defer        Instead of building all upstream dependencies, reuse the
#                nodes that already exist in the --state manifest (the
#                production run). Only nodes missing from prod are built
#                locally, saving time and cost.
#
# --state        Path to a directory containing the reference manifest.json
#                produced by the CI pipeline. dbt uses this to know what
#                prod looks like. Keep it fresh with `dbt-sync-state`.
#
# --profiles-dir Points dbt at the repo-local profiles.yml instead of the
#                default ~/.dbt/profiles.yml, so credentials and targets are
#                version-controlled alongside the project.
#
# --target $DBT_TARGET
#                Selects the target defined in profiles.yml, which typically
#                writes to a personal dataset (e.g. $DBT_DATASET_PREFIX).

local usage="dbt-run [-s SELECTOR] [-n] [-- EXTRA_ARGS...]

Run a dbt model locally with --defer against the production
ref-state. Omit -s to open an fzf picker over dbt models (recently used first).

  -s SELECTOR   dbt node selector; skips the picker
  -n, --list    dry-run: show which nodes will be built locally vs read from
                prod (via --defer), then exit without running dbt
  --            pass any additional arguments straight to dbt

Environment (all required):
  DBT_STATE_DIR      path to dir containing the ref-state manifest.json
  DBT_PROJECT_SUBDIR subdir of the git root containing dbt_project.yml
  DBT_TARGET         dbt target name (e.g. local_dev)
  DBT_DEV_PROJECT    GCP project ID used for local runs
  DBT_DATASET_PREFIX BigQuery dataset name for locally-built models

Examples:
  dbt-run
  dbt-run -s my_model+
  dbt-run -n -s my_model+
  dbt-run -s tag:finance -- --full-refresh"

for _dbt_run_var in DBT_STATE_DIR DBT_PROJECT_SUBDIR DBT_TARGET DBT_DEV_PROJECT DBT_DATASET_PREFIX; do
  if [[ -z ${(P)_dbt_run_var} ]]; then
    print -u2 "dbt-run: \$$_dbt_run_var is not set"
    unset _dbt_run_var
    return 1
  fi
done
unset _dbt_run_var

local selector=""
local list_only=0
local -a extra_args

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    -s)
      [[ -z $2 ]] && { print -u2 "dbt-run: -s requires an argument"; return 1 }
      selector=$2
      shift 2
      ;;
    -n|--list)
      list_only=1
      shift
      ;;
    -h|--help)
      print "$usage"
      return 0
      ;;
    --)
      shift
      extra_args=("$@")
      break
      ;;
    *)
      print -u2 "dbt-run: unknown option: $1"
      print -u2 "$usage"
      return 1
      ;;
  esac
done

# Check ref-state exists and is fresh (< 7 days old)
local state_dir="$DBT_STATE_DIR"
local manifest="$state_dir/manifest.json"

if [[ ! -f $manifest ]]; then
  print -u2 "dbt-run: ref-state manifest not found at $manifest"
  print -u2 "         Run: dbt-sync-state"
  return 1
fi

# mtime check — stat -f %m is macOS; fallback to Linux
local mtime now age
if mtime=$(stat -f %m "$manifest" 2>/dev/null); then
  now=$(date +%s)
  age=$(( now - mtime ))
elif mtime=$(stat -c %Y "$manifest" 2>/dev/null); then
  now=$(date +%s)
  age=$(( now - mtime ))
else
  print -u2 "dbt-run: could not check manifest age (stat failed)"
  age=0
fi

if (( age > 7 * 24 * 3600 )); then
  local days=$(( age / 86400 ))
  print -u2 "dbt-run: ref-state manifest is ${days} days old (> 7 days)"
  print -u2 "         Run: dbt-sync-state"
  return 1
fi

local repo_root
repo_root=$(git root 2>/dev/null) || {
  print -u2 "dbt-run: not inside a git repository"
  return 1
}

local dbt_root="$repo_root/$DBT_PROJECT_SUBDIR"
local profiles_dir="$dbt_root/profile"
if [[ ! -d $profiles_dir ]]; then
  print -u2 "dbt-run: profiles dir not found: $profiles_dir"
  return 1
fi

local dbt_target="$DBT_TARGET"

local cache_dir="$HOME/.cache/dbt-run"
local models_cache="$cache_dir/models.txt"
local history_file="$cache_dir/history.txt"
# history_ts: tab-separated "epoch<TAB>model" entries, newest first
local history_ts_file="$cache_dir/history_ts.txt"
mkdir -p "$cache_dir"

# Fetch model list from dbt ls, save to cache
_dbt_run_fetch_models() {
  print -u2 "dbt-run: fetching model list via dbt ls …"
  local output
  output=$(cd "$dbt_root" && poetry run dbt ls \
    --resource-type model \
    --profiles-dir "$profiles_dir" \
    --target "$dbt_target" \
    --output name \
    --quiet 2>/dev/null) || {
    print -u2 "dbt-run: dbt ls failed; falling back to empty model list"
    return 1
  }
  print -- "$output" >| "$models_cache"
}

# If no -s given, open fzf picker
if [[ -z $selector ]]; then
  # Fetch cache if missing
  if [[ ! -f $models_cache ]]; then
    _dbt_run_fetch_models || true
  fi

  # Helper: format elapsed seconds as human-readable "X ago"
  _dbt_run_elapsed_label() {
    local elapsed=$1
    if (( elapsed < 60 )); then
      print "${elapsed}s ago"
    elif (( elapsed < 3600 )); then
      print "$(( elapsed / 60 ))m ago"
    elif (( elapsed < 86400 )); then
      print "$(( elapsed / 3600 ))h ago"
    else
      print "$(( elapsed / 86400 ))d ago"
    fi
  }

  local now_ts
  now_ts=$(date +%s)

  # Build set of history model names (for exclusion from the unrun list)
  local -A history_seen
  local -a history_lines  # "MODEL_NAME\tLABEL" pairs
  if [[ -f $history_ts_file ]]; then
    while IFS=$'\t' read -r ts model; do
      [[ -z $model ]] && continue
      if [[ -z ${history_seen[$model]:-} ]]; then
        local elapsed=$(( now_ts - ts ))
        local label=$(_dbt_run_elapsed_label "$elapsed")
        history_lines+=("${model}"$'\t'"${label}")
        history_seen[$model]=1
      fi
    done < "$history_ts_file"
  elif [[ -f $history_file ]]; then
    # Migrate legacy plain-name history (no timestamps); show no time label
    while IFS= read -r model; do
      [[ -z $model ]] && continue
      if [[ -z ${history_seen[$model]:-} ]]; then
        history_lines+=("${model}"$'\t'"")
        history_seen[$model]=1
      fi
    done < "$history_file"
  fi

  local cache_age_label=""
  if [[ -f $models_cache ]]; then
    local cmtime cnow celapsed
    cmtime=$(stat -f %m "$models_cache" 2>/dev/null || stat -c %Y "$models_cache" 2>/dev/null)
    cnow=$(date +%s)
    celapsed=$(( cnow - cmtime ))
    if (( celapsed < 60 )); then
      cache_age_label="${celapsed}s ago"
    elif (( celapsed < 3600 )); then
      cache_age_label="$(( celapsed / 60 ))m ago"
    elif (( celapsed < 86400 )); then
      cache_age_label="$(( celapsed / 3600 ))h ago"
    else
      cache_age_label="$(( celapsed / 86400 ))d ago"
    fi
  fi

  local refresh_sentinel="--- REFRESH MODEL CACHE${cache_age_label:+ (cached ${cache_age_label})} ---"

  # fzf input: sentinel, history with labels, then remaining models
  local raw_selection
  raw_selection=$(
    {
      print -- "$refresh_sentinel"
      # History entries: "MODEL  (last run LABEL)" — displayed text
      local entry
      for entry in "${history_lines[@]}"; do
        local m="${entry%%$'\t'*}"
        local lbl="${entry##*$'\t'}"
        if [[ -n $lbl ]]; then
          printf '%s\t(last run %s)\n' "$m" "$lbl"
        else
          printf '%s\t\n' "$m"
        fi
      done
      # Remaining models not in history
      if [[ -f $models_cache ]]; then
        while IFS= read -r model; do
          [[ -z ${history_seen[$model]:-} ]] && printf '%s\t\n' "$model"
        done < "$models_cache"
      fi
    } \
    | fzf --prompt="dbt model> " \
          --height=80% \
          --reverse \
          --no-sort \
          --delimiter=$'\t' \
          --with-nth='1,2' \
          --preview-window=bottom:40%:wrap \
          --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)'
  ) || return 130

  [[ -z $raw_selection ]] && return 130

  if [[ $raw_selection == "--- REFRESH MODEL CACHE"* ]]; then
    rm -f "$models_cache"
    _dbt_run_fetch_models || return 1
    rlm-dbt-run "${extra_args[@]}"
    return $?
  fi

  # Extract just the model name (first tab-delimited field)
  selector="${raw_selection%%$'\t'*}"
fi

# Record selector in history with timestamp (newest first, deduped, max 100)
{
  printf '%s\t%s\n' "$(date +%s)" "$selector"
  if [[ -f $history_ts_file ]]; then
    grep -v $'\t'"${selector}"'$' "$history_ts_file" 2>/dev/null || true
  fi
} | head -100 >| "${history_ts_file}.tmp" && mv "${history_ts_file}.tmp" "$history_ts_file"
# Keep legacy history_file in sync (plain names, for any other consumers)
{
  print -- "$selector"
  [[ -f $history_file ]] && grep -Fxv "$selector" "$history_file" 2>/dev/null || true
} | head -100 >| "${history_file}.tmp" && mv "${history_file}.tmp" "$history_file"

local -a dbt_cmd=(
  poetry run dbt run
  -s "$selector"
  --defer
  --state "$state_dir"
  --profiles-dir "$profiles_dir"
  --target "$dbt_target"
  "${extra_args[@]}"
)

print "dbt-run: selector=$selector"
local age_label
if (( age < 60 )); then
  age_label="${age}s"
elif (( age < 3600 )); then
  age_label="$(( age / 60 ))m"
elif (( age < 86400 )); then
  age_label="$(( age / 3600 ))h"
else
  age_label="$(( age / 86400 ))d"
fi
print "dbt-run: state=$state_dir (${age_label} old)"
print "dbt-run: profiles=$profiles_dir"
print ""

_dbt_run_cost_estimate() {
  print "Estimating query cost (compiling + bq dry-run) …"

  # Find which nodes build locally (not deferred from prod)
  local tmp_local_nodes
  tmp_local_nodes=$(mktemp)
  (
    cd "$dbt_root" && poetry run dbt ls \
      -s "$selector" \
      --resource-type model \
      --defer --state "$state_dir" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --output name --quiet 2>/dev/null \
    | sort
  ) >| "$tmp_local_nodes" 2>/dev/null

  local -a local_nodes
  local_nodes=("${(@f)$(cat "$tmp_local_nodes")}")
  rm -f "$tmp_local_nodes"

  local count_local=${#local_nodes[@]}
  [[ ${local_nodes[1]:-} == '' ]] && count_local=0

  if (( count_local == 0 )); then
    print "  No models will be built locally (all deferred from prod) — cost: \$0.00"
    return 0
  fi

  # Compile to get SQL
  (
    cd "$dbt_root" && poetry run dbt compile \
      -s "$selector" \
      --defer --state "$state_dir" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --quiet 2>/dev/null
  ) || {
    print "  Warning: dbt compile failed; skipping cost estimate"
    return 0
  }

  local compiled_dir="$dbt_root/target/compiled"
  local total_bytes=0
  local -a failed_models

  for node in "${local_nodes[@]}"; do
    [[ -z $node ]] && continue
    local model_name="${node##*.}"
    # Find compiled SQL (may be nested under project name subdirs)
    local sql_file
    sql_file=$(find "$compiled_dir" -name "${model_name}.sql" -type f 2>/dev/null | head -1)
    if [[ -z $sql_file ]]; then
      failed_models+=("$model_name (compiled SQL not found)")
      continue
    fi
    local dry_out
    dry_out=$(bq query --dry_run --use_legacy_sql=false < "$sql_file" 2>&1)
    local rc=$?
    if (( rc != 0 )); then
      failed_models+=("$model_name (bq dry-run failed)")
      continue
    fi
    # bq dry-run output: "Query successfully validated. Assuming the tables are not modified,
    # running this query will process X bytes of data."
    local bytes
    bytes=$(print -- "$dry_out" | grep -oE '[0-9]+ bytes' | grep -oE '[0-9]+' | head -1)
    if [[ -n $bytes ]]; then
      total_bytes=$(( total_bytes + bytes ))
    else
      failed_models+=("$model_name (could not parse bytes from: $dry_out)")
    fi
  done

  # Format total size and cost via python3 (avoids zsh float issues)
  local _py_out size_label cost_dollars
  _py_out=$(python3 - "$total_bytes" <<'PYEOF'
import sys
b = int(sys.argv[1])
if b >= 1_000_000_000_000:
    size = f"{b/1_000_000_000_000:.2f} TB"
elif b >= 1_000_000_000:
    size = f"{b/1_000_000_000:.2f} GB"
elif b >= 1_000_000:
    size = f"{b/1_000_000:.2f} MB"
else:
    size = f"{b/1_000:.1f} KB"
cost = b / 1e12 * 6.25
print(f"{size}|${cost:.4f}")
PYEOF
  )
  size_label="${_py_out%%|*}"
  cost_dollars="${_py_out##*|}"

  print ""
  print "  Models building locally : $count_local"
  print "  Data processed estimate : $size_label"
  print "  Cost estimate           : $cost_dollars  (@ \$6.25/TB)"
  if (( ${#failed_models[@]} )); then
    print "  Warnings (excluded from estimate):"
    for m in "${failed_models[@]}"; do
      print "    - $m"
    done
  fi
  print ""
}

if ! (( list_only )); then
  _dbt_run_cost_estimate
  print -n "Proceed? [Y/n] "
  local answer
  read -r answer
  case ${answer:-Y} in
    [Yy]*|'') ;;
    *) print "Aborted."; return 1 ;;
  esac
  print ""
fi
if (( list_only )); then
  print "Resolving relations (this may take a moment) …"

  # Capture system python3 before any poetry subshell can shadow it
  local system_python3
  system_python3=$(whence -p python3)

  local tmp_local tmp_all
  tmp_local=$(mktemp)
  tmp_all=$(mktemp)

  # Run both dbt ls calls in parallel (MONITOR off to suppress job notifications)
  setopt LOCAL_OPTIONS
  unsetopt MONITOR
  (
    cd "$dbt_root" && poetry run dbt ls \
      -s "$selector" \
      --resource-type model \
      --defer --state "$state_dir" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --output name --quiet 2>/dev/null \
    | sort >| "$tmp_local"
  ) &
  local pid_local=$!

  (
    cd "$dbt_root" && poetry run dbt ls \
      -s "+${selector}" \
      --resource-type model \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --output name --quiet 2>/dev/null \
    | sort >| "$tmp_all"
  ) &
  local pid_all=$!

  wait $pid_local $pid_all

  # Nodes in all-upstream but not in the deferred-local set → read from prod
  local -a local_nodes deferred_nodes
  local_nodes=("${(@f)$(cat "$tmp_local")}")
  deferred_nodes=("${(@f)$(comm -23 "$tmp_all" "$tmp_local")}")

  rm -f "$tmp_local" "$tmp_all"

  # filter empty strings (empty array quirk when dbt ls returns nothing)
  local count_local=${#local_nodes[@]}
  [[ ${local_nodes[1]:-} == '' ]] && count_local=0
  local count_def=${#deferred_nodes[@]}
  [[ ${deferred_nodes[1]:-} == '' ]] && count_def=0

  local dev_project="$DBT_DEV_PROJECT"
  local dev_dataset="$DBT_DATASET_PREFIX"

  # Build fzf input: "TAG|dbt_name|bq_ref" per line
  # TAG: LOCAL or PROD
  # bq_ref: project:dataset.table (bq CLI format, derived from relation_name)
  local tmp_fzf
  tmp_fzf=$(mktemp)

  if (( count_local )); then
    for node in "${local_nodes[@]}"; do
      local model_name="${node##*.}"
      printf 'LOCAL|%s|%s:%s.%s\n' \
        "$node" "$dev_project" "$dev_dataset" "$model_name" >> "$tmp_fzf"
    done
  fi

  if (( count_def )); then
    # Parse all deferred relations from prod manifest in one python3 call.
    # Write script to a temp file so stdin is free for the node list pipe.
    local tmp_py tmp_rel
    tmp_py=$(mktemp -t dbt-run-rel.XXXXXX)
    tmp_rel=$(mktemp -t dbt-run-rel.XXXXXX)
    cat >| "$tmp_py" <<'PYEOF'
import json, sys
manifest_path = sys.argv[1]
with open(manifest_path) as f:
    nodes = json.load(f)['nodes']
idx = {}
for k, v in nodes.items():
    if v.get('resource_type') == 'model':
        idx[v['name']] = v.get('relation_name', '')
for line in sys.stdin:
    node_name = line.strip()
    if not node_name:
        continue
    model_name = node_name.split('.')[-1]
    rel = idx.get(model_name) or ''
    # relation_name is `project`.`dataset`.`table` — convert to project:dataset.table
    parts = [p.strip('`') for p in rel.split('`.`')]
    if len(parts) == 3:
        bq_ref = f"{parts[0]}:{parts[1]}.{parts[2]}"
    else:
        bq_ref = ''
    print(f"{node_name}|{bq_ref}")
PYEOF
    printf '%s\n' "${deferred_nodes[@]}" \
      | "$system_python3" "$tmp_py" "$manifest" >| "$tmp_rel"
    while IFS='|' read -r node bq_ref; do
      printf 'PROD|%s|%s\n' "$node" "$bq_ref" >> "$tmp_fzf"
    done < "$tmp_rel"
    rm -f "$tmp_py" "$tmp_rel"
  fi

  # Write preview script to a temp file — avoids quoting/splitting issues
  # with passing multiline scripts via --preview="zsh -c '...'"
  local tmp_preview
  tmp_preview=$(mktemp -t dbt-run-preview.XXXXXX)
  cat >| "$tmp_preview" <<PREVIEW_EOF
#!/bin/zsh
# fzf passes the selected line as \$1; format is "TAG|dbt_name|bq_ref"
line=\$1
tag=\${line%%|*}
rest=\${line#*|}
dbt_name=\${rest%%|*}
bq_ref=\${rest##*|}

print "Model  : \$dbt_name"
print "Source : \$tag"
print "BQ ref : \$bq_ref"
print ""

if [[ -z \$bq_ref ]]; then
  print "(relation unknown — model not found in prod manifest)"
  exit 0
fi

raw=\$(bq show --format=json "\$bq_ref" 2>&1)
rc=\$?
if (( rc != 0 )); then
  print "(not yet materialized in BigQuery)"
  print ""
  print "\$raw"
  exit 0
fi

printf '%s' "\$raw" | python3 -c "
import json, sys
raw = sys.stdin.buffer.read()
d = json.loads(raw.decode('utf-8', errors='replace'))
ref = d.get('tableReference', {})
logical = int(d.get('numTotalLogicalBytes') or 0)
rows    = int(d.get('numRows') or 0)
if logical >= 1_000_000_000:
    size = f'{logical/1_000_000_000:.2f} GB'
elif logical >= 1_000_000:
    size = f'{logical/1_000_000:.2f} MB'
else:
    size = f'{logical/1_000:.1f} KB'
from datetime import datetime, timezone
last_mod_ms = int(d.get('lastModifiedTime') or 0)
last_mod = datetime.fromtimestamp(last_mod_ms / 1000, tz=timezone.utc).strftime('%Y-%m-%d %H:%M UTC') if last_mod_ms else '?'
print(f'Type         : {d.get(\"type\", \"?\")}')
print(f'Project      : {ref.get(\"projectId\", \"?\")}')
print(f'Dataset      : {ref.get(\"datasetId\", \"?\")}')
print(f'Table        : {ref.get(\"tableId\", \"?\")}')
print(f'Last updated : {last_mod}')
print(f'Rows         : {rows:,}')
print(f'Logical bytes: {size}')
"
PREVIEW_EOF
  chmod +x "$tmp_preview"

  fzf --read0 \
      --prompt="dbt-run -n > " \
      --height=80% \
      --reverse \
      --no-sort \
      --no-mouse \
      --with-nth='1,2' \
      --delimiter='|' \
      --preview="$tmp_preview {}" \
      --preview-window=bottom:40%:wrap \
      --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
      < <(tr '\n' '\0' < "$tmp_fzf")

  rm -f "$tmp_fzf" "$tmp_preview"
  return 0
fi

print "$ ${dbt_cmd[*]}"
print ""

"${dbt_cmd[@]}"
