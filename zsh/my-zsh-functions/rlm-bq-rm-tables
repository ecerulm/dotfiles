emulate -L zsh
setopt LOCAL_OPTIONS NO_MONITOR
set -o pipefail

if [[ -z $SANDBOX_BQ_PROJECT ]]; then
  print -u2 "bq-rm-tables: SANDBOX_BQ_PROJECT is not set"
  return 1
fi
if [[ -z $SANDBOX_BQ_DATASETS ]]; then
  print -u2 "bq-rm-tables: SANDBOX_BQ_DATASETS is not set"
  return 1
fi

for cmd in bq fzf jq; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    print -u2 "bq-rm-tables: '$cmd' not found in PATH"
    return 1
  fi
done

# Shared cache + history wiring. All five rlm-bq-* / rlm-sandbox-bq-*
# commands share one cache pair (~/.cache/bq-open/<md5>.txt and
# -sandbox.txt) and one pooled history TSV (~/.cache/bq-open/history.tsv)
# via these helpers. See zsh/AGENTS.md "Current internal helpers".
autoload -Uz _rlm-bq-cache _rlm-bq-history _rlm-bq-dead-refs-gc _rlm-bq-refresh-sentinels

# Garbage-collect any refs that bq-preview marked as dead on a previous
# run. No-op when ~/.cache/bq-open/dead-refs.txt is missing/empty.
_rlm-bq-dead-refs-gc

# Resolve current cache-key, paths.
local key cache sandbox
eval "$(_rlm-bq-cache paths)" || return 1

# Fetch on first run if no sandbox cache exists yet
if [[ ! -f $sandbox ]]; then
  _rlm-bq-cache refresh --sandbox-only || return 1
fi

# Tab-delimited format for fzf lines: DISPLAY_TAG<TAB>BQ_REF
# DISPLAY_TAG is the ANSI open code that colours the whole line purple
# (this command is sandbox-only); the RESET lives at the end of the
# BQ_REF field. --with-nth=1,2 shows both fields; --nth=2 restricts
# match highlighting to the BQ ref field so fzf never injects highlight
# codes before the colour opener.
local PURPLE=$'\033[35m'
local RESET=$'\033[0m'
local SANDBOX_TAG="$PURPLE"   # colour opener — closed by RESET appended to BQ_REF

# Sentinel (tab-prefixed for --with-nth=2 layout) comes from the
# shared _rlm-bq-refresh-sentinels helper.
local refresh_sandbox_sentinel
refresh_sandbox_sentinel=$(_rlm-bq-refresh-sentinels emit-sandbox --tab)

# Build set of sandbox bq_refs visible in the current cache. Pooled
# history may contain entries from other scopes or non-sandbox refs;
# we suppress those so the picker never offers a ref this command
# can't actually delete.
local -A in_scope
local _ref
while IFS= read -r _ref; do
  [[ -n $_ref ]] && in_scope[$_ref]=1
done < <(_rlm-bq-cache read --sandbox)

# Build the picker input from the pooled history.tsv. Each line:
#   <epoch>\t<command>\t<bq_ref>\t<flags>
# Render as tab-delimited PURPLE_TAG\tBQ_REF (every line in this picker
# is sandbox-scoped).
_bq_rm_history_lines() {
  local ts cmd ref flags
  while IFS=$'\t' read -r ts cmd ref flags; do
    [[ -z $ref ]] && continue
    [[ -z ${in_scope[$ref]:-} ]] && continue
    printf '%s\t%s%s\n' "$SANDBOX_TAG" "$ref" "$RESET"
  done < <(_rlm-bq-history read)
}

# Sandbox cache entries (every entry rendered purple).
_bq_rm_sandbox_lines() {
  while IFS= read -r line; do
    [[ -n $line ]] && printf '%s\t%s%s\n' "$SANDBOX_TAG" "$line" "$RESET"
  done < <(_rlm-bq-cache read --sandbox)
}

local fzf_out
fzf_out=$(
  {
    print -- "$refresh_sandbox_sentinel"
    # History first (recents from any rlm-bq-* command, filtered to
    # sandbox-scope), then remaining sandbox cache entries. awk dedupes
    # on the ANSI-stripped bq_ref so the same ref never appears twice.
    _bq_rm_history_lines
    _bq_rm_sandbox_lines
  } \
  | awk -F'\t' '
    { key = $2; gsub(/\033\[[0-9;]*m/, "", key); if (!seen[key]++) print }' \
  | fzf \
      --prompt="Select tables to DELETE (TAB=multi)> " \
      --ansi \
      --no-mouse \
      --multi \
      --height=80% --reverse \
      --delimiter=$'\t' \
      --with-nth=1,2 \
      --nth=2 \
      --preview='raw=$(printf "%s" {} | cut -f2 | sed "s/\x1b\[[0-9;]*m//g"); case "$raw" in ---*) echo "Select to refresh the sandbox cache and reopen the picker." ;; *) "$HOME/bin/bq-preview" "$raw" ;; esac' \
      --preview-window=bottom:40%:wrap \
      --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
      --bind='ctrl-g:abort'
) || return 130

if [[ -z $fzf_out ]]; then
  print -u2 "bq-rm-tables: no selection made"
  return 130
fi

# Parse fzf output: one tab-delimited row per selection.
# Field 2 is the BQ ref (with trailing ANSI reset to strip).
local -a to_delete to_delete_colored
local sel_line sel_ref sel_proj sel_ds_table sel_ds sel_tbl
local refresh_picked=0
while IFS= read -r sel_line; do
  [[ -z $sel_line ]] && continue
  sel_ref=$(printf '%s' "${sel_line#*$'\t'}" | sed 's/\x1b\[[0-9;]*m//g')
  if _rlm-bq-refresh-sentinels is-sandbox "$sel_ref"; then
    refresh_picked=1
    continue
  fi
  to_delete+=("$sel_ref")
  sel_proj=${sel_ref%%:*}
  sel_ds_table=${sel_ref##*:}
  sel_ds=${sel_ds_table%%.*}
  sel_tbl=${sel_ds_table##*.}
  # Colorize: project=cyan, dataset=yellow, table=green
  to_delete_colored+=("$(print -P "%F{cyan}${sel_proj}%f:%F{yellow}${sel_ds}%f.%F{green}${sel_tbl}%f")")
done <<< "$fzf_out"

if (( refresh_picked )); then
  _rlm-bq-refresh-sentinels apply-sandbox || return 1
  rlm-bq-rm-tables
  return $?
fi

if (( ${#to_delete} == 0 )); then
  print -u2 "bq-rm-tables: could not parse selection"
  return 1
fi

print ""
print "The following tables/views will be PERMANENTLY DELETED:"
local i
for (( i = 1; i <= ${#to_delete_colored}; i++ )); do
  print "  - ${to_delete_colored[$i]}"
done
print ""

local confirm
vared -p "Type 'yes' to confirm deletion: " confirm

if [[ $confirm != "yes" ]]; then
  print "bq-rm-tables: deletion cancelled"
  return 1
fi

local failed=0
local ref
for ref in "${to_delete[@]}"; do
  print -u2 "bq-rm-tables: deleting ${ref} …"
  if bq rm --force --table "$ref" 2>&1; then
    print "bq-rm-tables: deleted ${ref}"
    _rlm-bq-history append bq-rm-tables "$ref" sandbox deleted
  else
    print -u2 "bq-rm-tables: FAILED to delete ${ref}"
    failed=1
  fi
done

# Refresh the sandbox cache so deleted tables drop out of subsequent picks.
_rlm-bq-cache refresh --sandbox-only

return $failed
