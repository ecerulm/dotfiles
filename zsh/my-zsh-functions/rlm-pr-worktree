# pr-worktree: pick a PR or JIRA issue via fzf and create a sibling git
# worktree.
#
# Sources (current repo only), shown in this order in the picker:
#   1. GitHub PRs where you opened/commented/reviewed/were assigned/were
#      mentioned (gh search prs --involves=@me).
#   2. JIRA issues that matter to you, via the shared
#      ~/.cache/rlm-jira/ cache (assigned -> reporter -> watching ->
#      DATA-only, with previously-picked tickets floating to the top).
#      The cache is populated on first call to either rlm-jira-pick or
#      rlm-pr-worktree; to force a refresh, run rlm-jira-pick and pick
#      the REFRESH sentinel. Skipped silently if acli is missing or
#      unauthenticated.
#   3. Other open PRs in the repo that don't involve you, so you can pick
#      up a teammate's PR to review locally.
#
# Selecting a PR     -> worktree at ../<repo>-pr-<N>      on the PR branch.
# Selecting an issue -> prompts (vared) for an optional suffix:
#   * empty   -> worktree ../<repo>-<KEY>            branch <KEY>/feat/<key_lowercased>
#                (e.g. DATA-1234 -> branch DATA-1234/feat/data_1234)
#   * "foo bar" -> worktree ../<repo>-<KEY>-foo-bar  branch <KEY>/feat/foo_bar
# In both cases the new branch is created off origin/<default-branch>.
#
# After the picker (and the optional JIRA suffix prompt), a second vared
# prompt lets you edit the final worktree directory name (basename only;
# parent is always the repo's sibling). Press Enter to accept the default.
#
# Usage: pr-worktree [PR_NUMBER | JIRA_KEY | --suffix SUFFIX]
#   - no arg             -> fzf picker (JIRA selections also prompt for suffix)
#   - PR num             -> skip picker, treat as PR
#   - JIRA key           -> skip picker, treat as JIRA issue (e.g. DATA-1234);
#                           still prompts for the optional suffix
#   - --suffix SUFFIX    -> create worktree at ../<repo>-<SUFFIX> off default branch
#   - -s SUFFIX          -> same as --suffix
#
# Requires: gh, git, fzf. acli is optional (enables JIRA rows).

emulate -L zsh
set -o pipefail

for cmd in gh git fzf; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    print -u2 "pr-worktree: '$cmd' not found in PATH"
    return 1
  fi
done

autoload -Uz _rlm-jira-cache _rlm-jira-history _rlm-jira-sorted-rows

local repo_root repo_slug repo_name
repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
  print -u2 "pr-worktree: not inside a git repository"
  return 1
}
repo_slug=$(git -C "$repo_root" -c gh.protocol=https config --get remote.origin.url 2>/dev/null \
  | sed -E 's#(git@github\.com:|https://github\.com/)##; s#\.git$##')
if [[ -z $repo_slug ]]; then
  repo_slug=$(cd -- "$repo_root" && gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null)
fi
if [[ -z $repo_slug ]]; then
  print -u2 "pr-worktree: could not resolve GitHub repo (gh repo view failed)"
  return 1
fi
repo_name=${repo_root:t}

# --- helpers ---------------------------------------------------------------

_prwt_default_branch() {
  local b
  b=$(git -C "$repo_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null)
  if [[ -n $b ]]; then
    print -- "${b#origin/}"
    return 0
  fi
  ( cd -- "$repo_root" && gh repo view --json defaultBranchRef -q .defaultBranchRef.name 2>/dev/null )
}

_prwt_make_pr_worktree() {
  local pr_number=$1
  local default_dirname=${repo_name}-pr-${pr_number}
  _prwt_prompt_dirname "$default_dirname" || {
    print -u2 "pr-worktree: cancelled (empty worktree name)"
    return 1
  }
  local worktree_path=${repo_root:h}/${_prwt_dirname_out}

  if [[ -e $worktree_path ]]; then
    print "pr-worktree: $worktree_path already exists; entering it."
    cd -- "$worktree_path"
    git pull
    return 0
  fi

  local pr_branch
  pr_branch=$(cd -- "$repo_root" && gh pr view "$pr_number" --json headRefName -q .headRefName) || return 1

  print "pr-worktree: creating worktree at $worktree_path for PR #$pr_number ($pr_branch)"

  git -C "$repo_root" fetch origin "pull/${pr_number}/head:pr-${pr_number}" 2>/dev/null \
    || git -C "$repo_root" fetch origin "$pr_branch" 2>/dev/null

  if git -C "$repo_root" worktree add "$worktree_path" "$pr_branch" 2>/dev/null; then
    :
  elif git -C "$repo_root" worktree add "$worktree_path" "pr-${pr_number}" 2>/dev/null; then
    :
  else
    print -u2 "pr-worktree: failed to create worktree for PR #$pr_number"
    return 1
  fi

  cd -- "$worktree_path"
  git pull
}

_prwt_make_suffix_worktree() {
  local suffix=$1
  local default_dirname=${repo_name}-${suffix}
  _prwt_prompt_dirname "$default_dirname" || {
    print -u2 "pr-worktree: cancelled (empty worktree name)"
    return 1
  }
  local worktree_path=${repo_root:h}/${_prwt_dirname_out}

  if [[ -e $worktree_path ]]; then
    print "pr-worktree: $worktree_path already exists; entering it."
    cd -- "$worktree_path"
    git pull
    return 0
  fi

  local default_branch
  default_branch=$(_prwt_default_branch) || default_branch=main
  [[ -z $default_branch ]] && default_branch=main

  print "pr-worktree: creating worktree at $worktree_path on new branch $suffix off origin/$default_branch"
  git -C "$repo_root" fetch origin "$default_branch" 2>/dev/null

  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$suffix"; then
    git -C "$repo_root" worktree add "$worktree_path" "$suffix" || return 1
  else
    git -C "$repo_root" worktree add -b "$suffix" "$worktree_path" "origin/$default_branch" || return 1
  fi

  cd -- "$worktree_path"
  git pull
}

# Normalize a free-form suffix into a token using the given separator.
# Collapses runs of non-alphanumerics into a single separator, trims
# leading/trailing separators, and lowercases the result. The two callers
# pass '-' (path) and '_' (branch slug) so e.g. "Fix BQ Cost-Bug" becomes
# "fix-bq-cost-bug" for the path and "fix_bq_cost_bug" for the branch.
_prwt_slug() {
  local raw=$1 sep=$2
  print -r -- "${raw}" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E "s/[^a-z0-9]+/${sep}/g; s/^${sep}+//; s/${sep}+\$//"
}

# Prompt the user to optionally edit a worktree suffix for a JIRA key.
# Writes the (possibly empty) sanitized suffix into the global
# `_prwt_suffix_out`. Empty result means "keep the legacy behavior"
# (worktree at ../<repo>-<KEY>, branch = <KEY>).
#
# Same caveat as `_prwt_prompt_dirname`: vared cannot run inside
# `$(...)` — call this helper as a plain statement, not via command
# substitution.
_prwt_prompt_suffix() {
  local key=$1
  typeset -g _prwt_suffix_out=''
  local suffix=''
  vared -p "pr-worktree: suffix for $key (Enter = none, e.g. 'fix bq cost') > " suffix
  _prwt_suffix_out=$(_prwt_slug "$suffix" '-')
}

# Prompt the user to edit the final worktree directory name (the basename,
# not the full path — the parent is always ${repo_root:h}). Pre-fills with
# the proposed default name so the user can just press Enter to accept, or
# tweak the tail.
#
# IMPORTANT: vared requires an interactive zle session and CANNOT be called
# from inside `$(...)` (command substitution forks a subshell where zle is
# unavailable; even `</dev/tty` won't save it — the redirect itself fails
# with "device not configured" when stdin is a pipe from fzf). So this
# helper writes the result into the global `_prwt_dirname_out` and must be
# called as a plain statement, not via `name=$(_prwt_prompt_dirname ...)`.
#
# Returns 0 with `_prwt_dirname_out` set to the chosen name (default or
# edited). Returns 1 if the user cleared the input — caller should treat
# that as cancel.
_prwt_prompt_dirname() {
  local default_name=$1
  typeset -g _prwt_dirname_out=$default_name
  vared -p "pr-worktree: worktree dir (under ${repo_root:h}/) > " _prwt_dirname_out
  [[ -z $_prwt_dirname_out ]] && return 1
  return 0
}

_prwt_make_jira_worktree() {
  local key=${1:u}
  local suffix=${2:-}
  local path_slug branch_slug default_dirname worktree_path branch
  if [[ -n $suffix ]]; then
    path_slug=$(_prwt_slug "$suffix" '-')
    branch_slug=$(_prwt_slug "$suffix" '_')
  fi
  # Always use <KEY>/feat/<slug> branch structure for JIRA picks.
  # When no suffix is provided, default the slug to the lowercased key
  # (with '-' -> '_'), e.g. DATA-1234 -> DATA-1234/feat/data_1234.
  if [[ -n $path_slug ]]; then
    default_dirname=${repo_name}-${key}-${path_slug}
    branch=${key}/feat/${branch_slug}
  else
    default_dirname=${repo_name}-${key}
    branch=${key}/feat/$(_prwt_slug "$key" '_')
  fi

  _prwt_prompt_dirname "$default_dirname" || {
    print -u2 "pr-worktree: cancelled (empty worktree name)"
    return 1
  }
  worktree_path=${repo_root:h}/${_prwt_dirname_out}

  if [[ -e $worktree_path ]]; then
    print "pr-worktree: $worktree_path already exists; entering it."
    cd -- "$worktree_path"
    git pull
    return 0
  fi

  local default_branch
  default_branch=$(_prwt_default_branch) || default_branch=main
  [[ -z $default_branch ]] && default_branch=main

  print "pr-worktree: creating worktree at $worktree_path on new branch $branch off origin/$default_branch"
  git -C "$repo_root" fetch origin "$default_branch" 2>/dev/null

  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$repo_root" worktree add "$worktree_path" "$branch" || return 1
  else
    git -C "$repo_root" worktree add -b "$branch" "$worktree_path" "origin/$default_branch" || return 1
  fi

  cd -- "$worktree_path"
  git pull
}

# --- direct-arg fast path --------------------------------------------------

local arg=$1
if [[ -n $arg ]]; then
  if [[ $arg == '--suffix' || $arg == '-s' ]]; then
    local suffix=$2
    if [[ -z $suffix ]]; then
      print -u2 "pr-worktree: --suffix requires a value"
      return 1
    fi
    _prwt_make_suffix_worktree "$suffix"
    return $?
  elif [[ $arg =~ '^[0-9]+$' ]]; then
    _prwt_make_pr_worktree "$arg"
    return $?
  elif [[ $arg =~ '^[A-Za-z][A-Za-z0-9_]+-[0-9]+$' ]]; then
    local key=${arg:u}
    _prwt_prompt_suffix "$key"
    _prwt_make_jira_worktree "$key" "$_prwt_suffix_out"
    return $?
  else
    print -u2 "pr-worktree: argument must be a PR number, a JIRA key (e.g. DATA-1234), or --suffix SUFFIX"
    return 1
  fi
fi

# --- gather rows -----------------------------------------------------------
#
# Row format consumed by the picker (single line, tab-separated for the
# preview key, but rendered as plain text):
#   PR     #1234  [draft]  Title (branch) [author]
#   JIRA   DATA-1234  [In Progress]  Summary [assignee]

local -a rows
local pr_rows jira_rows other_pr_rows pr_involved_json

pr_involved_json=$(
  gh search prs \
    --repo "$repo_slug" \
    --involves=@me \
    --state=open \
    --limit=200 \
    --json number,title,author,isDraft,updatedAt 2>/dev/null
)

pr_rows=$(
  print -r -- "$pr_involved_json" \
  | jq -r '
      sort_by(.updatedAt) | reverse | .[] |
      "PR\t#\(.number)\t\(if .isDraft then "[draft]" else "[ready]" end)\t\(.title)\t[\(.author.login)]"
    ' 2>/dev/null
)

# All other open PRs in the repo, excluding the ones already listed above.
local involved_numbers
involved_numbers=$(print -r -- "$pr_involved_json" | jq -r '.[].number' 2>/dev/null | paste -sd, -)
other_pr_rows=$(
  gh pr list \
    --repo "$repo_slug" \
    --state open \
    --limit 200 \
    --json number,title,author,isDraft,updatedAt 2>/dev/null \
  | jq -r --arg involved "$involved_numbers" '
      ($involved | split(",") | map(select(length > 0) | tonumber)) as $skip |
      sort_by(.updatedAt) | reverse | .[] |
      select(.number as $n | ($skip | index($n)) | not) |
      "PR\t#\(.number)\t\(if .isDraft then "[draft]" else "[ready]" end)\t\(.title)\t[\(.author.login)]"
    ' 2>/dev/null
)

if command -v acli >/dev/null 2>&1 && acli jira auth status >/dev/null 2>&1; then
  # Ensure the shared JIRA cache exists; refresh once on cold cache.
  if ! _rlm-jira-cache read >/dev/null 2>&1; then
    _rlm-jira-cache refresh >/dev/null 2>&1 || true
  fi
  # Reshape the helper's 7-field rows
  #   <group>\t<KEY>\t<status>\t<summary>\t<assignee>\t<updated_epoch>\t<last_commented_epoch>
  # into pr-worktree's expected 5-field rows
  #   JIRA\t<KEY>\t[<status>]\t<summary>\t[<assignee>]
  # The two trailing epoch fields exist only for the composite-key
  # sort that _rlm-jira-sorted-rows applies upstream; they don't
  # surface in the picker's visible columns.
  jira_rows=$(
    _rlm-jira-sorted-rows 2>/dev/null \
      | awk -F'\t' 'BEGIN{OFS="\t"} NF>=7 {print "JIRA", $2, "[" $3 "]", $4, "[" $5 "]"}'
  )
fi

if [[ -z $pr_rows && -z $jira_rows && -z $other_pr_rows ]]; then
  print -u2 "pr-worktree: no PRs or JIRA issues found in $repo_slug"
  return 1
fi

# Pretty-print into fzf using column for alignment.
#
# NOTE: `setopt local_options no_pipefail` inside this subshell is
# REQUIRED. Without it, the function exits silently right after the
# user picks an entry — the underlying mechanic is:
#
#   1. fzf renders the first screenful of candidates and stops
#      reading from stdin until you scroll past what it has buffered.
#   2. Upstream of fzf, `column -t` keeps writing into a pipe whose
#      reader has paused. With a large input (the new 4-group JIRA
#      cache, up to 1500 issues, vs the old 100-cap), column eventually
#      gets SIGPIPE and dies with exit status 141.
#   3. The function-scope `set -o pipefail` propagates that 141 out
#      through the `$(...)` substitution. `|| return 130` then fires
#      and the function returns silently, after the user has already
#      picked — no vared prompt, no worktree, no error message.
#
# This bug was latent before the rlm-jira-cache refactor because the
# old per-call `acli jira workitem search --limit 100` produced too
# few rows to trigger SIGPIPE in practice. The fix is local to the
# picker subshell; outer pipefail (which legitimately guards the jq
# pipelines that build pr_rows / other_pr_rows / jira_rows above)
# stays in effect.
local selection
selection=$(
  setopt local_options no_pipefail
  {
    [[ -n $pr_rows       ]] && print -- "$pr_rows"
    [[ -n $jira_rows     ]] && print -- "$jira_rows"
    [[ -n $other_pr_rows ]] && print -- "$other_pr_rows"
  } \
  | column -t -s $'\t' \
  | fzf --ansi --prompt='PR/JIRA> ' --height=80% --reverse \
        --no-mouse \
        --header='Yours first, then your JIRA, then other open PRs. Enter = create worktree. Ctrl-P: toggle preview' \
        --preview='
          line={};
          kind=$(echo "$line" | awk "{print \$1}");
          if [ "$kind" = "PR" ]; then
            num=$(echo "$line" | sed -E "s/^PR[[:space:]]+#([0-9]+).*/\1/");
            gh pr view "$num";
          else
            key=$(echo "$line" | awk "{print \$2}");
            acli jira workitem view "$key" 2>/dev/null || echo "(install/auth acli to preview $key)";
          fi
        ' \
        --preview-window=bottom:40%:wrap \
        --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
        --bind='ctrl-g:abort'
) || return 130
[[ -z $selection ]] && return 130

local kind=${selection%% *}
case $kind in
  PR)
    local pr_number
    pr_number=$(print -- "$selection" | sed -E 's/^PR[[:space:]]+#([0-9]+).*/\1/')
    _prwt_make_pr_worktree "$pr_number"
    ;;
  JIRA)
    local key jira_rc
    key=$(print -- "$selection" | awk '{print $2}')
    key=${key:u}
    _prwt_prompt_suffix "$key"
    _prwt_make_jira_worktree "$key" "$_prwt_suffix_out"
    jira_rc=$?
    if [[ $jira_rc -eq 0 ]]; then
      _rlm-jira-history append "$key" >/dev/null 2>&1 || true
    fi
    return $jira_rc
    ;;
  *)
    print -u2 "pr-worktree: could not parse selection: $selection"
    return 1
    ;;
esac
