# pr-worktree: pick a PR or JIRA issue via fzf and create a sibling git
# worktree.
#
# Sources (current repo only), shown in this order in the picker:
#   1. All open PRs in the repo updated in the last 2 weeks, sorted by
#      updatedAt desc. Rows authored by you are highlighted in green so
#      they stand out from teammates' PRs.
#   2. JIRA issues that matter to you, via the shared
#      ~/.cache/rlm-jira/ cache (assigned -> reporter -> watching ->
#      DATA-only, with previously-picked tickets floating to the top).
#      The cache is populated on first call to either rlm-jira-pick or
#      rlm-pr-worktree; to force a refresh, pick the REFRESH sentinel
#      at the top of the picker (or run rlm-jira-pick and pick its
#      REFRESH sentinel). Skipped silently if acli is missing or
#      unauthenticated.
#   3. A CUSTOM sentinel row. Picking it prompts (vared) for a free-form
#      suffix; the slugified suffix becomes BOTH the worktree dirname
#      tail and the new branch name (off origin/<default-branch>).
#   4. A REFRESH sentinel row (only when acli is available). Picking it
#      re-runs `_rlm-jira-cache refresh` and re-opens the picker with
#      the fresh JIRA rows.
#
# Selecting a PR     -> worktree at ../<repo>-pr-<N>      on the PR branch.
# Selecting CUSTOM   -> worktree at ../<repo>-<slug>      branch <slug>.
# Selecting an issue -> prompts (vared) for an optional suffix:
#   * empty   -> worktree ../<repo>-<KEY>            branch <KEY>/feat/<key_lowercased>
#                (e.g. DATA-1234 -> branch DATA-1234/feat/data_1234)
#   * "foo bar" -> worktree ../<repo>-<KEY>-foo-bar  branch <KEY>/feat/foo_bar
# In both cases the new branch is created off origin/<default-branch>.
#
# After the picker (and the optional JIRA suffix prompt), a second vared
# prompt lets you edit the final worktree directory name (basename only;
# parent is always the repo's sibling). Press Enter to accept the default.
#
# Usage: pr-worktree [PR_NUMBER | JIRA_KEY | --suffix SUFFIX]
#   - no arg             -> fzf picker (JIRA selections also prompt for suffix)
#   - PR num             -> skip picker, treat as PR
#   - JIRA key           -> skip picker, treat as JIRA issue (e.g. DATA-1234);
#                           still prompts for the optional suffix
#   - --suffix SUFFIX    -> create worktree at ../<repo>-<SUFFIX> off default branch
#   - -s SUFFIX          -> same as --suffix
#
# Requires: gh, git, fzf. acli is optional (enables JIRA rows).

emulate -L zsh
set -o pipefail

for cmd in gh git fzf; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    print -u2 "pr-worktree: '$cmd' not found in PATH"
    return 1
  fi
done

autoload -Uz _rlm-jira-cache _rlm-jira-history _rlm-jira-sorted-rows

local repo_root main_root repo_slug repo_name
repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
  print -u2 "pr-worktree: not inside a git repository"
  return 1
}
# When invoked from inside a secondary worktree, `--show-toplevel` returns
# the *worktree* root, not the main repo. New worktrees must be siblings of
# the main repo (the one originally cloned), not siblings of whichever
# worktree we happen to be in. `--git-common-dir` always points at the main
# repo's .git directory, regardless of which worktree is the cwd; its
# parent is the main repo root.
main_root=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
main_root=${main_root:h}
[[ -z $main_root ]] && main_root=$repo_root
repo_slug=$(git -C "$repo_root" -c gh.protocol=https config --get remote.origin.url 2>/dev/null \
  | sed -E 's#(git@github\.com:|https://github\.com/)##; s#\.git$##')
if [[ -z $repo_slug ]]; then
  repo_slug=$(cd -- "$repo_root" && gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null)
fi
if [[ -z $repo_slug ]]; then
  print -u2 "pr-worktree: could not resolve GitHub repo (gh repo view failed)"
  return 1
fi
repo_name=${main_root:t}

# --- helpers ---------------------------------------------------------------

_prwt_default_branch() {
  local b
  b=$(git -C "$repo_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null)
  if [[ -n $b ]]; then
    print -- "${b#origin/}"
    return 0
  fi
  ( cd -- "$repo_root" && gh repo view --json defaultBranchRef -q .defaultBranchRef.name 2>/dev/null )
}

_prwt_make_pr_worktree() {
  local pr_number=$1
  # Optional free-form suffix (slug-normalized). Symmetrical with the
  # JIRA flow's _prwt_prompt_suffix: empty -> legacy <repo>-pr-<N>;
  # non-empty -> <repo>-pr-<N>-<slug>. The follow-up
  # `_prwt_prompt_dirname` still lets the user edit the full basename
  # before the worktree is actually created.
  _prwt_prompt_suffix "PR #$pr_number"
  local today
  today=$(date +%Y%m%d)
  local default_dirname=${repo_name}-${today}-pr-${pr_number}
  [[ -n $_prwt_suffix_out ]] && default_dirname=${default_dirname}-${_prwt_suffix_out}
  _prwt_prompt_dirname "$default_dirname" || {
    print -u2 "pr-worktree: cancelled (empty worktree name)"
    return 1
  }
  local worktree_path=${main_root:h}/${_prwt_dirname_out}

  if [[ -e $worktree_path ]]; then
    print "pr-worktree: $worktree_path already exists; entering it."
    cd -- "$worktree_path"
    git pull
    return 0
  fi

  local pr_branch
  pr_branch=$(cd -- "$repo_root" && gh pr view "$pr_number" --json headRefName -q .headRefName) || return 1

  print "pr-worktree: creating worktree at $worktree_path for PR #$pr_number ($pr_branch)"

  # Create an EMPTY worktree (only .git) on a detached HEAD, then let
  # `gh pr checkout` create and configure the branch inside it. This is
  # the key to getting the upstream right: gh sets tracking the way only
  # gh knows how — for same-repo PRs it tracks `origin/<headRef>`; for
  # fork PRs it sets `branch.<name>.remote` to the fork URL and
  # `branch.<name>.merge` to `refs/heads/<headRef>` so `git pull` works
  # with no args. The old approach (pre-create the branch with `git
  # worktree add <branch>`, falling back to a synthetic `pr-<N>` branch,
  # then `gh pr checkout -f` to fix up tracking) left the upstream unset
  # whenever the fallback path hit, because the `pr-<N>` branch name does
  # not match the PR head ref and gh would not (re)configure tracking for
  # it. `--detach --no-checkout` claims no branch name, so gh is free to
  # create the real one.
  if ! git -C "$repo_root" worktree add --detach --no-checkout "$worktree_path" HEAD 2>/dev/null; then
    print -u2 "pr-worktree: failed to create worktree for PR #$pr_number"
    return 1
  fi

  cd -- "$worktree_path"
  if ! gh pr checkout "$pr_number"; then
    print -u2 "pr-worktree: gh pr checkout failed; removing empty worktree"
    cd -- "$repo_root"
    git -C "$repo_root" worktree remove --force "$worktree_path" 2>/dev/null
    return 1
  fi
  git pull
}

# Verify that a freshly-created local branch's upstream is configured as a
# same-name branch on origin, NOT the default branch. Defense-in-depth
# against `branch.autoSetupMerge` (or any other mechanism) silently wiring
# the new branch up to track origin/<default> instead of the explicit
# `branch.<name>.{remote,merge}` config set right after creation.
#
# Checks the *configured* tracking (`branch.<name>.remote` /
# `branch.<name>.merge`) rather than resolving `<name>@{upstream}` via
# `git rev-parse`: at this point the branch has just been created locally
# and has NOT been pushed yet, so the remote-tracking ref
# `refs/remotes/origin/<name>` doesn't exist. `@{upstream}` resolution
# requires that ref to exist and fails with "unknown revision" on an
# unpushed branch even when the tracking config is entirely correct.
_prwt_verify_upstream() {
  local worktree_path=$1 branch=$2 cfg_remote cfg_merge
  cfg_remote=$(git -C "$worktree_path" config --get "branch.${branch}.remote" 2>/dev/null)
  cfg_merge=$(git -C "$worktree_path" config --get "branch.${branch}.merge" 2>/dev/null)
  if [[ -z $cfg_remote || -z $cfg_merge ]]; then
    print -u2 "pr-worktree: BUG: branch '$branch' has no upstream configured"
    return 1
  fi
  if [[ $cfg_remote != origin || $cfg_merge != "refs/heads/${branch}" ]]; then
    print -u2 "pr-worktree: BUG: branch '$branch' upstream is '${cfg_remote}/${cfg_merge#refs/heads/}' (expected origin/$branch)"
    return 1
  fi
}

_prwt_make_suffix_worktree() {
  local suffix=$1
  local today
  today=$(date +%Y%m%d)
  local default_dirname=${repo_name}-${today}-${suffix}
  _prwt_prompt_dirname "$default_dirname" || {
    print -u2 "pr-worktree: cancelled (empty worktree name)"
    return 1
  }
  local worktree_path=${main_root:h}/${_prwt_dirname_out}

  if [[ -e $worktree_path ]]; then
    print "pr-worktree: $worktree_path already exists; entering it."
    cd -- "$worktree_path"
    git pull
    return 0
  fi

  local default_branch
  default_branch=$(_prwt_default_branch) || default_branch=main
  [[ -z $default_branch ]] && default_branch=main

  print "pr-worktree: creating worktree at $worktree_path on new branch $suffix off origin/$default_branch"
  git -C "$repo_root" fetch origin "$default_branch" 2>/dev/null

  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$suffix"; then
    git -C "$repo_root" worktree add "$worktree_path" "$suffix" || return 1
  else
    git -C "$repo_root" worktree add -b "$suffix" "$worktree_path" "origin/$default_branch" || return 1
    git -C "$worktree_path" config "branch.${suffix}.remote" origin
    git -C "$worktree_path" config "branch.${suffix}.merge" "refs/heads/${suffix}"
    _prwt_verify_upstream "$worktree_path" "$suffix" || return 1
  fi

  cd -- "$worktree_path"
  git pull --no-rebase 2>/dev/null || true
}

# Normalize a free-form suffix into a token using the given separator.
# Collapses runs of non-alphanumerics into a single separator, trims
# leading/trailing separators, and lowercases the result. The two callers
# pass '-' (path) and '_' (branch slug) so e.g. "Fix BQ Cost-Bug" becomes
# "fix-bq-cost-bug" for the path and "fix_bq_cost_bug" for the branch.
_prwt_slug() {
  local raw=$1 sep=$2
  print -r -- "${raw}" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E "s/[^a-z0-9]+/${sep}/g; s/^${sep}+//; s/${sep}+\$//"
}

# Prompt the user to optionally edit a worktree suffix for a JIRA key.
# Writes the (possibly empty) sanitized suffix into the global
# `_prwt_suffix_out`. Empty result means "keep the legacy behavior"
# (worktree at ../<repo>-<KEY>, branch = <KEY>).
#
# Same caveat as `_prwt_prompt_dirname`: vared cannot run inside
# `$(...)` — call this helper as a plain statement, not via command
# substitution.
_prwt_prompt_suffix() {
  local key=$1
  typeset -g _prwt_suffix_out=''
  local suffix=''
  vared -p "pr-worktree: suffix for $key (Enter = none, e.g. 'fix bq cost') > " suffix
  _prwt_suffix_out=$(_prwt_slug "$suffix" '-')
}

# Prompt the user to edit the final worktree directory name (the basename,
# not the full path — the parent is always ${main_root:h}). Pre-fills with
# the proposed default name so the user can just press Enter to accept, or
# tweak the tail.
#
# IMPORTANT: vared requires an interactive zle session and CANNOT be called
# from inside `$(...)` (command substitution forks a subshell where zle is
# unavailable; even `</dev/tty` won't save it — the redirect itself fails
# with "device not configured" when stdin is a pipe from fzf). So this
# helper writes the result into the global `_prwt_dirname_out` and must be
# called as a plain statement, not via `name=$(_prwt_prompt_dirname ...)`.
#
# Returns 0 with `_prwt_dirname_out` set to the chosen name (default or
# edited). Returns 1 if the user cleared the input — caller should treat
# that as cancel.
_prwt_prompt_dirname() {
  local default_name=$1
  typeset -g _prwt_dirname_out=$default_name
  vared -p "pr-worktree: worktree dir (under ${main_root:h}/) > " _prwt_dirname_out
  [[ -z $_prwt_dirname_out ]] && return 1
  return 0
}

_prwt_make_jira_worktree() {
  local key=${1:u}
  local suffix=${2:-}
  local path_slug branch_slug default_dirname worktree_path branch
  if [[ -n $suffix ]]; then
    path_slug=$(_prwt_slug "$suffix" '-')
    branch_slug=$(_prwt_slug "$suffix" '_')
  fi
  # Always use <KEY>/feat/<slug> branch structure for JIRA picks.
  # When no suffix is provided, default the slug to the lowercased key
  # (with '-' -> '_'), e.g. DATA-1234 -> DATA-1234/feat/data_1234.
  local today
  today=$(date +%Y%m%d)
  if [[ -n $path_slug ]]; then
    default_dirname=${repo_name}-${today}-${key}-${path_slug}
    branch=${key}/feat/${branch_slug}
  else
    default_dirname=${repo_name}-${today}-${key}
    branch=${key}/feat/$(_prwt_slug "$key" '_')
  fi

  _prwt_prompt_dirname "$default_dirname" || {
    print -u2 "pr-worktree: cancelled (empty worktree name)"
    return 1
  }
  worktree_path=${main_root:h}/${_prwt_dirname_out}

  if [[ -e $worktree_path ]]; then
    print "pr-worktree: $worktree_path already exists; entering it."
    cd -- "$worktree_path"
    git pull
    return 0
  fi

  local default_branch
  default_branch=$(_prwt_default_branch) || default_branch=main
  [[ -z $default_branch ]] && default_branch=main

  print "pr-worktree: creating worktree at $worktree_path on new branch $branch off origin/$default_branch"
  git -C "$repo_root" fetch origin "$default_branch" 2>/dev/null

  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$repo_root" worktree add "$worktree_path" "$branch" || return 1
  else
    git -C "$repo_root" worktree add -b "$branch" "$worktree_path" "origin/$default_branch" || return 1
    git -C "$worktree_path" config "branch.${branch}.remote" origin
    git -C "$worktree_path" config "branch.${branch}.merge" "refs/heads/${branch}"
    _prwt_verify_upstream "$worktree_path" "$branch" || return 1
  fi

  cd -- "$worktree_path"
  git pull --no-rebase 2>/dev/null || true
}

# --- direct-arg fast path --------------------------------------------------

local arg=$1
if [[ -n $arg ]]; then
  if [[ $arg == '--suffix' || $arg == '-s' ]]; then
    local suffix=$2
    if [[ -z $suffix ]]; then
      print -u2 "pr-worktree: --suffix requires a value"
      return 1
    fi
    _prwt_make_suffix_worktree "$suffix"
    return $?
  elif [[ $arg =~ '^[0-9]+$' ]]; then
    _prwt_make_pr_worktree "$arg"
    return $?
  elif [[ $arg =~ '^[A-Za-z][A-Za-z0-9_]+-[0-9]+$' ]]; then
    local key=${arg:u}
    _prwt_prompt_suffix "$key"
    _prwt_make_jira_worktree "$key" "$_prwt_suffix_out"
    return $?
  else
    print -u2 "pr-worktree: argument must be a PR number, a JIRA key (e.g. DATA-1234), or --suffix SUFFIX"
    return 1
  fi
fi

# --- gather rows -----------------------------------------------------------
#
# Row format consumed by the picker (single line, tab-separated for the
# preview key, but rendered as plain text):
#   PR     #1234  [draft]  Title (branch) [author]
#   JIRA   DATA-1234  [In Progress]  Summary [assignee]

local -a rows
local pr_rows jira_rows jira_available='' jira_cache_age='' me cutoff_date

# Current GitHub login, used by the picker's awk filter to color rows
# you authored. Empty string if `gh api` fails — coloring is then a no-op
# and every row renders uncolored, which is a safe fallback.
me=$(gh api user --jq .login 2>/dev/null)

# Date cutoff for the `updated:>` search qualifier. 14 days back from
# today in YYYY-MM-DD form. GNU and BSD date have incompatible flag
# syntax; -v is BSD/macOS, -d is GNU/Linux.
if cutoff_date=$(date -v-14d +%Y-%m-%d 2>/dev/null); then
  : # BSD/macOS path
else
  cutoff_date=$(date -d '14 days ago' +%Y-%m-%d 2>/dev/null) || cutoff_date=""
fi

# Single query: every open PR in this repo updated in the last 2 weeks.
# `gh search prs` accepts free-form qualifiers via positional args; we
# pass `updated:>YYYY-MM-DD` so the API does the date filtering server-
# side instead of pulling 200 PRs and trimming locally.
pr_rows=$(
  gh search prs \
    --repo "$repo_slug" \
    --state=open \
    --limit=200 \
    --json number,title,author,isDraft,updatedAt \
    ${cutoff_date:+"updated:>$cutoff_date"} 2>/dev/null \
  | jq -r '
      sort_by(.updatedAt) | reverse | .[] |
      "PR\t#\(.number)\t\(if .isDraft then "[draft]" else "[ready]" end)\t\(.title)\t[\(.author.login)]"
    ' 2>/dev/null
)

if command -v acli >/dev/null 2>&1 && acli jira auth status >/dev/null 2>&1; then
  jira_available=1
  # Ensure the shared JIRA cache exists; refresh once on cold cache.
  if ! _rlm-jira-cache read >/dev/null 2>&1; then
    _rlm-jira-cache refresh >/dev/null 2>&1 || true
  fi
  jira_cache_age=$(_rlm-jira-cache age 2>/dev/null)
  # Reshape the helper's 7-field rows
  #   <group>\t<KEY>\t<status>\t<summary>\t<assignee>\t<updated_epoch>\t<last_commented_epoch>
  # into pr-worktree's expected 5-field rows
  #   JIRA\t<KEY>\t[<status>]\t<summary>\t[<assignee>]
  # The two trailing epoch fields exist only for the composite-key
  # sort that _rlm-jira-sorted-rows applies upstream; they don't
  # surface in the picker's visible columns.
  jira_rows=$(
    _rlm-jira-sorted-rows 2>/dev/null \
      | awk -F'\t' 'BEGIN{OFS="\t"} NF>=7 {print "JIRA", $2, "[" $3 "]", $4, "[" $5 "]"}'
  )
fi

if [[ -z $pr_rows && -z $jira_rows ]]; then
  print -u2 "pr-worktree: no PRs or JIRA issues found in $repo_slug"
  return 1
fi

# Pretty-print into fzf using column for alignment.
#
# NOTE: `setopt local_options no_pipefail` inside this subshell is
# REQUIRED. Without it, the function exits silently right after the
# user picks an entry — the underlying mechanic is:
#
#   1. fzf renders the first screenful of candidates and stops
#      reading from stdin until you scroll past what it has buffered.
#   2. Upstream of fzf, `column -t` keeps writing into a pipe whose
#      reader has paused. With a large input (the new 4-group JIRA
#      cache, up to 1500 issues, vs the old 100-cap), column eventually
#      gets SIGPIPE and dies with exit status 141.
#   3. The function-scope `set -o pipefail` propagates that 141 out
#      through the `$(...)` substitution. `|| return 130` then fires
#      and the function returns silently, after the user has already
#      picked — no vared prompt, no worktree, no error message.
#
# This bug was latent before the rlm-jira-cache refactor because the
# old per-call `acli jira workitem search --limit 100` produced too
# few rows to trigger SIGPIPE in practice. The fix is local to the
# picker subshell; outer pipefail (which legitimately guards the jq
# pipelines that build pr_rows / other_pr_rows / jira_rows above)
# stays in effect.
local selection
selection=$(
  setopt local_options no_pipefail
  {
    # Sentinel (always first, when JIRA is reachable): pick this to
    # refresh the shared ~/.cache/rlm-jira/ cache and reopen the picker
    # with fresh JIRA rows. Handled by the REFRESH branch of the
    # selection case below. The "(cached <age>)" suffix mirrors the
    # rlm-bq-* / rlm-jira-pick refresh sentinels.
    if [[ -n $jira_available ]]; then
      local age_label="${jira_cache_age:-unknown}"
      print -- $'REFRESH\t--- REFRESH JIRA CACHE (cached '"${age_label}"$') ---'
    fi
    # Sentinel: pick this to be prompted for a free-form suffix that
    # becomes both the worktree dirname tail and the branch name.
    # Handled by the CUSTOM branch of the selection case below.
    print -- $'CUSTOM\t<type your own worktree name>'
    [[ -n $pr_rows   ]] && print -- "$pr_rows"
    [[ -n $jira_rows ]] && print -- "$jira_rows"
  } \
  | column -t -s $'\t' \
  | awk -v me="$me" '
      # Color PR rows authored by $me green. column -t already aligned the
      # row, so injecting ANSI here does not skew widths. The author marker
      # is the trailing "[<login>]" field; matching it against me is enough
      # to identify the row regardless of how column padded the columns.
      BEGIN { reset = "\033[0m"; green = "\033[32m" }
      {
        if (me != "" && match($0, /\[[^][]+\][[:space:]]*$/)) {
          author = substr($0, RSTART + 1, RLENGTH - 2)
          sub(/[[:space:]]+$/, "", author)
          if (author == me) { print green $0 reset; next }
        }
        print
      }
    ' \
  | fzf --ansi --prompt='PR/JIRA> ' --height=80% --reverse \
        --no-mouse \
        --expect=ctrl-r \
        --header='PRs updated in last 2 weeks (green = you), then your JIRA. Enter = create worktree. Ctrl-R: refresh JIRA cache. Ctrl-P: toggle preview' \
        --preview='
          line={};
          kind=$(echo "$line" | awk "{print \$1}");
          if [ "$kind" = "PR" ]; then
            num=$(echo "$line" | sed -E "s/^PR[[:space:]]+#([0-9]+).*/\1/");
            gh pr view "$num";
          elif [ "$kind" = "CUSTOM" ]; then
            echo "Pick this to be prompted for a free-form suffix.";
            echo "";
            echo "The suffix is normalized to a slug (e.g. \"fix bq cost\" -> \"fix-bq-cost\")";
            echo "and used as BOTH the worktree dirname tail AND the new branch name,";
            echo "branched off origin/<default-branch>.";
          elif [ "$kind" = "REFRESH" ]; then
            echo "Refresh the shared ~/.cache/rlm-jira/ cache and reopen this picker";
            echo "with fresh JIRA rows.";
            echo "";
            echo "Shortcut: press Ctrl-R from any row to do the same thing without";
            echo "having to navigate to this sentinel first.";
          else
            key=$(echo "$line" | awk "{print \$2}");
            acli jira workitem view "$key" 2>/dev/null || echo "(install/auth acli to preview $key)";
          fi
        ' \
        --preview-window=bottom:40%:wrap \
        --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
        --bind='ctrl-g:abort'
) || return 130
[[ -z $selection ]] && return 130

# --expect=ctrl-r prepends a key line ("ctrl-r" or empty for Enter) to
# fzf's output. Split into key + the actual selected row.
local fzf_key=${selection%%$'\n'*}
local selection_line=${selection#*$'\n'}
[[ -z $selection_line || $selection_line == "$fzf_key" ]] && selection_line=''

if [[ $fzf_key == ctrl-r ]]; then
  if [[ -z $jira_available ]]; then
    # jira_available is set only when both `command -v acli` AND
    # `acli jira auth status` succeed. Distinguish the two failure modes
    # so the user knows whether to install acli or just authenticate.
    if ! command -v acli >/dev/null 2>&1; then
      print -u2 "pr-worktree: ctrl-r refresh requires acli (not found in PATH)"
    else
      print -u2 "pr-worktree: ctrl-r refresh requires JIRA auth — run 'acli jira auth login'"
    fi
    return 1
  fi
  print "pr-worktree: refreshing JIRA cache..."
  _rlm-jira-cache refresh >/dev/null 2>&1 || {
    print -u2 "pr-worktree: failed to refresh JIRA cache"
    return 1
  }
  rlm-pr-worktree
  return $?
fi

[[ -z $selection_line ]] && return 130
selection=$selection_line

local kind=${selection%% *}
case $kind in
  REFRESH)
    print "pr-worktree: refreshing JIRA cache..."
    _rlm-jira-cache refresh >/dev/null 2>&1 || {
      print -u2 "pr-worktree: failed to refresh JIRA cache"
      return 1
    }
    rlm-pr-worktree
    return $?
    ;;
  PR)
    local pr_number
    pr_number=$(print -- "$selection" | sed -E 's/^PR[[:space:]]+#([0-9]+).*/\1/')
    _prwt_make_pr_worktree "$pr_number"
    ;;
  JIRA)
    local key jira_rc
    key=$(print -- "$selection" | awk '{print $2}')
    key=${key:u}
    _prwt_prompt_suffix "$key"
    _prwt_make_jira_worktree "$key" "$_prwt_suffix_out"
    jira_rc=$?
    if [[ $jira_rc -eq 0 ]]; then
      _rlm-jira-history append "$key" >/dev/null 2>&1 || true
    fi
    return $jira_rc
    ;;
  CUSTOM)
    # Prompt for a free-form suffix; both the path tail and the branch
    # name are derived from it. Same vared caveat as the other prompts:
    # call as a plain statement, not via $(...).
    local custom_raw='' custom_suffix
    vared -p "pr-worktree: worktree suffix (also used as branch name, e.g. 'fix bq cost') > " custom_raw
    custom_suffix=$(_prwt_slug "$custom_raw" '-')
    if [[ -z $custom_suffix ]]; then
      print -u2 "pr-worktree: cancelled (empty suffix)"
      return 1
    fi
    _prwt_make_suffix_worktree "$custom_suffix"
    ;;
  *)
    print -u2 "pr-worktree: could not parse selection: $selection"
    return 1
    ;;
esac
