# pr-worktree-rm-merged-closed: automatically delete every git worktree in
# the current repo that is safe to discard without losing work. Two cases:
#
#   1. merged/closed PR — the branch has a GitHub PR in state `merged` or
#      `closed`; any leftover changes are stale rebase/merge debris.
#   2. no-pr + no-diff — the branch has no PR and no commits ahead of
#      origin/main (`git log --oneline origin/main..<branch>` is empty);
#      the worktree was created but never actually worked on.
#
# Builds the same branch -> pr_state map that pr-worktree-rm uses
# (`gh pr list --state all --limit 500 --json number,state,headRefName`),
# walks `git worktree list --porcelain`, and selects every worktree in
# either category above. The current worktree and the main/primary worktree
# are always excluded — same gate as pr-worktree-rm.
#
# Lists what it's about to delete and asks for a single y/N confirmation
# before touching anything. Use --yes / -y to skip the prompt (intended
# for cron / scripted use). Use --dry-run / -n to just print the list and
# exit 0.
#
# Each worktree is removed with `git worktree remove`; on failure it
# retries with `--force` (matches pr-worktree-rm semantics). `git worktree
# prune` runs once at the end.
#
# Worktrees with `pr-status = open` are LEFT ALONE. Worktrees with no PR
# that have commits ahead of origin/main are also left alone — use
# pr-worktree-rm for the interactive picker in those cases.
#
# Usage:
#   pr-worktree-rm-merged-closed             # interactive (prompts y/N)
#   pr-worktree-rm-merged-closed --yes       # skip confirmation
#   pr-worktree-rm-merged-closed --dry-run   # list and exit, do not delete
#
# Requires: gh, git, jq

emulate -L zsh
set -o pipefail

local yes=0 dry_run=0
local arg
for arg in "$@"; do
  case $arg in
    -y | --yes) yes=1 ;;
    -n | --dry-run) dry_run=1 ;;
    -h | --help)
      print -- "usage: pr-worktree-rm-merged-closed [--yes|-y] [--dry-run|-n]"
      return 0
      ;;
    *)
      print -u2 "pr-worktree-rm-merged-closed: unknown arg: $arg"
      return 1
      ;;
  esac
done

for cmd in gh git jq; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    print -u2 "pr-worktree-rm-merged-closed: '$cmd' not found in PATH"
    return 1
  fi
done

local repo_root
repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
  print -u2 "pr-worktree-rm-merged-closed: not inside a git repository"
  return 1
}

# Identify the main/primary worktree (first entry of `git worktree list --porcelain`).
local main_worktree
main_worktree=$(git -C "$repo_root" worktree list --porcelain | awk '/^worktree /{print $2; exit}')

local current_worktree
current_worktree=$(git rev-parse --show-toplevel)

# Build a map: branch -> "<state>#<number>" (state lower-cased), by
# querying all PRs (any state) once. Same query as pr-worktree-rm.
local -A pr_state
local pr_json
pr_json=$(gh pr list --state all --limit 500 --json number,state,headRefName 2>/dev/null) || pr_json='[]'
while IFS=$'\t' read -r branch state number; do
  [[ -z $branch ]] && continue
  pr_state[$branch]="${(L)state}#${number}"
done < <(print -r -- "$pr_json" | jq -r '.[] | [.headRefName, .state, .number] | @tsv')

# Walk worktrees, collect the ones whose PR is merged/closed OR that have
# no PR and no commits ahead of origin/main (never actually worked on).
local -a abs_paths display_lines
local wt_path="" wt_branch=""

_prwtrmc_consider() {
  local wt_abs=$1 branch=$2
  [[ -z $branch ]] && return 0                          # detached HEAD: leave alone
  [[ $wt_abs == $main_worktree || $wt_abs == $current_worktree ]] && return 0

  local rel_path=${wt_abs#${repo_root:h}/}
  [[ $rel_path == $wt_abs ]] && rel_path=$wt_abs

  local entry=${pr_state[$branch]:-}
  if [[ -z $entry ]]; then
    # Not in the bulk map (no PR, or PR beyond the --limit 500 cap).
    # Ask gh directly so we don't miss PRs that fell off the --limit 500 cap.
    local pr_check
    pr_check=$(gh pr list --head "$branch" --state all --json number,state 2>/dev/null) || pr_check='[]'
    if [[ $pr_check != '[]' && $pr_check != '' ]]; then
      # A PR exists — take the first (most recent) one.
      local pr_st pr_num
      pr_st=$(print -r -- "$pr_check" | jq -r '.[0].state // empty' 2>/dev/null)
      pr_num=$(print -r -- "$pr_check" | jq -r '.[0].number // empty' 2>/dev/null)
      [[ -z $pr_st ]] && return 0
      entry="${(L)pr_st}#${pr_num}"
      # fall through to the merged/closed check below
    else
      # Truly no PR — only auto-delete if the branch has no commits ahead of origin/main.
      local ahead
      ahead=$(git -C "$repo_root" rev-list --count "origin/main..${branch}" 2>/dev/null) || return 0
      (( ahead > 0 )) && return 0                       # has unmerged work: leave alone
      abs_paths+=("$wt_abs")
      display_lines+=("$(printf '%s\t%s\tno-pr/no-diff' "$rel_path" "$branch")")
      return 0
    fi
  fi

  local pr_state_str=${entry%#*}                        # open | closed | merged
  local pr_number=${entry#*#}

  case $pr_state_str in
    closed | merged) ;;                                 # fall through to add
    *) return 0 ;;                                      # open / unknown -> skip
  esac

  abs_paths+=("$wt_abs")
  display_lines+=("$(printf '%s\t%s\t%s#%s' "$rel_path" "$branch" "$pr_state_str" "$pr_number")")
}

while IFS= read -r line; do
  case $line in
    worktree\ *)
      wt_path=${line#worktree }
      wt_branch=""
      ;;
    branch\ *)
      wt_branch=${line#branch refs/heads/}
      ;;
    "")
      [[ -n $wt_path ]] && _prwtrmc_consider "$wt_path" "$wt_branch"
      wt_path=""
      wt_branch=""
      ;;
  esac
done < <(git -C "$repo_root" worktree list --porcelain)

# Handle trailing block if porcelain output didn't end with a blank line.
[[ -n $wt_path ]] && _prwtrmc_consider "$wt_path" "$wt_branch"

if (( ${#abs_paths} == 0 )); then
  print "pr-worktree-rm-merged-closed: no deletable worktrees found (excluding main and current)."
  return 0
fi

# Pretty-print the list (column-aligned) so the user can sanity-check.
local pretty
pretty=$(printf '%s\n' "${display_lines[@]}" | column -t -s $'\t')

print "pr-worktree-rm-merged-closed: worktrees to delete (merged/closed PR or no-pr/no-diff):"
print -- "$pretty"

if (( dry_run )); then
  print
  print "(dry-run: nothing deleted)"
  return 0
fi

if (( ! yes )); then
  print
  print -n "Delete the ${#abs_paths} worktree(s) listed above? [y/N] "
  local reply
  read -r reply
  if [[ ${reply:l} != y && ${reply:l} != yes ]]; then
    print "Aborted."
    return 1
  fi
fi

local failed=0 i
for (( i = 1; i <= ${#abs_paths}; i++ )); do
  local p=${abs_paths[$i]}
  local d=${display_lines[$i]%%$'\t'*}                  # rel_path for display
  local err
  if git -C "$repo_root" worktree remove "$p" 2>/dev/null; then
    print "removed: $d"
  elif err=$(git -C "$repo_root" worktree remove --force "$p" 2>&1); then
    print "removed (force): $d"
  else
    print -u2 "failed:  $d ($p)"
    print -u2 "  hint: $(git -C "$repo_root" worktree remove "$p" 2>&1 || true)"
    [[ -n $err ]] && print -u2 "  force: $err"
    failed=$(( failed + 1 ))
  fi
done

git -C "$repo_root" worktree prune

return $failed
