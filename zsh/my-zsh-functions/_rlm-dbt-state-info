emulate -L zsh

# Locate the dbt prod ref-state manifest (the one synced by dbt-sync-state
# into $DBT_STATE_DIR/manifest.json) and report it as `key=value` lines on
# stdout, suitable for `eval`. Centralizes the env-var name, the path
# (`$DBT_STATE_DIR/manifest.json`), the freshness check, and the
# stat-mtime-with-Linux-fallback that was previously duplicated across
# _rlm-dbt-cmd and the manifest-fallback path in rlm-dbt-ls.
#
# Usage:
#   _rlm-dbt-state-info [--require] [--max-age-days N] [--label LBL]
#
#   --require           Treat missing/unset DBT_STATE_DIR, missing
#                       manifest.json, or a too-old manifest as a hard
#                       failure (return 1, diagnostic to stderr). Without
#                       --require, the same conditions are a soft failure
#                       (return 2, nothing on stdout, nothing on stderr).
#   --max-age-days N    Maximum manifest age in days. When set and the
#                       manifest is older, the check fails per --require
#                       semantics. Omit to skip the freshness check.
#   --label LBL         Prefix for stderr diagnostics (e.g. "dbt-run",
#                       "dbt-build"). Defaults to "dbt-state-info".
#
# Stdout (on success): one shell-assignable line per key:
#   state_dir=<absolute path>
#   manifest=<absolute path to manifest.json>
#   age_seconds=<integer>
#   age_label=<human-readable, e.g. "3h" / "12d" / "45s">
#
# Return codes:
#   0 — success; stdout populated.
#   1 — hard failure (only with --require); stderr explains and points to
#       `dbt-sync-state` for fixable cases.
#   2 — soft failure (only without --require); silent. Caller treats this
#       as "no usable state available" and proceeds without it.
#   3 — usage error (bad flag).

local require=0
local max_age_days=0
local label="dbt-state-info"

while [[ $# -gt 0 ]]; do
  case $1 in
    --require)
      require=1
      shift
      ;;
    --max-age-days)
      [[ -z ${2:-} ]] && { print -u2 "_rlm-dbt-state-info: --max-age-days requires a value"; return 3 }
      max_age_days=$2
      shift 2
      ;;
    --label)
      [[ -z ${2:-} ]] && { print -u2 "_rlm-dbt-state-info: --label requires a value"; return 3 }
      label=$2
      shift 2
      ;;
    *)
      print -u2 "_rlm-dbt-state-info: unknown option: $1"
      return 3
      ;;
  esac
done

_rlm_dbt_state_info_fail() {
  # $1 = stderr message body (no prefix). Honored only when --require is set.
  if (( require )); then
    print -u2 "${label}: $1"
    return 1
  fi
  return 2
}

if [[ -z ${DBT_STATE_DIR:-} ]]; then
  _rlm_dbt_state_info_fail "\$DBT_STATE_DIR is not set"
  return $?
fi

local state_dir="$DBT_STATE_DIR"
local manifest="${state_dir}/manifest.json"

if [[ ! -f $manifest ]]; then
  _rlm_dbt_state_info_fail "ref-state manifest not found at $manifest
         Run: dbt-sync-state"
  return $?
fi

# stat mtime with macOS / Linux fallback. Centralized here so callers don't
# each reinvent it. Treat stat failure as "age unknown, age=0" — better than
# refusing to use a manifest we can clearly see.
local mtime now age
if mtime=$(stat -f %m "$manifest" 2>/dev/null); then
  now=$(date +%s)
  age=$(( now - mtime ))
elif mtime=$(stat -c %Y "$manifest" 2>/dev/null); then
  now=$(date +%s)
  age=$(( now - mtime ))
else
  age=0
fi

if (( max_age_days > 0 && age > max_age_days * 24 * 3600 )); then
  local days=$(( age / 86400 ))
  _rlm_dbt_state_info_fail "ref-state manifest is ${days} days old (> ${max_age_days} days)
         Run: dbt-sync-state"
  return $?
fi

local age_label
if (( age < 60 )); then
  age_label="${age}s"
elif (( age < 3600 )); then
  age_label="$(( age / 60 ))m"
elif (( age < 86400 )); then
  age_label="$(( age / 3600 ))h"
else
  age_label="$(( age / 86400 ))d"
fi

print -- "state_dir=$state_dir"
print -- "manifest=$manifest"
print -- "age_seconds=$age"
print -- "age_label=$age_label"
