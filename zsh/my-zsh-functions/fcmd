# fcmd — fuzzy-pick any zsh alias, function, builtin, reserved word, or $PATH
# command, with a preview of what the name resolves to.
#
# The preview pane shows the alias expansion + function body (for things only
# the running shell knows about) or `type` / executable path (for everything
# else). On selection the resolved definition is printed to stdout and the bare
# name is pushed onto the next command line (via `print -z`) so you can edit and
# run it.
#
# Usage: fcmd [initial-query]
#
# Requires: fzf.

emulate -L zsh
setopt local_options pipe_fail

(( $+commands[fzf] )) || {
  print -u2 "fcmd: 'fzf' not found in PATH"
  return 1
}

local tmpdir
tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/fcmd.XXXXXX") || return 1
{
  local defdir="$tmpdir/def"
  mkdir -p -- "$defdir"

  # Pre-render the names that need the *running* shell to inspect: aliases and
  # functions. `whence -va` captures the whole resolution chain (alias ->
  # function -> file), so the file is also enough when the same name is a
  # builtin/command; the function body is appended when there is one.
  # Names starting with `_` (completion functions, internal helpers) are skipped.
  local n
  for n in "${(@k)aliases}" "${(@k)functions}"; do
    [[ $n == _* || $n == */* || -e "$defdir/$n" ]] && continue
    {
      whence -va -- "$n" 2>/dev/null
      if (( ${+functions[$n]} )); then
        print
        functions -- "$n" 2>/dev/null
      fi
    } >"$defdir/$n" 2>/dev/null
  done

  # The candidate list: every name we know about, deduped and sorted, minus
  # anything starting with `_`.
  local list
  list=$(print -rl -- \
    "${(@k)aliases}" "${(@k)functions}" "${(@k)builtins}" \
    "${reswords[@]}" "${(@k)commands}" | sort -u | sed '/^_/d')

  local preview='
    n={}
    if [ -f "$FCMD_DEFDIR/$n" ]; then
      cat "$FCMD_DEFDIR/$n"
    else
      type "$n" 2>/dev/null || command -v "$n" 2>/dev/null || printf "%s\n" "$n"
    fi
  '

  local picked
  picked=$(print -r -- "$list" | FCMD_DEFDIR="$defdir" fzf \
    --height=70% --reverse --no-multi --cycle \
    --query="${1:-}" --prompt='cmd> ' \
    --preview="$preview" --preview-window=right:60%:wrap) || return

  [[ -n $picked ]] || return

  if [[ -f "$defdir/$picked" ]]; then
    cat -- "$defdir/$picked"
  else
    whence -va -- "$picked"
  fi
  print -z -- "$picked "
} always {
  rm -rf -- "$tmpdir"
}
