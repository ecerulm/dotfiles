emulate -L zsh
set -o pipefail

if [[ -z $BQ_SEARCH_PATH && -z $SANDBOX_BQ_PROJECT ]]; then
  print -u2 "bq-open: BQ_SEARCH_PATH or SANDBOX_BQ_PROJECT must be set"
  print -u2 "Set BQ_SEARCH_PATH to a colon-separated list of GCP projects, e.g.:"
  print -u2 "  export BQ_SEARCH_PATH=my-project-prod:my-project-dev"
  return 1
fi

for cmd in bq fzf jq; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    print -u2 "bq-open: '$cmd' not found in PATH"
    return 1
  fi
done

local -a projects sandbox_datasets
projects=(${(s[:])BQ_SEARCH_PATH})
# SANDBOX_BQ_DATASETS is colon-separated list of dataset IDs (no project prefix)
sandbox_datasets=(${(s[:])SANDBOX_BQ_DATASETS})

local cache_dir="$HOME/.cache/bq-open"
mkdir -p "$cache_dir"
# Cache key: md5 of sorted project list + sandbox vars so changes bust cache
local cache_key cache_file sandbox_cache_file history_file
cache_key=$(print -l -- "${(o)projects[@]}" "${SANDBOX_BQ_PROJECT:-}" "${(o)sandbox_datasets[@]}" | md5)
cache_file="${cache_dir}/${cache_key}.txt"
sandbox_cache_file="${cache_dir}/${cache_key}-sandbox.txt"
history_file="${cache_dir}/history.txt"

# Tab-delimited format for fzf lines: DISPLAY_TAG<TAB>BQ_REF
# DISPLAY_TAG is either empty (normal lines) or the ANSI open code that colours
# the whole line purple; the RESET lives at the end of the BQ_REF field.
# --with-nth=1,2 shows both fields; --nth=2 restricts match highlighting to the
# BQ ref field so fzf never injects highlight codes before the colour opener.
local PURPLE=$'\033[35m'
local RESET=$'\033[0m'
local SANDBOX_TAG="$PURPLE"   # colour opener — closed by RESET appended to BQ_REF

_bq_open_fetch() {
  local project dataset table_json
  local -a tables
  for project in "${projects[@]}"; do
    print "bq-open: fetching datasets from $project …" >&2
    while IFS= read -r dataset; do
      table_json=$(bq ls --format=json --max_results=10000 --project_id="$project" "$dataset" 2>/dev/null) || continue
      while IFS= read -r tbl; do
        [[ -n $tbl ]] && tables+=("${project}:${dataset}.${tbl}")
      done < <(print -- "$table_json" | jq -r '.[].tableReference.tableId // empty' 2>/dev/null)
    done < <(bq ls --format=json --max_results=10000 --project_id="$project" 2>/dev/null \
      | jq -r '.[].datasetReference.datasetId // empty' 2>/dev/null)
  done

  if (( ${#tables} == 0 )) && [[ -z $SANDBOX_BQ_PROJECT ]]; then
    print -u2 "bq-open: no tables found in BQ_SEARCH_PATH='$BQ_SEARCH_PATH'"
    return 1
  fi

  print -l -- "${tables[@]}" >| "$cache_file"
}

_bq_open_fetch_sandbox() {
  [[ -z $SANDBOX_BQ_PROJECT ]] && { print -u2 "bq-open: SANDBOX_BQ_PROJECT not set, skipping sandbox fetch"; return 0; }
  [[ ${#sandbox_datasets} -eq 0 ]] && { print -u2 "bq-open: SANDBOX_BQ_DATASETS is empty, skipping sandbox fetch"; return 0; }
  local project="$SANDBOX_BQ_PROJECT"
  local dataset
  local tmp_dir
  tmp_dir=$(mktemp -d)

  print "bq-open: fetching sandbox tables from ${project} (${#sandbox_datasets} datasets in parallel) …" >&2

  # Fetch all datasets in parallel; each writes to its own temp file
  local -a pids
  setopt LOCAL_OPTIONS
  unsetopt MONITOR
  for dataset in "${sandbox_datasets[@]}"; do
    (
      local out
      out=$(bq ls --format=json --max_results=10000 --project_id="$project" "$dataset" 2>/dev/null) || exit 0
      [[ -z $out ]] && exit 0
      jq -r '.[].tableReference.tableId // empty' <<< "$out" 2>/dev/null \
        | while IFS= read -r tbl; do
            [[ -n $tbl ]] && printf '%s:%s.%s\n' "$project" "$dataset" "$tbl"
          done > "$tmp_dir/${dataset}.txt"
    ) &
    pids+=($!)
  done
  wait "${pids[@]}"

  # Merge results; always write the cache file (even if empty, to avoid re-fetching)
  cat "$tmp_dir"/*.txt 2>/dev/null | sort >| "$sandbox_cache_file"
  rm -rf "$tmp_dir"
}

# Fetch on first run if no cache exists yet
if [[ ! -f $cache_file ]]; then
  _bq_open_fetch || return 1
fi
if [[ -n $SANDBOX_BQ_PROJECT && ! -f $sandbox_cache_file ]]; then
  _bq_open_fetch_sandbox
fi

_bq_cache_age() {
  local file="$1"
  local mtime now elapsed
  mtime=$(stat -f %m "$file" 2>/dev/null || stat -c %Y "$file" 2>/dev/null)
  now=$(date +%s)
  elapsed=$(( now - mtime ))
  if (( elapsed < 3600 )); then
    print "${elapsed}s ago"
  elif (( elapsed < 86400 )); then
    print "$(( elapsed / 3600 ))h ago"
  else
    print "$(( elapsed / 86400 ))d ago"
  fi
}

# Sentinels use the tab format: empty-tag field <TAB> sentinel text
local refresh_sentinel=$'\t'"--- REFRESH CACHE (cached $(_bq_cache_age "$cache_file")) ---"
local sandbox_age=""
[[ -f $sandbox_cache_file ]] && sandbox_age=" (cached $(_bq_cache_age "$sandbox_cache_file"))"
local refresh_sandbox_sentinel="${PURPLE}"$'\t'"--- REFRESH SANDBOX CACHE${sandbox_age} ---${RESET}"

# Emit tab-delimited "COLOUR_OPENER<TAB>BQ_REF+RESET" lines.
# Normal lines: empty first field, plain BQ ref.
# Sandbox lines: PURPLE opener in field 1, BQ ref + RESET in field 2 — whole line purple.
_bq_open_sandbox_lines() {
  [[ -f $sandbox_cache_file ]] || return 0
  while IFS= read -r line; do
    [[ -n $line ]] && printf '%s\t%s%s\n' "$SANDBOX_TAG" "$line" "$RESET"
  done < "$sandbox_cache_file"
}

local selection
selection=$(
  {
    print -- "$refresh_sentinel"
    [[ -n $SANDBOX_BQ_PROJECT ]] && print -- "$refresh_sandbox_sentinel"
    # History lines: stored as plain BQ refs (or "[sandbox] BQ_REF"), convert to tab format
    if [[ -f $history_file ]]; then
      while IFS= read -r line; do
        if [[ $line == '[sandbox] '* ]]; then
          printf '%s\t%s%s\n' "$SANDBOX_TAG" "${line#'[sandbox] '}" "$RESET"
        else
          printf '\t%s\n' "$line"
        fi
      done < "$history_file"
    fi
    # Sandbox lines right after history so they appear near the top of the picker
    _bq_open_sandbox_lines
    # Non-sandbox lines (deduplicated against history); emit in tab format
    if [[ -f $history_file ]]; then
      grep -vxFf "$history_file" "$cache_file" 2>/dev/null || true
    else
      cat "$cache_file"
    fi | while IFS= read -r line; do printf '\t%s\n' "$line"; done
  } \
  | awk -F'\t' '
    { key = $2; gsub(/\033\[[0-9;]*m/, "", key); if (!seen[key]++) print }' \
  | fzf --ansi --prompt="BigQuery table> " --height=80% --reverse \
        --no-mouse \
        --delimiter=$'\t' \
        --with-nth=1,2 \
        --nth=2 \
        --preview='raw=$(printf "%s" {} | cut -f2 | sed "s/\x1b\[[0-9;]*m//g"); case "$raw" in ---*) echo "Select to refresh the cache and reopen the picker." ;; *) "$HOME/bin/bq-preview" "$raw" ;; esac' \
        --preview-window=bottom:40%:wrap \
        --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)'
) || return 130

[[ -z $selection ]] && return 130

# selection is TAB-delimited: "COLOUR_OPENER<TAB>BQ_REF+RESET"
# Extract the BQ ref (second field, strip any trailing ANSI) and whether it's sandbox
local sel_tag sel_bq_ref
sel_tag="${selection%%$'\t'*}"
sel_bq_ref=$(printf '%s' "${selection#*$'\t'}" | sed 's/\x1b\[[0-9;]*m//g')

if [[ $sel_bq_ref == "--- REFRESH CACHE"* ]]; then
  rm -f "$cache_file" "$sandbox_cache_file"
  _bq_open_fetch || return 1
  _bq_open_fetch_sandbox
  rlm-bq-open
  return $?
fi
if [[ $sel_bq_ref == "--- REFRESH SANDBOX CACHE"* ]]; then
  rm -f "$sandbox_cache_file"
  _bq_open_fetch_sandbox
  rlm-bq-open
  return $?
fi

# raw_selection is the plain BQ ref: project:dataset.table
local raw_selection="$sel_bq_ref"

local sel_project dataset_table sel_dataset sel_table
sel_project=${raw_selection%%:*}
dataset_table=${raw_selection##*:}
sel_dataset=${dataset_table%%.*}
sel_table=${dataset_table##*.}

# Determine if this is a sandbox entry (tag field non-empty after stripping ANSI)
local is_sandbox=0
local plain_tag
plain_tag=$(printf '%s' "$sel_tag" | sed 's/\x1b\[[0-9;]*m//g')
[[ -n $plain_tag ]] && is_sandbox=1

# Persist to history as plain "BQ_REF" or "[sandbox] BQ_REF" (no ANSI)
local history_entry
(( is_sandbox )) && history_entry="[sandbox] ${raw_selection}" || history_entry="$raw_selection"
local tmp_history
tmp_history=$(mktemp)
{ print -- "$history_entry"; [[ -f $history_file ]] && grep -vxF "$history_entry" "$history_file"; } >| "$tmp_history"
mv "$tmp_history" "$history_file"

# GCP console deep-link for a specific table in the BigQuery UI
local url="https://console.cloud.google.com/bigquery?project=${sel_project}&ws=!1m5!1m4!4m3!1s${sel_project}!2s${sel_dataset}!3s${sel_table}"

print "$url"

# Copy to clipboard (macOS pbcopy, Linux xclip/xsel fallback)
if command -v pbcopy >/dev/null 2>&1; then
  print -n "$url" | pbcopy
  print "bq-open: URL copied to clipboard" >&2
elif command -v xclip >/dev/null 2>&1; then
  print -n "$url" | xclip -selection clipboard
  print "bq-open: URL copied to clipboard" >&2
elif command -v xsel >/dev/null 2>&1; then
  print -n "$url" | xsel --clipboard --input
  print "bq-open: URL copied to clipboard" >&2
fi

# Open in system browser
if command -v open >/dev/null 2>&1; then
  open "$url"
elif command -v xdg-open >/dev/null 2>&1; then
  xdg-open "$url"
fi
