emulate -L zsh
set -o pipefail

if [[ -z $BQ_SEARCH_PATH && -z $SANDBOX_BQ_PROJECT ]]; then
  print -u2 "bq-open: BQ_SEARCH_PATH or SANDBOX_BQ_PROJECT must be set"
  print -u2 "Set BQ_SEARCH_PATH to a colon-separated list of GCP projects, e.g.:"
  print -u2 "  export BQ_SEARCH_PATH=my-project-prod:my-project-dev"
  return 1
fi

for cmd in bq fzf jq; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    print -u2 "bq-open: '$cmd' not found in PATH"
    return 1
  fi
done

# Shared cache + history wiring. All five rlm-bq-* / rlm-sandbox-bq-*
# commands share one cache pair (~/.cache/bq-open/<md5>.txt and
# -sandbox.txt) and one pooled history TSV (~/.cache/bq-open/history.tsv)
# via these helpers. See zsh/AGENTS.md "Current internal helpers".
autoload -Uz _rlm-bq-cache _rlm-bq-history _rlm-bq-dead-refs-gc

# Garbage-collect any refs that bq-preview marked as dead on a previous
# run. No-op when ~/.cache/bq-open/dead-refs.txt is missing/empty.
_rlm-bq-dead-refs-gc

# Resolve current cache-key, paths.
local key cache sandbox
eval "$(_rlm-bq-cache paths)" || return 1

# Fetch on first run if no cache exists yet
if [[ ! -f $cache ]]; then
  _rlm-bq-cache refresh --main-only || return 1
fi
if [[ -n $SANDBOX_BQ_PROJECT && ! -f $sandbox ]]; then
  _rlm-bq-cache refresh --sandbox-only
fi

# Tab-delimited format for fzf lines: DISPLAY_TAG<TAB>BQ_REF
# DISPLAY_TAG is either empty (normal lines) or the ANSI open code that colours
# the whole line purple; the RESET lives at the end of the BQ_REF field.
# --with-nth=1,2 shows both fields; --nth=2 restricts match highlighting to the
# BQ ref field so fzf never injects highlight codes before the colour opener.
local PURPLE=$'\033[35m'
local RESET=$'\033[0m'
local SANDBOX_TAG="$PURPLE"   # colour opener — closed by RESET appended to BQ_REF

_bq_cache_age() {
  local file="$1"
  local mtime now elapsed
  mtime=$(stat -f %m "$file" 2>/dev/null || stat -c %Y "$file" 2>/dev/null)
  now=$(date +%s)
  elapsed=$(( now - mtime ))
  if (( elapsed < 3600 )); then
    print "${elapsed}s ago"
  elif (( elapsed < 86400 )); then
    print "$(( elapsed / 3600 ))h ago"
  else
    print "$(( elapsed / 86400 ))d ago"
  fi
}

# Sentinels use the tab format: empty-tag field <TAB> sentinel text
local refresh_sentinel=$'\t'"--- REFRESH CACHE (cached $(_bq_cache_age "$cache")) ---"
local sandbox_age=""
[[ -f $sandbox ]] && sandbox_age=" (cached $(_bq_cache_age "$sandbox"))"
local refresh_sandbox_sentinel="${PURPLE}"$'\t'"--- REFRESH SANDBOX CACHE${sandbox_age} ---${RESET}"

# Build set of bq_refs that exist in the current cache scope. Pooled
# history may contain entries from other scopes (different
# BQ_SEARCH_PATH); we suppress those so the picker never suggests a
# ref the user can't actually open from here.
local -A in_scope
local _ref
while IFS= read -r _ref; do
  [[ -n $_ref ]] && in_scope[$_ref]=1
done < <(_rlm-bq-cache read --both)

# Build the picker input from the pooled history.tsv. Each line:
#   <epoch>\t<command>\t<bq_ref>\t<flags>
# Render as tab-delimited TAG\tBQ_REF (purple TAG when flags ~ sandbox).
_bq_open_history_lines() {
  local ts cmd ref flags display tag
  while IFS=$'\t' read -r ts cmd ref flags; do
    [[ -z $ref ]] && continue
    [[ -z ${in_scope[$ref]:-} ]] && continue
    if [[ ,${flags}, == *,sandbox,* ]]; then
      tag="$SANDBOX_TAG"
      display="${ref}${RESET}"
    else
      tag=""
      display="$ref"
    fi
    printf '%s\t%s\n' "$tag" "$display"
  done < <(_rlm-bq-history read)
}

# Sandbox cache entries that aren't in history yet
_bq_open_sandbox_lines() {
  while IFS= read -r line; do
    [[ -n $line ]] && printf '%s\t%s%s\n' "$SANDBOX_TAG" "$line" "$RESET"
  done < <(_rlm-bq-cache read --sandbox)
}

# Non-sandbox cache entries that aren't in history yet
_bq_open_main_lines() {
  while IFS= read -r line; do
    [[ -n $line ]] && printf '\t%s\n' "$line"
  done < <(_rlm-bq-cache read --main)
}

local selection
selection=$(
  {
    print -- "$refresh_sentinel"
    [[ -n $SANDBOX_BQ_PROJECT ]] && print -- "$refresh_sandbox_sentinel"
    # History first (recents from any rlm-bq-* command), then remaining
    # sandbox entries, then remaining non-sandbox entries. awk dedupes
    # on the ANSI-stripped bq_ref so the same ref never appears twice.
    _bq_open_history_lines
    _bq_open_sandbox_lines
    _bq_open_main_lines
  } \
  | awk -F'\t' '
    { key = $2; gsub(/\033\[[0-9;]*m/, "", key); if (!seen[key]++) print }' \
  | fzf --ansi --prompt="BigQuery table> " --height=80% --reverse \
        --no-mouse \
        --delimiter=$'\t' \
        --with-nth=1,2 \
        --nth=2 \
        --preview='raw=$(printf "%s" {} | cut -f2 | sed "s/\x1b\[[0-9;]*m//g"); case "$raw" in ---*) echo "Select to refresh the cache and reopen the picker." ;; *) "$HOME/bin/bq-preview" "$raw" ;; esac' \
        --preview-window=bottom:40%:wrap \
        --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
        --bind='ctrl-g:abort'
) || return 130

[[ -z $selection ]] && return 130

# selection is TAB-delimited: "COLOUR_OPENER<TAB>BQ_REF+RESET"
# Extract the BQ ref (second field, strip any trailing ANSI) and whether it's sandbox
local sel_tag sel_bq_ref
sel_tag="${selection%%$'\t'*}"
sel_bq_ref=$(printf '%s' "${selection#*$'\t'}" | sed 's/\x1b\[[0-9;]*m//g')

if [[ $sel_bq_ref == "--- REFRESH CACHE"* ]]; then
  rm -f "$cache" "$sandbox"
  _rlm-bq-cache refresh || return 1
  rlm-bq-open
  return $?
fi
if [[ $sel_bq_ref == "--- REFRESH SANDBOX CACHE"* ]]; then
  rm -f "$sandbox"
  _rlm-bq-cache refresh --sandbox-only
  rlm-bq-open
  return $?
fi

# raw_selection is the plain BQ ref: project:dataset.table
local raw_selection="$sel_bq_ref"

local sel_project dataset_table sel_dataset sel_table
sel_project=${raw_selection%%:*}
dataset_table=${raw_selection##*:}
sel_dataset=${dataset_table%%.*}
sel_table=${dataset_table##*.}

# Determine if this is a sandbox entry (tag field non-empty after stripping ANSI)
local is_sandbox=0
local plain_tag
plain_tag=$(printf '%s' "$sel_tag" | sed 's/\x1b\[[0-9;]*m//g')
[[ -n $plain_tag ]] && is_sandbox=1

# Append to the shared pooled history. The "sandbox" flag is recorded
# whenever the pick came from a sandbox-coloured row, so every other
# rlm-bq-* picker can render it in purple too.
if (( is_sandbox )); then
  _rlm-bq-history append bq-open "$raw_selection" sandbox
else
  _rlm-bq-history append bq-open "$raw_selection"
fi

# GCP console deep-link for a specific table in the BigQuery UI. URL
# construction is delegated to the shared `~/bin/bq-console-url` helper,
# which is the single source of truth for the deep-link format (also used
# by rlm-sandbox-bq-open, rlm-dbt-bq-link, and the OSC 8 hyperlink in
# dbt-model-preview).
local url
url=$("$HOME/bin/bq-console-url" "${sel_project}:${sel_dataset}.${sel_table}")

print "$url"

# Copy to clipboard (macOS pbcopy, Linux xclip/xsel fallback)
if command -v pbcopy >/dev/null 2>&1; then
  print -n "$url" | pbcopy
  print "bq-open: URL copied to clipboard" >&2
elif command -v xclip >/dev/null 2>&1; then
  print -n "$url" | xclip -selection clipboard
  print "bq-open: URL copied to clipboard" >&2
elif command -v xsel >/dev/null 2>&1; then
  print -n "$url" | xsel --clipboard --input
  print "bq-open: URL copied to clipboard" >&2
fi

# Open in system browser
if command -v open >/dev/null 2>&1; then
  open "$url"
elif command -v xdg-open >/dev/null 2>&1; then
  xdg-open "$url"
fi
