emulate -L zsh
set -o pipefail

if [[ -z $BQ_SEARCH_PATH && -z $SANDBOX_BQ_PROJECT ]]; then
  print -u2 "bq-open: BQ_SEARCH_PATH or SANDBOX_BQ_PROJECT must be set"
  print -u2 "Set BQ_SEARCH_PATH to a colon-separated list of GCP projects, e.g.:"
  print -u2 "  export BQ_SEARCH_PATH=my-project-prod:my-project-dev"
  return 1
fi

for cmd in bq fzf jq; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    print -u2 "bq-open: '$cmd' not found in PATH"
    return 1
  fi
done

# Shared cache + history wiring. All five rlm-bq-* / rlm-sandbox-bq-*
# commands share one cache pair (~/.cache/bq-open/<md5>.txt and
# -sandbox.txt) and one pooled history TSV (~/.cache/bq-open/history.tsv)
# via these helpers. See zsh/AGENTS.md "Current internal helpers".
autoload -Uz _rlm-bq-cache _rlm-bq-history _rlm-bq-dead-refs-gc _rlm-bq-refresh-sentinels

# macOS-only: place a multi-flavor payload on the system clipboard via a small
# inline Swift NSPasteboard program (pbcopy can only set a single plain-text
# flavor, and AppleScript's RTF handling stores the markup as plain text). The
# destination app then chooses the richest flavor it understands.
#   $1 = HTML fragment (<a href=…>label</a> joined by <br>) → RTF + HTML flavors
#   $2 = Markdown links (one per line)                       → plain-text + public.markdown
# Returns swift's exit status (non-zero if HTML parsing/RTF generation failed),
# so the caller can fall back to a plain `pbcopy`. Mirrors the helper of the
# same shape in rlm-pubsub-open.
_bq_open_clip_rich() {
  HTML_CLIP=$1 PLAIN_CLIP=$2 swift - <<'SWIFT'
import AppKit
import Foundation

let env = ProcessInfo.processInfo.environment
let html = env["HTML_CLIP"] ?? ""
let plain = env["PLAIN_CLIP"] ?? ""   // Markdown link

let pb = NSPasteboard.general
pb.clearContents()

let htmlData = Data(html.utf8)
guard let attr = NSAttributedString(
        html: htmlData,
        options: [.documentType: NSAttributedString.DocumentType.html,
                  .characterEncoding: String.Encoding.utf8.rawValue],
        documentAttributes: nil) else {
  FileHandle.standardError.write("bq-open: failed to parse HTML for clipboard\n".data(using: .utf8)!)
  exit(1)
}
guard let rtfData = try? attr.data(
        from: NSRange(location: 0, length: attr.length),
        documentAttributes: [.documentType: NSAttributedString.DocumentType.rtf]) else {
  FileHandle.standardError.write("bq-open: failed to build RTF for clipboard\n".data(using: .utf8)!)
  exit(1)
}

let markdownType = NSPasteboard.PasteboardType("public.markdown")
let item = NSPasteboardItem()
item.setData(rtfData, forType: .rtf)
item.setData(htmlData, forType: .html)
item.setString(plain, forType: .string)        // Markdown is the plain-text flavor
item.setString(plain, forType: markdownType)    // and a dedicated markdown flavor
pb.writeObjects([item])
SWIFT
}

# Garbage-collect any refs that bq-preview marked as dead on a previous
# run. No-op when ~/.cache/bq-open/dead-refs.txt is missing/empty.
_rlm-bq-dead-refs-gc

# Resolve current cache-key, paths.
local key cache sandbox
eval "$(_rlm-bq-cache paths)" || return 1

# Fetch on first run if no cache exists yet
if [[ ! -f $cache ]]; then
  _rlm-bq-cache refresh --main-only || return 1
fi
if [[ -n $SANDBOX_BQ_PROJECT && ! -f $sandbox ]]; then
  _rlm-bq-cache refresh --sandbox-only
fi

# Tab-delimited format for fzf lines: DISPLAY_TAG<TAB>BQ_REF
# DISPLAY_TAG is either empty (normal lines) or the ANSI open code that colours
# the whole line purple; the RESET lives at the end of the BQ_REF field.
# --with-nth=1,2 shows both fields; --nth=2 restricts match highlighting to the
# BQ ref field so fzf never injects highlight codes before the colour opener.
local PURPLE=$'\033[35m'
local RESET=$'\033[0m'
local SANDBOX_TAG="$PURPLE"   # colour opener — closed by RESET appended to BQ_REF

# Sentinels (tab-prefixed for --with-nth=2 layout) come from the shared
# _rlm-bq-refresh-sentinels helper. See zsh/AGENTS.md.
local refresh_sentinel refresh_sandbox_sentinel
refresh_sentinel=$(_rlm-bq-refresh-sentinels emit-main --tab)
refresh_sandbox_sentinel=$(_rlm-bq-refresh-sentinels emit-sandbox --tab)

# Build set of bq_refs that exist in the current cache scope. Pooled
# history may contain entries from other scopes (different
# BQ_SEARCH_PATH); we suppress those so the picker never suggests a
# ref the user can't actually open from here.
local -A in_scope
local _ref
while IFS= read -r _ref; do
  [[ -n $_ref ]] && in_scope[$_ref]=1
done < <(_rlm-bq-cache read --both)

# Build the picker input from the pooled history.tsv. Each line:
#   <epoch>\t<command>\t<bq_ref>\t<flags>
# Render as tab-delimited TAG\tBQ_REF (purple TAG when flags ~ sandbox).
_bq_open_history_lines() {
  local ts cmd ref flags display tag
  while IFS=$'\t' read -r ts cmd ref flags; do
    [[ -z $ref ]] && continue
    [[ -z ${in_scope[$ref]:-} ]] && continue
    if [[ ,${flags}, == *,sandbox,* ]]; then
      tag="$SANDBOX_TAG"
      display="${ref}${RESET}"
    else
      tag=""
      display="$ref"
    fi
    printf '%s\t%s\n' "$tag" "$display"
  done < <(_rlm-bq-history read)
}

# Sandbox cache entries that aren't in history yet
_bq_open_sandbox_lines() {
  while IFS= read -r line; do
    [[ -n $line ]] && printf '%s\t%s%s\n' "$SANDBOX_TAG" "$line" "$RESET"
  done < <(_rlm-bq-cache read --sandbox)
}

# Non-sandbox cache entries that aren't in history yet
_bq_open_main_lines() {
  while IFS= read -r line; do
    [[ -n $line ]] && printf '\t%s\n' "$line"
  done < <(_rlm-bq-cache read --main)
}

local selection
selection=$(
  {
    print -- "$refresh_sentinel"
    [[ -n $SANDBOX_BQ_PROJECT ]] && print -- "$refresh_sandbox_sentinel"
    # History first (recents from any rlm-bq-* command), then remaining
    # sandbox entries, then remaining non-sandbox entries. awk dedupes
    # on the ANSI-stripped bq_ref so the same ref never appears twice.
    _bq_open_history_lines
    _bq_open_sandbox_lines
    _bq_open_main_lines
  } \
  | awk -F'\t' '
    { key = $2; gsub(/\033\[[0-9;]*m/, "", key); if (!seen[key]++) print }' \
  | fzf --ansi --prompt="BigQuery table> " --height=80% --reverse \
        --no-mouse \
        --multi \
        --header="TAB: multi-select  Enter: open all" \
        --delimiter=$'\t' \
        --with-nth=1,2 \
        --nth=2 \
        --preview='raw=$(printf "%s" {} | cut -f2 | sed "s/\x1b\[[0-9;]*m//g"); case "$raw" in ---*) echo "Select to refresh the cache and reopen the picker." ;; *) "$HOME/bin/bq-preview" "$raw" ;; esac' \
        --preview-window=bottom:40%:wrap \
        --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
        --bind='ctrl-g:abort'
) || return 130

[[ -z $selection ]] && return 130

# Split the (possibly multi-line) selection into individual rows. Each row is
# TAB-delimited: "COLOUR_OPENER<TAB>BQ_REF+RESET".
local -a sel_lines
sel_lines=("${(@f)selection}")
sel_lines=("${(@)sel_lines:#}")
(( ${#sel_lines} == 0 )) && return 130

# If a refresh sentinel is among the selections, it takes over: refresh the
# corresponding cache (ignoring any other co-selected rows) and re-run the
# picker. The sentinels are mutually exclusive in practice, but checking each
# selected row keeps the behaviour predictable regardless of selection order.
local line _tag _ref
for line in "${sel_lines[@]}"; do
  _ref=$(printf '%s' "${line#*$'\t'}" | sed 's/\x1b\[[0-9;]*m//g')
  if _rlm-bq-refresh-sentinels is-main "$_ref"; then
    _rlm-bq-refresh-sentinels apply-main || return 1
    rlm-bq-open
    return $?
  fi
  if _rlm-bq-refresh-sentinels is-sandbox "$_ref"; then
    _rlm-bq-refresh-sentinels apply-sandbox
    rlm-bq-open
    return $?
  fi
done

# Build a console URL per selected table. Alongside the raw URLs we collect the
# pre-rendered HTML and Markdown link forms so we can put a single multi-format
# payload on the clipboard covering every selected table.
local -a urls html_links md_links
local sel_tag sel_bq_ref sel_project dataset_table sel_dataset sel_table
local is_sandbox plain_tag url fqn kind type_raw clip_label
for line in "${sel_lines[@]}"; do
  sel_tag="${line%%$'\t'*}"
  sel_bq_ref=$(printf '%s' "${line#*$'\t'}" | sed 's/\x1b\[[0-9;]*m//g')

  # Parse the plain BQ ref: project:dataset.table
  sel_project=${sel_bq_ref%%:*}
  dataset_table=${sel_bq_ref##*:}
  sel_dataset=${dataset_table%%.*}
  sel_table=${dataset_table##*.}

  # Determine if this row came from a sandbox-coloured entry (tag field
  # non-empty after stripping ANSI).
  is_sandbox=0
  plain_tag=$(printf '%s' "$sel_tag" | sed 's/\x1b\[[0-9;]*m//g')
  [[ -n $plain_tag ]] && is_sandbox=1

  # Append to the shared pooled history. The "sandbox" flag is recorded
  # whenever the pick came from a sandbox-coloured row, so every other
  # rlm-bq-* picker can render it in purple too.
  if (( is_sandbox )); then
    _rlm-bq-history append bq-open "$sel_bq_ref" sandbox
  else
    _rlm-bq-history append bq-open "$sel_bq_ref"
  fi

  # GCP console deep-link for a specific table in the BigQuery UI. URL
  # construction is delegated to the shared `~/bin/bq-console-url` helper,
  # which is the single source of truth for the deep-link format (also used
  # by rlm-sandbox-bq-open, rlm-dbt-bq-link, and the OSC 8 hyperlink in
  # dbt-model-preview).
  url=$("$HOME/bin/bq-console-url" "${sel_project}:${sel_dataset}.${sel_table}")
  fqn="${sel_project}.${sel_dataset}.${sel_table}"

  # Determine TABLE vs VIEW (or MATERIALIZED_VIEW/EXTERNAL/SNAPSHOT) for the
  # label prefix. `bq show --format=json` is one round-trip. We keep stderr so
  # the auth/permission reason surfaces, and capture bq's exit status: a failed
  # lookup (expired tokens, network, missing perms) yields no JSON, which would
  # otherwise be indistinguishable from a genuine TABLE. On failure we warn
  # (with the bq error) and fall back to a bare "TABLE" prefix — labelling a
  # view as a table without explanation is exactly the silent-mislabel trap.
  local type_json type_err
  type_err=$(mktemp)
  type_json=$(bq show --format=json "${sel_project}:${sel_dataset}.${sel_table}" 2>"$type_err")
  if (( $? != 0 )) || [[ -z $type_json ]]; then
    print -u2 "bq-open: type lookup failed for ${fqn}; labelling as TABLE (re-auth?)"
    [[ -s $type_err ]] && sed 's/^/bq-open:   /' "$type_err" >&2
    kind="TABLE"
  else
    type_raw=$(print -r -- "$type_json" | jq -r '.type // "TABLE"' 2>/dev/null)
    case "$type_raw" in
      VIEW)               kind="VIEW" ;;
      MATERIALIZED_VIEW)  kind="MATERIALIZED_VIEW" ;;
      EXTERNAL)           kind="EXTERNAL" ;;
      SNAPSHOT)           kind="SNAPSHOT" ;;
      "" )                kind="TABLE" ;;
      *)                  kind="$type_raw" ;;
    esac
  fi
  rm -f "$type_err"

  clip_label="${kind}: ${fqn}"
  urls+=("$url")
  html_links+=("<a href=\"${url}\">${clip_label}</a>")
  md_links+=("[${clip_label}](${url})")

  print "$clip_label"
  print "$url"
done

# Copy a multi-format payload to the clipboard. On macOS a small Swift
# NSPasteboard helper places several flavors at once so the destination app
# chooses: RTF + HTML carry the hyperlinked "kind: fqn" labels (rich editors,
# mail, chat), while the plain-text flavor holds Markdown links (and a
# dedicated public.markdown flavor mirrors it). Falls back to plain `pbcopy`
# (Markdown) when `swift` is unavailable, and to xclip/xsel (Markdown) on
# Linux. Mirrors the clipboard handling in rlm-pubsub-open.
local md_payload html_payload
md_payload=${(F)md_links}                       # one Markdown link per line
html_payload=${(j:<br>:)html_links}             # <a> links joined by <br>

if [[ $OSTYPE == darwin* ]] && command -v swift >/dev/null 2>&1; then
  if _bq_open_clip_rich "$html_payload" "$md_payload"; then
    print "bq-open: ${#urls} URL(s) copied to clipboard (rich + markdown)" >&2
  elif command -v pbcopy >/dev/null 2>&1; then
    print -rn -- "$md_payload" | pbcopy
    print "bq-open: ${#urls} URL(s) copied to clipboard (markdown; rich copy failed)" >&2
  fi
elif command -v pbcopy >/dev/null 2>&1; then
  print -rn -- "$md_payload" | pbcopy
  print "bq-open: ${#urls} URL(s) copied to clipboard (markdown)" >&2
elif command -v xclip >/dev/null 2>&1; then
  print -rn -- "$md_payload" | xclip -selection clipboard
  print "bq-open: ${#urls} URL(s) copied to clipboard (markdown)" >&2
elif command -v xsel >/dev/null 2>&1; then
  print -rn -- "$md_payload" | xsel --clipboard --input
  print "bq-open: ${#urls} URL(s) copied to clipboard (markdown)" >&2
fi

# Open every selected table in the system browser.
if command -v open >/dev/null 2>&1; then
  open "${urls[@]}"
elif command -v xdg-open >/dev/null 2>&1; then
  for url in "${urls[@]}"; do
    xdg-open "$url"
  done
fi
