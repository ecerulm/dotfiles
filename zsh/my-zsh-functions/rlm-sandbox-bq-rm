emulate -L zsh
set -o pipefail

if [[ -z $SANDBOX_BQ_PROJECT ]]; then
  print -u2 "sandbox-bq-rm: SANDBOX_BQ_PROJECT is not set"
  return 1
fi
if [[ -z $SANDBOX_BQ_DATASETS ]]; then
  print -u2 "sandbox-bq-rm: SANDBOX_BQ_DATASETS is not set"
  return 1
fi

for _cmd in bq fzf jq; do
  if ! command -v "$_cmd" >/dev/null 2>&1; then
    print -u2 "sandbox-bq-rm: '$_cmd' not found in PATH"
    return 1
  fi
done
unset _cmd

# Shared cache + history wiring. All five rlm-bq-* / rlm-sandbox-bq-*
# commands share one cache pair (~/.cache/bq-open/<md5>.txt and
# -sandbox.txt) and one pooled history TSV (~/.cache/bq-open/history.tsv)
# via these helpers. See zsh/AGENTS.md "Current internal helpers".
autoload -Uz _rlm-bq-cache _rlm-bq-history _rlm-bq-dead-refs-gc _rlm-bq-refresh-sentinels

# Garbage-collect any refs that bq-preview marked as dead on a previous
# run. No-op when ~/.cache/bq-open/dead-refs.txt is missing/empty.
_rlm-bq-dead-refs-gc

# Resolve current cache-key, paths.
local key cache sandbox
eval "$(_rlm-bq-cache paths)" || return 1

# Fetch on first run if no sandbox cache exists yet
if [[ ! -f $sandbox ]]; then
  _rlm-bq-cache refresh --sandbox-only || return 1
fi

# Sentinel via the shared helper. --no-color because every row in this
# picker is sandbox-scoped (PURPLE wrap would be redundant noise).
local refresh_sentinel
refresh_sentinel=$(_rlm-bq-refresh-sentinels emit-sandbox --no-color)

# Build set of bq_refs that exist in the current sandbox cache scope.
# Pooled history may contain entries from other scopes or non-sandbox
# refs; we suppress those so the picker only suggests refs the user
# can actually delete from here.
local -A in_scope
local _ref
while IFS= read -r _ref; do
  [[ -n $_ref ]] && in_scope[$_ref]=1
done < <(_rlm-bq-cache read --sandbox)

# Pooled history entries (newest first), filtered to refs in the
# current sandbox cache scope. Plain bare refs (single-column layout).
_bq_open_history_lines() {
  local ts cmd ref flags
  while IFS=$'\t' read -r ts cmd ref flags; do
    [[ -z $ref ]] && continue
    [[ -z ${in_scope[$ref]:-} ]] && continue
    print -r -- "$ref"
  done < <(_rlm-bq-history read)
}

local selection
selection=$(
  {
    print -r -- "$refresh_sentinel"
    _bq_open_history_lines
    _rlm-bq-cache read --sandbox
  } \
  | awk '!seen[$0]++' \
  | fzf --prompt="Delete sandbox BQ table> " \
        --no-mouse \
        --ansi \
        --multi \
        --height=80% --reverse \
        --preview="$HOME/bin/bq-preview {}" \
        --preview-window=bottom:40%:wrap \
        --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
        --bind='ctrl-g:abort'
) || return 130

[[ -z $selection ]] && return 130

if _rlm-bq-refresh-sentinels is-sandbox "$selection"; then
  _rlm-bq-refresh-sentinels apply-sandbox || return 1
  rlm-sandbox-bq-rm
  return $?
fi

local -a selected_tables
selected_tables=("${(@f)selection}")

print "sandbox-bq-rm: the following tables will be permanently deleted:"
local tbl
for tbl in "${selected_tables[@]}"; do
  print "  $tbl"
done
print -n "Confirm delete? [y/N] "
read -r REPLY
if [[ $REPLY != [yY] ]]; then
  print "sandbox-bq-rm: aborted" >&2
  return 1
fi

local failed=0
for tbl in "${selected_tables[@]}"; do
  local proj rest
  proj=${tbl%%:*}
  rest=${tbl##*:}
  if bq rm -f -t "${proj}:${rest}" 2>&1; then
    print "sandbox-bq-rm: deleted ${tbl}"
    _rlm-bq-history append sandbox-bq-rm "$tbl" sandbox deleted
  else
    print -u2 "sandbox-bq-rm: failed to delete ${tbl}"
    failed=1
  fi
done

# Refresh the shared sandbox cache once so the cache reflects current state.
_rlm-bq-cache refresh --sandbox-only

return $failed
