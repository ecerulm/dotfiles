emulate -L zsh

# Ensure a uv-managed project's virtualenv exists and provides the
# expected executable. If not, run `uv sync` once and re-check;
# if it still fails, print a three-line diagnostic and return non-zero.
#
# This is the uv counterpart to _rlm-poetry-ensure-venv, used by
# rlm-dbt-* functions when the project is detected as uv-managed
# (uv.lock present in project_root or [tool.uv] in pyproject.toml).
# It asserts the resolved binary lives inside the project's .venv —
# `uv run` happily falls through to $PATH if the venv is missing the
# executable, which can silently shadow the pinned project version.
#
# Usage:
#   _rlm-uv-ensure-venv <project_root> <expected_bin> <label>
#
#   project_root   absolute path to the directory containing pyproject.toml
#   expected_bin   bare name of the executable that must live in the venv
#                  (e.g. dbt, ruff)
#   label          short caller name used as a prefix in stderr messages
#                  (e.g. dbt-run, dbt-ls)
#
# Returns:
#   0 if the venv resolves and the bin is inside it (possibly after a
#     successful auto `uv sync`).
#   1 if anything failed; a diagnostic has been printed to stderr.

local project_root="$1"
local expected_bin="$2"
local label="$3"

if [[ -z $project_root || -z $expected_bin || -z $label ]]; then
  print -u2 "_rlm-uv-ensure-venv: usage: <project_root> <expected_bin> <label>"
  return 2
fi

# Redirect stderr on the bare `cd` (not the whole subshell) to silence
# direnv's "loading/unloading" chatter. See _rlm-poetry-ensure-venv for
# the full rationale — same pattern applies here.
_rlm_uv_ensure_venv_check() {
  local venv_path bin_path
  venv_path="${project_root}/.venv"
  bin_path=$(cd "$project_root" 2>/dev/null && uv run which "$expected_bin" 2>/dev/null)
  [[ -n $bin_path && $bin_path == ${venv_path}/* ]]
}

if _rlm_uv_ensure_venv_check; then
  return 0
fi

print -u2 "${label}: ${expected_bin} not resolved from project venv — running uv sync in $project_root …"
(cd "$project_root" 2>/dev/null && uv sync) || {
  print -u2 "${label}: uv sync failed"
  return 1
}

if _rlm_uv_ensure_venv_check; then
  return 0
fi

local _bin
_bin=$(cd "$project_root" 2>/dev/null && uv run which "$expected_bin" 2>/dev/null)
print -u2 "${label}: ${expected_bin} still not in venv after uv sync"
print -u2 "         expected venv : ${project_root}/.venv"
print -u2 "         resolved ${expected_bin}  : ${_bin:-<unresolved>}"
print -u2 "         project dir   : $project_root"
return 1
