emulate -L zsh

# Shared per-cache-key BigQuery table-list cache for all rlm-bq-* /
# rlm-sandbox-bq-* commands. Two files per key live under
# ~/.cache/bq-open/:
#
#   <md5>.txt          — non-sandbox tables (one project:dataset.table
#                        per line), populated by `bq ls` over every
#                        project in BQ_SEARCH_PATH.
#   <md5>-sandbox.txt  — sandbox tables (one project:dataset.table per
#                        line), populated by `bq ls` over each dataset
#                        in SANDBOX_BQ_DATASETS under SANDBOX_BQ_PROJECT.
#
# The md5 key is computed by the shared _rlm-bq-cache-key helper from
# BQ_SEARCH_PATH + SANDBOX_BQ_PROJECT + SANDBOX_BQ_DATASETS, so any
# change to the scope of "what tables are visible" busts the cache.
#
# Originally lived inline in rlm-bq-open (_bq_open_fetch and
# _bq_open_fetch_sandbox). Lifted into a shared helper so all five
# bq-related commands refresh and read from the same files.
#
# Usage:
#   _rlm-bq-cache paths
#       → "key=<md5>\ncache=<absolute path>\nsandbox=<absolute path>\n"
#         on stdout, suitable for `eval`.
#
#   _rlm-bq-cache refresh [--main-only | --sandbox-only]
#                         [--projects p1:p2:…] [--datasets d1:d2:…]
#       Re-fetch the cache file(s) via `bq ls`. Default: both. Writes
#       to <md5>.txt and/or <md5>-sandbox.txt atomically (each fetcher
#       writes its own file). Stderr carries progress messages.
#
#       --projects restricts the *main* refresh to a colon-separated
#       subset of BQ_SEARCH_PATH; entries for the other projects are
#       preserved from the existing <md5>.txt (partial refresh / merge).
#       Omitted ⇒ all projects in BQ_SEARCH_PATH.
#
#       --datasets restricts the *sandbox* refresh to a colon-separated
#       subset of SANDBOX_BQ_DATASETS; entries for the other datasets
#       are preserved from the existing <md5>-sandbox.txt. Omitted ⇒
#       all datasets in SANDBOX_BQ_DATASETS.
#
#       Both subset selectors are validated against the configured
#       scope: an unknown project/dataset is dropped with a stderr
#       warning rather than silently widening the cache key.
#
#   _rlm-bq-cache read [--main | --sandbox | --both]
#       Concatenate the corresponding cache file(s) to stdout, one
#       bq_ref per line. Default: --both (main first, then sandbox).
#       Empty stdout if no cache file exists for the requested mode.
#
# Return codes:
#   0 — success.
#   1 — refresh failed (no usable tables in either source) or no
#       BQ_SEARCH_PATH / SANDBOX_BQ_PROJECT set for the requested
#       refresh.
#   2 — usage error.

autoload -Uz _rlm-bq-cache-key

local cache_dir="$HOME/.cache/bq-open"
mkdir -p "$cache_dir"
local cache_key cache_file sandbox_cache_file
cache_key=$(_rlm-bq-cache-key) || return 1
cache_file="${cache_dir}/${cache_key}.txt"
sandbox_cache_file="${cache_dir}/${cache_key}-sandbox.txt"

# Refresh the non-sandbox cache file by listing every dataset/table in
# each project in BQ_SEARCH_PATH. Lifted from rlm-bq-open:70–90.
#
# Args: an optional subset of projects to refresh. When given, only
# those projects are re-listed and entries for the *other* configured
# projects are preserved from the existing $cache_file (partial-refresh
# merge, mirroring _pubsub_open_fetch). With no args, every project in
# BQ_SEARCH_PATH is refreshed (the whole file is rebuilt).
_rlm_bq_cache_refresh_main() {
  if [[ -z $BQ_SEARCH_PATH ]]; then
    print -u2 "_rlm-bq-cache: BQ_SEARCH_PATH is not set; cannot refresh main cache"
    return 1
  fi
  local -a all_projects refresh_projects
  all_projects=(${(s[:])BQ_SEARCH_PATH})
  if (( $# > 0 )); then
    # Validate the requested subset against BQ_SEARCH_PATH; drop unknowns
    # so a typo can't poison the cache with a project outside the scope
    # the cache key was computed from.
    local p
    for p in "$@"; do
      if (( ${all_projects[(I)$p]} )); then
        refresh_projects+=("$p")
      else
        print -u2 "_rlm-bq-cache: '$p' is not in BQ_SEARCH_PATH; skipping"
      fi
    done
    if (( ${#refresh_projects} == 0 )); then
      print -u2 "_rlm-bq-cache: no valid projects to refresh"
      return 1
    fi
  else
    refresh_projects=("${all_projects[@]}")
  fi

  local project dataset table_json tbl
  local -a tables
  for project in "${refresh_projects[@]}"; do
    print "_rlm-bq-cache: fetching datasets from $project …" >&2
    while IFS= read -r dataset; do
      table_json=$(bq ls --format=json --max_results=10000 --project_id="$project" "$dataset" 2>/dev/null) || continue
      while IFS= read -r tbl; do
        [[ -n $tbl ]] && tables+=("${project}:${dataset}.${tbl}")
      done < <(print -- "$table_json" | jq -r '.[].tableReference.tableId // empty' 2>/dev/null)
    done < <(bq ls --format=json --max_results=10000 --project_id="$project" 2>/dev/null \
      | jq -r '.[].datasetReference.datasetId // empty' 2>/dev/null)
  done

  # Preserve entries for projects we did NOT refresh. A cache line is
  # "<project>:<dataset>.<table>", so the project is everything before
  # the first ':'. For a full refresh the refreshed-set covers all
  # projects and nothing is kept.
  local -a kept
  if [[ -f $cache_file ]]; then
    local line entry_project
    local -A refreshed_set
    for project in "${refresh_projects[@]}"; do
      refreshed_set[$project]=1
    done
    while IFS= read -r line; do
      [[ -z $line ]] && continue
      entry_project=${line%%:*}
      [[ -z ${refreshed_set[$entry_project]} ]] && kept+=("$line")
    done < "$cache_file"
  fi

  if (( ${#tables} == 0 && ${#kept} == 0 )) && [[ -z $SANDBOX_BQ_PROJECT ]]; then
    print -u2 "_rlm-bq-cache: no tables found in BQ_SEARCH_PATH='$BQ_SEARCH_PATH'"
    return 1
  fi

  {
    (( ${#kept} ))   && print -l -- "${kept[@]}"
    (( ${#tables} )) && print -l -- "${tables[@]}"
  } >| "$cache_file"
}

# Refresh the sandbox cache file. Lifted from rlm-bq-open:92–123 —
# same parallel-per-dataset bq ls, same sort, same write-empty-on-no-results
# behavior so we don't re-fetch indefinitely.
#
# Args: an optional subset of datasets to refresh. When given, only
# those datasets are re-listed and entries for the *other* configured
# datasets are preserved from the existing $sandbox_cache_file (partial
# refresh). With no args, every dataset in SANDBOX_BQ_DATASETS is
# refreshed (the whole sandbox file is rebuilt).
_rlm_bq_cache_refresh_sandbox() {
  if [[ -z $SANDBOX_BQ_PROJECT ]]; then
    print -u2 "_rlm-bq-cache: SANDBOX_BQ_PROJECT not set, skipping sandbox fetch"
    return 0
  fi
  local -a all_datasets sandbox_datasets
  all_datasets=(${(s[:])SANDBOX_BQ_DATASETS})
  if (( ${#all_datasets} == 0 )); then
    print -u2 "_rlm-bq-cache: SANDBOX_BQ_DATASETS is empty, skipping sandbox fetch"
    return 0
  fi
  if (( $# > 0 )); then
    # Validate the requested subset against SANDBOX_BQ_DATASETS; drop
    # unknowns so a typo can't poison the cache.
    local d
    for d in "$@"; do
      if (( ${all_datasets[(I)$d]} )); then
        sandbox_datasets+=("$d")
      else
        print -u2 "_rlm-bq-cache: '$d' is not in SANDBOX_BQ_DATASETS; skipping"
      fi
    done
    if (( ${#sandbox_datasets} == 0 )); then
      print -u2 "_rlm-bq-cache: no valid sandbox datasets to refresh"
      return 0
    fi
  else
    sandbox_datasets=("${all_datasets[@]}")
  fi

  local project="$SANDBOX_BQ_PROJECT"
  local dataset
  local tmp_dir
  tmp_dir=$(mktemp -d)

  print "_rlm-bq-cache: fetching sandbox tables from ${project} (${#sandbox_datasets} datasets in parallel) …" >&2

  # Fetch all datasets in parallel; each writes to its own temp file.
  # MONITOR off so the job-notifications don't leak into the user's TTY.
  local -a pids
  setopt LOCAL_OPTIONS
  unsetopt MONITOR
  for dataset in "${sandbox_datasets[@]}"; do
    (
      local out
      out=$(bq ls --format=json --max_results=10000 --project_id="$project" "$dataset" 2>/dev/null) || exit 0
      [[ -z $out ]] && exit 0
      jq -r '.[].tableReference.tableId // empty' <<< "$out" 2>/dev/null \
        | while IFS= read -r tbl; do
            [[ -n $tbl ]] && printf '%s:%s.%s\n' "$project" "$dataset" "$tbl"
          done > "$tmp_dir/${dataset}.txt"
    ) &
    pids+=($!)
  done
  wait "${pids[@]}"

  # Preserve entries for datasets we did NOT refresh. A sandbox cache
  # line is "<project>:<dataset>.<table>"; the dataset is between the
  # ':' and the first '.'. For a full refresh nothing is kept.
  local -a kept
  if [[ -f $sandbox_cache_file ]]; then
    local line entry_dataset dt
    local -A refreshed_set
    for dataset in "${sandbox_datasets[@]}"; do
      refreshed_set[$dataset]=1
    done
    while IFS= read -r line; do
      [[ -z $line ]] && continue
      dt=${line#*:}            # <dataset>.<table>
      entry_dataset=${dt%%.*}
      [[ -z ${refreshed_set[$entry_dataset]} ]] && kept+=("$line")
    done < "$sandbox_cache_file"
  fi

  # Always write the cache file (even if empty) so we don't re-fetch
  # on every invocation when the sandbox is genuinely empty. Sort the
  # merged set so output ordering stays stable regardless of which
  # datasets were refreshed this time.
  {
    (( ${#kept} )) && print -l -- "${kept[@]}"
    cat "$tmp_dir"/*.txt 2>/dev/null
  } | sort >| "$sandbox_cache_file"
  rm -rf "$tmp_dir"
}

local subcmd="$1"
shift

case $subcmd in
  paths)
    print -- "key=${cache_key}"
    print -- "cache=${cache_file}"
    print -- "sandbox=${sandbox_cache_file}"
    ;;
  refresh)
    local mode="both"
    local -a refresh_projects refresh_datasets
    while (( $# )); do
      case $1 in
        --main-only)    mode="main";    shift ;;
        --sandbox-only) mode="sandbox"; shift ;;
        --projects)     refresh_projects=(${(s[:])2}); shift 2 ;;
        --datasets)     refresh_datasets=(${(s[:])2}); shift 2 ;;
        *)
          print -u2 "_rlm-bq-cache: refresh: unknown option: $1"
          return 2
          ;;
      esac
    done
    if [[ $mode == main || $mode == both ]]; then
      _rlm_bq_cache_refresh_main "${refresh_projects[@]}" || {
        # Only hard-fail if the user asked specifically for --main-only;
        # in --both mode we still want sandbox to try.
        [[ $mode == main ]] && return 1
      }
    fi
    if [[ $mode == sandbox || $mode == both ]]; then
      _rlm_bq_cache_refresh_sandbox "${refresh_datasets[@]}" || return 1
    fi
    ;;
  read)
    local mode="both"
    case ${1:-} in
      --main)    mode="main"; shift ;;
      --sandbox) mode="sandbox"; shift ;;
      --both)    mode="both"; shift ;;
      "")        ;;
      *)
        print -u2 "_rlm-bq-cache: read: unknown option: $1"
        return 2
        ;;
    esac
    if [[ $mode == main || $mode == both ]]; then
      [[ -f $cache_file ]] && cat "$cache_file"
    fi
    if [[ $mode == sandbox || $mode == both ]]; then
      [[ -f $sandbox_cache_file ]] && cat "$sandbox_cache_file"
    fi
    return 0
    ;;
  *)
    print -u2 "_rlm-bq-cache: unknown subcommand: ${subcmd:-(empty)}"
    print -u2 "_rlm-bq-cache: usage: paths"
    print -u2 "                  refresh [--main-only | --sandbox-only]"
    print -u2 "                  read    [--main | --sandbox | --both]"
    return 2
    ;;
esac
