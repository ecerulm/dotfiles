emulate -L zsh

# Shared implementation for rlm-dbt-run / rlm-dbt-build / rlm-dbt-test.
#
# Called by the wrapper functions with three leading positional arguments
# followed by the user's own argv:
#
#   _rlm-dbt-cmd <dbt_subcmd> <resource_types> <cost_resource_types> "$@"
#
#   dbt_subcmd            e.g. "run", "build", "test"
#   resource_types        comma-separated dbt --resource-type values used for
#                         the fzf picker / list view (e.g. "model",
#                         "model,seed", "test"). Also drives the wording in
#                         help / log output.
#   cost_resource_types   comma-separated --resource-type values used for
#                         the bq dry-run cost estimate. For `dbt run` and
#                         `dbt build` this is "model" (seeds don't dry-run
#                         through bq). For `dbt test` it's "test" so the
#                         estimate covers the test queries that actually
#                         scan data.
#
# All env / state / cache layout is identical to the original rlm-dbt-run;
# the cache directory is keyed off the wrapper name (passed as $0 by zsh)
# so dbt-run / dbt-build / dbt-test keep independent history.

local dbt_subcmd="$1"
local resource_types="$2"
local cost_resource_types="$3"
shift 3

local cmd_name="${funcstack[2]:-rlm-dbt-${dbt_subcmd}}"
# Short label used in user-facing messages (e.g. "dbt-run", "dbt-build")
local label="${cmd_name#rlm-}"

# Build "--resource-type X --resource-type Y" array from comma list
local -a resource_args
local rt
for rt in ${(s:,:)resource_types}; do
  resource_args+=(--resource-type "$rt")
done

# Human-readable name for the things in the picker (singular form):
#   "model"          -> "dbt models"
#   "model,seed"     -> "dbt models or seeds"
local node_kind
if [[ $resource_types == *,* ]]; then
  node_kind="${resource_types//,/s or }"
else
  node_kind="$resource_types"
fi

local usage="${label} [-s SELECTOR] [-n] [-- EXTRA_ARGS...]

Run \`dbt ${dbt_subcmd}\` locally with --defer against the production
ref-state. Omit -s to open an fzf picker over dbt ${node_kind}s (recently used first).

  -s SELECTOR   dbt node selector; skips the picker
  -n, --list    dry-run: show which nodes will be built locally vs read from
                prod (via --defer), then exit without running dbt
  --            pass any additional arguments straight to dbt

Environment (all required):
  DBT_STATE_DIR      path to dir containing the ref-state manifest.json
  DBT_PROJECT_SUBDIR subdir of the git root containing dbt_project.yml
  DBT_TARGET         dbt target name (e.g. local_dev)
  DBT_DEV_PROJECT    GCP project ID used for local runs
  DBT_DATASET_PREFIX BigQuery dataset name for locally-built models

Examples:
  ${label}
  ${label} -s my_model+
  ${label} -n -s my_model+
  ${label} -s tag:finance -- --full-refresh"

local _dbt_var
for _dbt_var in DBT_STATE_DIR DBT_PROJECT_SUBDIR DBT_TARGET DBT_DEV_PROJECT DBT_DATASET_PREFIX; do
  if [[ -z ${(P)_dbt_var} ]]; then
    print -u2 "${label}: \$$_dbt_var is not set"
    return 1
  fi
done

local selector=""
local list_only=0
local -a extra_args

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    -s)
      [[ -z $2 ]] && { print -u2 "${label}: -s requires an argument"; return 1 }
      selector=$2
      shift 2
      ;;
    -n|--list)
      list_only=1
      shift
      ;;
    -h|--help)
      print "$usage"
      return 0
      ;;
    --)
      shift
      extra_args=("$@")
      break
      ;;
    *)
      print -u2 "${label}: unknown option: $1"
      print -u2 "$usage"
      return 1
      ;;
  esac
done

# Locate and validate the prod ref-state manifest via the shared helper.
# `--require` makes missing/unset DBT_STATE_DIR a hard failure (with a
# stderr diagnostic + "Run: dbt-sync-state" hint), matching the previous
# inline behavior. `--max-age-days 7` enforces the same 7-day freshness
# rule that used to live here. The helper exports `state_dir`, `manifest`,
# `age_seconds`, `age_label` into the current shell via `eval`.
autoload -Uz _rlm-dbt-state-info
local _state_info
_state_info=$(_rlm-dbt-state-info --require --max-age-days 7 --label "$label") || return 1
eval "$_state_info"
# Compat aliases for the rest of this function, which reads `state_dir`,
# `manifest`, and the per-second `age` value.
local age=$age_seconds

local repo_root
repo_root=$(git root 2>/dev/null) || {
  print -u2 "${label}: not inside a git repository"
  return 1
}

local dbt_root="$repo_root/$DBT_PROJECT_SUBDIR"
local profiles_dir="$dbt_root/profile"
if [[ ! -d $profiles_dir ]]; then
  print -u2 "${label}: profiles dir not found: $profiles_dir"
  return 1
fi

# Verify `poetry run dbt` resolves to the project venv (not a stray $PATH
# dbt) and auto-install if not. Shared helper handles the three-line
# diagnostic on hard failure. Skipped under DBT_USE_FUSION=1 — the
# fusion path runs `dbtf` (a standalone binary), not poetry.
autoload -Uz _rlm-poetry-ensure-venv
if [[ ${DBT_USE_FUSION:-0} != 1 ]]; then
  _rlm-poetry-ensure-venv "$dbt_root" dbt "$label" || return 1
fi

# Resolve the dbt command-prefix tokens once. Under DBT_USE_FUSION=1 this
# is the single token `dbtf`; otherwise it's `poetry run dbt`. Every
# invocation of dbt below uses "${dbt_bin[@]}" instead of hard-coding
# `poetry run dbt`.
autoload -Uz _rlm-dbt-bin
local -a dbt_bin
dbt_bin=(${(f)"$(_rlm-dbt-bin)"}) || return 1

# Ensure dbt packages declared in packages.yml are installed (a fresh
# checkout or a newly added package would otherwise cause `dbt ls` to
# emit the "X package(s) specified … but only N installed" warning and
# produce no node list).
autoload -Uz _rlm-dbt-ensure-deps
_rlm-dbt-ensure-deps "$dbt_root" "$dbt_root" "$label" || return 1

local dbt_target="$DBT_TARGET"

# Project key + shared cache wiring. All four rlm-dbt-* commands share
# one history file (~/.cache/rlm-dbt/history.tsv, pooled across commands,
# scoped per project) and one nodes cache (~/.cache/rlm-dbt/<key>/nodes.json,
# covering every resource type the four commands care about). See the
# three _rlm-dbt-{project-key,history,nodes-cache} helpers.
autoload -Uz _rlm-dbt-project-key _rlm-dbt-history _rlm-dbt-nodes-cache
local project_key
project_key=$(_rlm-dbt-project-key "$dbt_root") || return 1
local nodes_cache
nodes_cache=$(_rlm-dbt-nodes-cache path "$project_key")

# Build a jq filter from the comma-list of resource_types passed in by
# the wrapper (e.g. "model" -> select(.resource_type == "model") | .name;
# "model,seed" -> select(.resource_type == "model" or .resource_type == "seed") | .name).
local _jq_rt_filter=""
local _rt
for _rt in ${(s:,:)resource_types}; do
  if [[ -z $_jq_rt_filter ]]; then
    _jq_rt_filter=".resource_type == \"$_rt\""
  else
    _jq_rt_filter+=" or .resource_type == \"$_rt\""
  fi
done
local nodes_jq_filter="select(${_jq_rt_filter}) | .name"

# Refresh the shared nodes cache via the shared helper.
_dbt_cmd_fetch_nodes() {
  _rlm-dbt-nodes-cache refresh \
    "$project_key" \
    "$dbt_root" \
    "$dbt_root" \
    "$profiles_dir" \
    "$dbt_target" \
    || {
      print -u2 "${label}: failed to refresh nodes cache"
      return 1
    }
}

# If no -s given, open fzf picker
if [[ -z $selector ]]; then
  # Fetch cache if missing
  if [[ ! -f $nodes_cache ]]; then
    _dbt_cmd_fetch_nodes || true
  fi

  # Helper: format elapsed seconds as human-readable "X ago"
  _dbt_cmd_elapsed_label() {
    local elapsed=$1
    if (( elapsed < 60 )); then
      print "${elapsed}s ago"
    elif (( elapsed < 3600 )); then
      print "$(( elapsed / 60 ))m ago"
    elif (( elapsed < 86400 )); then
      print "$(( elapsed / 3600 ))h ago"
    else
      print "$(( elapsed / 86400 ))d ago"
    fi
  }

  local now_ts
  now_ts=$(date +%s)

  # Build pooled-history lines from the shared TSV. Each line:
  #   "<selector>\t<label>"
  # where label is "(last used Xm ago in dbt-Y)". Pooled means every
  # command's picks for this project show up here, not just the current
  # command's — opted in by the user; see /Users/rubenlaguna/.claude/plans/can-all-the-rlm-dbt-logical-map.md.
  local -A history_seen
  local -a history_lines
  local _h_ts _h_cmd _h_sel _h_elapsed _h_lbl
  while IFS=$'\t' read -r _h_ts _h_cmd _h_sel; do
    [[ -z $_h_sel ]] && continue
    [[ -n ${history_seen[$_h_sel]:-} ]] && continue
    if [[ -n $_h_ts && $_h_ts != 0 ]]; then
      _h_elapsed=$(( now_ts - _h_ts ))
      _h_lbl="(last used $(_dbt_cmd_elapsed_label "$_h_elapsed") in ${_h_cmd})"
    else
      _h_lbl="(from ${_h_cmd})"
    fi
    history_lines+=("${_h_sel}"$'\t'"${_h_lbl}")
    history_seen[$_h_sel]=1
  done < <(_rlm-dbt-history read "$project_key")

  local cache_age_label=""
  if [[ -f $nodes_cache ]]; then
    local cmtime cnow celapsed
    cmtime=$(stat -f %m "$nodes_cache" 2>/dev/null || stat -c %Y "$nodes_cache" 2>/dev/null)
    cnow=$(date +%s)
    celapsed=$(( cnow - cmtime ))
    if (( celapsed < 60 )); then
      cache_age_label="${celapsed}s ago"
    elif (( celapsed < 3600 )); then
      cache_age_label="$(( celapsed / 60 ))m ago"
    elif (( celapsed < 86400 )); then
      cache_age_label="$(( celapsed / 3600 ))h ago"
    else
      cache_age_label="$(( celapsed / 86400 ))d ago"
    fi
  fi

  local refresh_sentinel="--- REFRESH NODES CACHE${cache_age_label:+ (cached ${cache_age_label})} ---"

  # fzf input: sentinel, history with labels, then remaining nodes
  local raw_selection
  raw_selection=$(
    {
      print -- "$refresh_sentinel"
      # History entries (pooled across all rlm-dbt-* commands, project-scoped)
      local entry
      for entry in "${history_lines[@]}"; do
        local m="${entry%%$'\t'*}"
        local lbl="${entry##*$'\t'}"
        printf '%s\t%s\n' "$m" "$lbl"
      done
      # Remaining nodes not in history — filtered to this command's
      # resource types via jq.
      _rlm-dbt-nodes-cache read "$project_key" "$nodes_jq_filter" \
        | while IFS= read -r node; do
            [[ -z $node ]] && continue
            [[ -z ${history_seen[$node]:-} ]] && printf '%s\t\n' "$node"
          done
    } \
    | fzf --prompt="${label}> " \
          --no-mouse \
          --ansi \
          --height=80% \
          --reverse \
          --no-sort \
          --delimiter=$'\t' \
          --with-nth='1,2' \
          --preview-window=bottom:40%:wrap \
          --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
          --bind='ctrl-g:abort'
  ) || return 130

  [[ -z $raw_selection ]] && return 130

  if [[ $raw_selection == "--- REFRESH "* ]]; then
    rm -f "$nodes_cache"
    _dbt_cmd_fetch_nodes || return 1
    "$cmd_name" "${extra_args[@]}"
    return $?
  fi

  # Extract just the selector (first tab-delimited field)
  selector="${raw_selection%%$'\t'*}"
fi

# Record selector in the shared pooled history (newest first, deduped on
# (project_key, selector), capped at 500 lines). Done before running dbt
# so the entry sticks even if dbt itself fails — matches the existing
# behavior (the previous code also wrote history before the cost prompt).
_rlm-dbt-history append "$label" "$project_key" "$selector"

local -a dbt_cmd=(
  "${dbt_bin[@]}" "$dbt_subcmd"
  --project-dir "$dbt_root"
  -s "$selector"
  --defer
  --state "$state_dir"
  --profiles-dir "$profiles_dir"
  --target "$dbt_target"
  "${extra_args[@]}"
)

print "${label}: selector=$selector"
# state_dir + age_label set by _rlm-dbt-state-info earlier (via eval).
print "${label}: state=$state_dir (${age_label} old)"
print "${label}: profiles=$profiles_dir"
print ""

_dbt_cmd_cost_estimate() {
  print "Estimating query cost (compiling + bq dry-run) …"

  # Find which nodes build locally (not deferred from prod). Restrict to
  # resource types that actually scan data via bq dry-run — for run/build
  # that's models only (seeds load static CSV); for test that's tests.
  local -a cost_resource_args
  local crt
  for crt in ${(s:,:)cost_resource_types}; do
    cost_resource_args+=(--resource-type "$crt")
  done

  local tmp_local_nodes
  tmp_local_nodes=$(mktemp)
  # Same noise-filter as the list-only block: dbt-core (HH:MM:SS log
  # prefix) and Fusion (trailing "suggestion: …" hint, "[warning] …"
  # lines, "===…===" separators) both leak non-name lines into stdout
  # even under --quiet. Restrict to strict dotted-identifier lines.
  (
    "${dbt_bin[@]}" ls \
      --project-dir "$dbt_root" \
      -s "$selector" \
      "${cost_resource_args[@]}" \
      --defer --state "$state_dir" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --output name --quiet 2>/dev/null \
    | grep -E '^[A-Za-z0-9_.]+$' \
    | sort
  ) >| "$tmp_local_nodes" 2>/dev/null

  local -a local_nodes
  local_nodes=("${(@f)$(cat "$tmp_local_nodes")}")
  rm -f "$tmp_local_nodes"

  local count_local=${#local_nodes[@]}
  [[ ${local_nodes[1]:-} == '' ]] && count_local=0

  # Human-readable label for items being costed (matches cost_resource_types).
  local cost_kind_label
  if [[ $cost_resource_types == *,* ]]; then
    cost_kind_label="${cost_resource_types//,/s/}s"
  else
    cost_kind_label="${cost_resource_types}s"
  fi

  if (( count_local == 0 )); then
    print "  No ${cost_kind_label} will run locally (all deferred from prod) — cost: \$0.00"
    return 0
  fi

  # Compile to get SQL.
  # `dbt compile --quiet` STILL prints the compiled SQL of every selected
  # node to stdout (the --quiet flag only silences log lines, not SQL).
  # Redirect stdout to /dev/null too, otherwise the SQL leaks into our
  # output between the "Estimating …" header and the summary table. We
  # do not need the stdout SQL anyway — we read each model's compiled SQL
  # from target/compiled/ below.
  (
    "${dbt_bin[@]}" compile \
      --project-dir "$dbt_root" \
      -s "$selector" \
      --defer --state "$state_dir" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --quiet >/dev/null 2>&1
  ) || {
    print "  Warning: dbt compile failed; skipping cost estimate"
    return 0
  }

  local compiled_dir="$dbt_root/target/compiled"
  local total_bytes=0
  local -a failed_models
  local -a per_model_lines

  for node in "${local_nodes[@]}"; do
    [[ -z $node ]] && continue
    local model_name="${node##*.}"
    # Find compiled SQL (may be nested under project name subdirs).
    # Exclude unit-test fixtures, which dbt writes under a parent directory
    # ending in `.yml` (e.g. `_foo_unit_tests.yml/foo.sql`). These compiled
    # fixtures use inline mock data and dry-run to 0 bytes, which silently
    # poisons the cost estimate if picked up before the real model file.
    local sql_file
    sql_file=$(find "$compiled_dir" -name "${model_name}.sql" -type f \
        -not -path '*.yml/*' 2>/dev/null | head -1)
    if [[ -z $sql_file ]]; then
      failed_models+=("$model_name (compiled SQL not found)")
      continue
    fi
    local dry_out
    dry_out=$(bq query --dry_run --use_legacy_sql=false < "$sql_file" 2>&1)
    local rc=$?
    if (( rc != 0 )); then
      failed_models+=("$model_name (bq dry-run failed) — compiled SQL: $sql_file"$'\n'"$(print -- "$dry_out" | sed 's/^/      /')")
      continue
    fi
    # bq dry-run output: "Query successfully validated. Assuming the tables are not modified,
    # running this query will process X bytes of data." (some versions insert "upper bound of")
    local bytes
    bytes=$(print -- "$dry_out" | grep -oE '[0-9]+ bytes' | grep -oE '[0-9]+' | head -1)
    if [[ -n $bytes ]]; then
      total_bytes=$(( total_bytes + bytes ))
      # Pretty-format this model's contribution (KB/MB/GB/TB).
      local _model_size
      _model_size=$(python3 - "$bytes" <<'PYEOF'
import sys
b = int(sys.argv[1])
if b >= 1_000_000_000_000:
    print(f"{b/1_000_000_000_000:.2f} TB")
elif b >= 1_000_000_000:
    print(f"{b/1_000_000_000:.2f} GB")
elif b >= 1_000_000:
    print(f"{b/1_000_000:.2f} MB")
else:
    print(f"{b/1_000:.1f} KB")
PYEOF
      )
      per_model_lines+=("    ${_model_size}  ${model_name}"$'\n'"      sql: ${sql_file}")
    else
      failed_models+=("$model_name (could not parse bytes from: $dry_out) — compiled SQL: $sql_file")
    fi
  done

  # Format total size and cost via python3 (avoids zsh float issues)
  local _py_out size_label cost_dollars
  _py_out=$(python3 - "$total_bytes" <<'PYEOF'
import sys
b = int(sys.argv[1])
if b >= 1_000_000_000_000:
    size = f"{b/1_000_000_000_000:.2f} TB"
elif b >= 1_000_000_000:
    size = f"{b/1_000_000_000:.2f} GB"
elif b >= 1_000_000:
    size = f"{b/1_000_000:.2f} MB"
else:
    size = f"{b/1_000:.1f} KB"
cost = b / 1e12 * 6.25
print(f"{size}|${cost:.4f}")
PYEOF
  )
  size_label="${_py_out%%|*}"
  cost_dollars="${_py_out##*|}"

  print ""
  print "  ${(C)cost_kind_label} running locally : $count_local"
  print "  Data processed estimate    : $size_label"
  print "  Cost estimate              : $cost_dollars  (@ \$6.25/TB)"
  if (( ${#per_model_lines[@]} )); then
    print "  Per-${cost_resource_types%%,*} breakdown (path printed so you can dry-run it manually):"
    local line
    for line in "${per_model_lines[@]}"; do
      print -- "$line"
    done
  fi
  if (( ${#failed_models[@]} )); then
    print "  Warnings (excluded from estimate):"
    for m in "${failed_models[@]}"; do
      print "    - $m"
    done
  fi
  print ""
}

if ! (( list_only )); then
  _dbt_cmd_cost_estimate
  print -n "Proceed? [Y/n] "
  local answer
  read -r answer
  case ${answer:-Y} in
    [Yy]*|'') ;;
    *) print "Aborted."; return 1 ;;
  esac
  print ""
fi
if (( list_only )); then
  print "Resolving relations (this may take a moment) …"

  # Capture system python3 before any poetry subshell can shadow it
  local system_python3
  system_python3=$(whence -p python3)

  local tmp_local tmp_all
  tmp_local=$(mktemp)
  tmp_all=$(mktemp)

  # Run both dbt ls calls in parallel (MONITOR off to suppress job notifications)
  setopt LOCAL_OPTIONS
  unsetopt MONITOR
  # Filter to lines that look like dbt node names. Both dbt-core (HH:MM:SS
  # log prefix) and Fusion (trailing "suggestion: …" hint, "[warning] …"
  # lines, "===…===" separators) can leak non-name lines into stdout even
  # under --quiet; node names are pure dotted identifiers, so a strict
  # `[A-Za-z0-9_.]+$` keep-list catches both.
  (
    "${dbt_bin[@]}" ls \
      --project-dir "$dbt_root" \
      -s "$selector" \
      "${resource_args[@]}" \
      --defer --state "$state_dir" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --output name --quiet 2>/dev/null \
    | grep -E '^[A-Za-z0-9_.]+$' \
    | sort >| "$tmp_local"
  ) &
  local pid_local=$!

  (
    "${dbt_bin[@]}" ls \
      --project-dir "$dbt_root" \
      -s "+${selector}" \
      "${resource_args[@]}" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --output name --quiet 2>/dev/null \
    | grep -E '^[A-Za-z0-9_.]+$' \
    | sort >| "$tmp_all"
  ) &
  local pid_all=$!

  wait $pid_local $pid_all

  # Nodes in all-upstream but not in the deferred-local set → read from prod
  local -a local_nodes deferred_nodes
  local_nodes=("${(@f)$(cat "$tmp_local")}")
  deferred_nodes=("${(@f)$(comm -23 "$tmp_all" "$tmp_local")}")

  rm -f "$tmp_local" "$tmp_all"

  # filter empty strings (empty array quirk when dbt ls returns nothing)
  local count_local=${#local_nodes[@]}
  [[ ${local_nodes[1]:-} == '' ]] && count_local=0
  local count_def=${#deferred_nodes[@]}
  [[ ${deferred_nodes[1]:-} == '' ]] && count_def=0

  local dev_project="$DBT_DEV_PROJECT"
  local dev_dataset="$DBT_DATASET_PREFIX"

  # Build fzf input: "TAG|dbt_name|bq_ref" per line
  # TAG: LOCAL or PROD
  # bq_ref: project:dataset.table (bq CLI format, derived from relation_name)
  local tmp_fzf
  tmp_fzf=$(mktemp)

  if (( count_local )); then
    for node in "${local_nodes[@]}"; do
      local model_name="${node##*.}"
      printf 'LOCAL|%s|%s:%s.%s\n' \
        "$node" "$dev_project" "$dev_dataset" "$model_name" >> "$tmp_fzf"
    done
  fi

  if (( count_def )); then
    # Parse all deferred relations from prod manifest in one python3 call.
    # Write script to a temp file so stdin is free for the node list pipe.
    local tmp_py tmp_rel
    tmp_py=$(mktemp -t dbt-cmd-rel.XXXXXX)
    tmp_rel=$(mktemp -t dbt-cmd-rel.XXXXXX)
    cat >| "$tmp_py" <<'PYEOF'
import json, sys
manifest_path = sys.argv[1]
with open(manifest_path) as f:
    nodes = json.load(f)['nodes']
idx = {}
for k, v in nodes.items():
    if v.get('resource_type') in ('model', 'seed'):
        idx[v['name']] = v.get('relation_name', '')
for line in sys.stdin:
    node_name = line.strip()
    if not node_name:
        continue
    model_name = node_name.split('.')[-1]
    rel = idx.get(model_name) or ''
    # relation_name is `project`.`dataset`.`table` — convert to project:dataset.table
    parts = [p.strip('`') for p in rel.split('`.`')]
    if len(parts) == 3:
        bq_ref = f"{parts[0]}:{parts[1]}.{parts[2]}"
    else:
        bq_ref = ''
    print(f"{node_name}|{bq_ref}")
PYEOF
    printf '%s\n' "${deferred_nodes[@]}" \
      | "$system_python3" "$tmp_py" "$manifest" >| "$tmp_rel"
    while IFS='|' read -r node bq_ref; do
      printf 'PROD|%s|%s\n' "$node" "$bq_ref" >> "$tmp_fzf"
    done < "$tmp_rel"
    rm -f "$tmp_py" "$tmp_rel"
  fi

  fzf --read0 \
      --prompt="${label} -n > " \
      --height=80% \
      --no-mouse \
      --reverse \
      --no-sort \
      --with-nth='1,2' \
      --delimiter='|' \
      --preview='
        line={}
        tag=${line%%|*}
        rest=${line#*|}
        dbt_name=${rest%%|*}
        bq_ref=${rest##*|}
        printf "node   : %s\n" "$dbt_name"
        printf "source : %s\n" "$tag"
        printf "bq_ref : %s\n" "$bq_ref"
        printf "\n"
        if [ -z "$bq_ref" ]; then
          echo "(relation unknown — node not found in prod manifest)"
        else
          "$HOME/bin/bq-preview" "$bq_ref" 2>&1 || echo "(not yet materialized in BigQuery)"
        fi
      ' \
      --preview-window=bottom:40%:wrap \
      --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
      --bind='ctrl-g:abort' \
      < <(tr '\n' '\0' < "$tmp_fzf")

  rm -f "$tmp_fzf"
  return 0
fi

print "$ ${dbt_cmd[*]}"
print ""

"${dbt_cmd[@]}"
