emulate -L zsh

# Shared implementation for rlm-dbt-run / rlm-dbt-build.
#
# Called by the wrapper functions with two leading positional arguments
# followed by the user's own argv:
#
#   _rlm-dbt-cmd <dbt_subcmd> <resource_types> -- "$@"
#
#   dbt_subcmd       e.g. "run" or "build"
#   resource_types   comma-separated dbt --resource-type values used for the
#                    fzf picker / cost estimate / list view (e.g. "model" or
#                    "model,seed"). The wrapper also drives the wording in
#                    help / log output.
#
# All env / state / cache layout is identical to the original rlm-dbt-run;
# the cache directory is keyed off the wrapper name (passed as $0 by zsh)
# so dbt-run and dbt-build keep independent history.

local dbt_subcmd="$1"
local resource_types="$2"
shift 2

local cmd_name="${funcstack[2]:-rlm-dbt-${dbt_subcmd}}"
# Short label used in user-facing messages (e.g. "dbt-run", "dbt-build")
local label="${cmd_name#rlm-}"

# Build "--resource-type X --resource-type Y" array from comma list
local -a resource_args
local rt
for rt in ${(s:,:)resource_types}; do
  resource_args+=(--resource-type "$rt")
done

# Human-readable name for the things in the picker (singular form):
#   "model"          -> "dbt models"
#   "model,seed"     -> "dbt models or seeds"
local node_kind
if [[ $resource_types == *,* ]]; then
  node_kind="${resource_types//,/s or }"
else
  node_kind="$resource_types"
fi

local usage="${label} [-s SELECTOR] [-n] [-- EXTRA_ARGS...]

Run \`dbt ${dbt_subcmd}\` locally with --defer against the production
ref-state. Omit -s to open an fzf picker over dbt ${node_kind}s (recently used first).

  -s SELECTOR   dbt node selector; skips the picker
  -n, --list    dry-run: show which nodes will be built locally vs read from
                prod (via --defer), then exit without running dbt
  --            pass any additional arguments straight to dbt

Environment (all required):
  DBT_STATE_DIR      path to dir containing the ref-state manifest.json
  DBT_PROJECT_SUBDIR subdir of the git root containing dbt_project.yml
  DBT_TARGET         dbt target name (e.g. local_dev)
  DBT_DEV_PROJECT    GCP project ID used for local runs
  DBT_DATASET_PREFIX BigQuery dataset name for locally-built models

Examples:
  ${label}
  ${label} -s my_model+
  ${label} -n -s my_model+
  ${label} -s tag:finance -- --full-refresh"

local _dbt_var
for _dbt_var in DBT_STATE_DIR DBT_PROJECT_SUBDIR DBT_TARGET DBT_DEV_PROJECT DBT_DATASET_PREFIX; do
  if [[ -z ${(P)_dbt_var} ]]; then
    print -u2 "${label}: \$$_dbt_var is not set"
    return 1
  fi
done

local selector=""
local list_only=0
local -a extra_args

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    -s)
      [[ -z $2 ]] && { print -u2 "${label}: -s requires an argument"; return 1 }
      selector=$2
      shift 2
      ;;
    -n|--list)
      list_only=1
      shift
      ;;
    -h|--help)
      print "$usage"
      return 0
      ;;
    --)
      shift
      extra_args=("$@")
      break
      ;;
    *)
      print -u2 "${label}: unknown option: $1"
      print -u2 "$usage"
      return 1
      ;;
  esac
done

# Check ref-state exists and is fresh (< 7 days old)
local state_dir="$DBT_STATE_DIR"
local manifest="$state_dir/manifest.json"

if [[ ! -f $manifest ]]; then
  print -u2 "${label}: ref-state manifest not found at $manifest"
  print -u2 "         Run: dbt-sync-state"
  return 1
fi

# mtime check — stat -f %m is macOS; fallback to Linux
local mtime now age
if mtime=$(stat -f %m "$manifest" 2>/dev/null); then
  now=$(date +%s)
  age=$(( now - mtime ))
elif mtime=$(stat -c %Y "$manifest" 2>/dev/null); then
  now=$(date +%s)
  age=$(( now - mtime ))
else
  print -u2 "${label}: could not check manifest age (stat failed)"
  age=0
fi

if (( age > 7 * 24 * 3600 )); then
  local days=$(( age / 86400 ))
  print -u2 "${label}: ref-state manifest is ${days} days old (> 7 days)"
  print -u2 "         Run: dbt-sync-state"
  return 1
fi

local repo_root
repo_root=$(git root 2>/dev/null) || {
  print -u2 "${label}: not inside a git repository"
  return 1
}

local dbt_root="$repo_root/$DBT_PROJECT_SUBDIR"
local profiles_dir="$dbt_root/profile"
if [[ ! -d $profiles_dir ]]; then
  print -u2 "${label}: profiles dir not found: $profiles_dir"
  return 1
fi

# Verify `poetry run dbt` resolves to the project venv (not a stray $PATH
# dbt) and auto-install if not. Shared helper handles the three-line
# diagnostic on hard failure.
autoload -Uz _rlm-poetry-ensure-venv
_rlm-poetry-ensure-venv "$dbt_root" dbt "$label" || return 1

local dbt_target="$DBT_TARGET"

local cache_dir="$HOME/.cache/${label}"
# Historical filename is models.txt — kept even for seeds-aware variants so
# pre-refactor caches keep working after the upgrade.
local nodes_cache="$cache_dir/models.txt"
local history_file="$cache_dir/history.txt"
# history_ts: tab-separated "epoch<TAB>node" entries, newest first
local history_ts_file="$cache_dir/history_ts.txt"
mkdir -p "$cache_dir"

# Fetch node list (models, and optionally seeds) from dbt ls, save to cache
_dbt_cmd_fetch_nodes() {
  print -u2 "${label}: fetching ${node_kind} list via dbt ls …"
  local err_log="$cache_dir/dbt-ls.err"
  local output rc
  output=$(cd "$dbt_root" && poetry run dbt ls \
    "${resource_args[@]}" \
    --profiles-dir "$profiles_dir" \
    --target "$dbt_target" \
    --output name \
    --quiet 2>"$err_log")
  rc=$?
  if (( rc != 0 )); then
    print -u2 "${label}: dbt ls failed (exit $rc); falling back to empty ${node_kind} list"
    print -u2 "${label}: command was:"
    print -u2 "  cd $dbt_root && poetry run dbt ls ${resource_args[*]} --profiles-dir $profiles_dir --target $dbt_target --output name --quiet"
    if [[ -s $err_log ]]; then
      print -u2 "${label}: stderr saved to $err_log"
    else
      print -u2 "${label}: (no stderr captured; see $err_log)"
    fi
    return 1
  fi
  print -- "$output" >| "$nodes_cache"
}

# If no -s given, open fzf picker
if [[ -z $selector ]]; then
  # Fetch cache if missing
  if [[ ! -f $nodes_cache ]]; then
    _dbt_cmd_fetch_nodes || true
  fi

  # Helper: format elapsed seconds as human-readable "X ago"
  _dbt_cmd_elapsed_label() {
    local elapsed=$1
    if (( elapsed < 60 )); then
      print "${elapsed}s ago"
    elif (( elapsed < 3600 )); then
      print "$(( elapsed / 60 ))m ago"
    elif (( elapsed < 86400 )); then
      print "$(( elapsed / 3600 ))h ago"
    else
      print "$(( elapsed / 86400 ))d ago"
    fi
  }

  local now_ts
  now_ts=$(date +%s)

  # Build set of history node names (for exclusion from the unrun list)
  local -A history_seen
  local -a history_lines  # "NODE_NAME\tLABEL" pairs
  if [[ -f $history_ts_file ]]; then
    while IFS=$'\t' read -r ts node; do
      [[ -z $node ]] && continue
      if [[ -z ${history_seen[$node]:-} ]]; then
        local elapsed=$(( now_ts - ts ))
        local hlabel=$(_dbt_cmd_elapsed_label "$elapsed")
        history_lines+=("${node}"$'\t'"${hlabel}")
        history_seen[$node]=1
      fi
    done < "$history_ts_file"
  elif [[ -f $history_file ]]; then
    # Migrate legacy plain-name history (no timestamps); show no time label
    while IFS= read -r node; do
      [[ -z $node ]] && continue
      if [[ -z ${history_seen[$node]:-} ]]; then
        history_lines+=("${node}"$'\t'"")
        history_seen[$node]=1
      fi
    done < "$history_file"
  fi

  local cache_age_label=""
  if [[ -f $nodes_cache ]]; then
    local cmtime cnow celapsed
    cmtime=$(stat -f %m "$nodes_cache" 2>/dev/null || stat -c %Y "$nodes_cache" 2>/dev/null)
    cnow=$(date +%s)
    celapsed=$(( cnow - cmtime ))
    if (( celapsed < 60 )); then
      cache_age_label="${celapsed}s ago"
    elif (( celapsed < 3600 )); then
      cache_age_label="$(( celapsed / 60 ))m ago"
    elif (( celapsed < 86400 )); then
      cache_age_label="$(( celapsed / 3600 ))h ago"
    else
      cache_age_label="$(( celapsed / 86400 ))d ago"
    fi
  fi

  local refresh_sentinel="--- REFRESH ${(U)node_kind} CACHE${cache_age_label:+ (cached ${cache_age_label})} ---"

  # fzf input: sentinel, history with labels, then remaining nodes
  local raw_selection
  raw_selection=$(
    {
      print -- "$refresh_sentinel"
      # History entries: "NODE  (last run LABEL)" — displayed text
      local entry
      for entry in "${history_lines[@]}"; do
        local m="${entry%%$'\t'*}"
        local lbl="${entry##*$'\t'}"
        if [[ -n $lbl ]]; then
          printf '%s\t(last run %s)\n' "$m" "$lbl"
        else
          printf '%s\t\n' "$m"
        fi
      done
      # Remaining nodes not in history
      if [[ -f $nodes_cache ]]; then
        while IFS= read -r node; do
          [[ -z ${history_seen[$node]:-} ]] && printf '%s\t\n' "$node"
        done < "$nodes_cache"
      fi
    } \
    | fzf --prompt="${label}> " \
          --height=80% \
          --reverse \
          --no-mouse \
          --no-sort \
          --delimiter=$'\t' \
          --with-nth='1,2' \
          --preview-window=bottom:40%:wrap \
          --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)'
  ) || return 130

  [[ -z $raw_selection ]] && return 130

  if [[ $raw_selection == "--- REFRESH "* ]]; then
    rm -f "$nodes_cache"
    _dbt_cmd_fetch_nodes || return 1
    "$cmd_name" "${extra_args[@]}"
    return $?
  fi

  # Extract just the node name (first tab-delimited field)
  selector="${raw_selection%%$'\t'*}"
fi

# Record selector in history with timestamp (newest first, deduped, max 100)
{
  printf '%s\t%s\n' "$(date +%s)" "$selector"
  if [[ -f $history_ts_file ]]; then
    grep -v $'\t'"${selector}"'$' "$history_ts_file" 2>/dev/null || true
  fi
} | head -100 >| "${history_ts_file}.tmp" && mv "${history_ts_file}.tmp" "$history_ts_file"
# Keep legacy history_file in sync (plain names, for any other consumers)
{
  print -- "$selector"
  [[ -f $history_file ]] && grep -Fxv "$selector" "$history_file" 2>/dev/null || true
} | head -100 >| "${history_file}.tmp" && mv "${history_file}.tmp" "$history_file"

local -a dbt_cmd=(
  poetry run dbt "$dbt_subcmd"
  -s "$selector"
  --defer
  --state "$state_dir"
  --profiles-dir "$profiles_dir"
  --target "$dbt_target"
  "${extra_args[@]}"
)

print "${label}: selector=$selector"
local age_label
if (( age < 60 )); then
  age_label="${age}s"
elif (( age < 3600 )); then
  age_label="$(( age / 60 ))m"
elif (( age < 86400 )); then
  age_label="$(( age / 3600 ))h"
else
  age_label="$(( age / 86400 ))d"
fi
print "${label}: state=$state_dir (${age_label} old)"
print "${label}: profiles=$profiles_dir"
print ""

_dbt_cmd_cost_estimate() {
  print "Estimating query cost (compiling + bq dry-run) …"

  # Find which nodes build locally (not deferred from prod). Seeds don't run
  # SQL through bq, so restrict the cost estimate to models.
  local tmp_local_nodes
  tmp_local_nodes=$(mktemp)
  (
    cd "$dbt_root" && poetry run dbt ls \
      -s "$selector" \
      --resource-type model \
      --defer --state "$state_dir" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --output name --quiet 2>/dev/null \
    | sort
  ) >| "$tmp_local_nodes" 2>/dev/null

  local -a local_nodes
  local_nodes=("${(@f)$(cat "$tmp_local_nodes")}")
  rm -f "$tmp_local_nodes"

  local count_local=${#local_nodes[@]}
  [[ ${local_nodes[1]:-} == '' ]] && count_local=0

  if (( count_local == 0 )); then
    print "  No models will be built locally (all deferred from prod) — cost: \$0.00"
    return 0
  fi

  # Compile to get SQL.
  # `dbt compile --quiet` STILL prints the compiled SQL of every selected
  # node to stdout (the --quiet flag only silences log lines, not SQL).
  # Redirect stdout to /dev/null too, otherwise the SQL leaks into our
  # output between the "Estimating …" header and the summary table. We
  # do not need the stdout SQL anyway — we read each model's compiled SQL
  # from target/compiled/ below.
  (
    cd "$dbt_root" && poetry run dbt compile \
      -s "$selector" \
      --defer --state "$state_dir" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --quiet >/dev/null 2>&1
  ) || {
    print "  Warning: dbt compile failed; skipping cost estimate"
    return 0
  }

  local compiled_dir="$dbt_root/target/compiled"
  local total_bytes=0
  local -a failed_models
  local -a per_model_lines

  for node in "${local_nodes[@]}"; do
    [[ -z $node ]] && continue
    local model_name="${node##*.}"
    # Find compiled SQL (may be nested under project name subdirs).
    # Exclude unit-test fixtures, which dbt writes under a parent directory
    # ending in `.yml` (e.g. `_foo_unit_tests.yml/foo.sql`). These compiled
    # fixtures use inline mock data and dry-run to 0 bytes, which silently
    # poisons the cost estimate if picked up before the real model file.
    local sql_file
    sql_file=$(find "$compiled_dir" -name "${model_name}.sql" -type f \
        -not -path '*.yml/*' 2>/dev/null | head -1)
    if [[ -z $sql_file ]]; then
      failed_models+=("$model_name (compiled SQL not found)")
      continue
    fi
    local dry_out
    dry_out=$(bq query --dry_run --use_legacy_sql=false < "$sql_file" 2>&1)
    local rc=$?
    if (( rc != 0 )); then
      failed_models+=("$model_name (bq dry-run failed) — compiled SQL: $sql_file"$'\n'"$(print -- "$dry_out" | sed 's/^/      /')")
      continue
    fi
    # bq dry-run output: "Query successfully validated. Assuming the tables are not modified,
    # running this query will process X bytes of data." (some versions insert "upper bound of")
    local bytes
    bytes=$(print -- "$dry_out" | grep -oE '[0-9]+ bytes' | grep -oE '[0-9]+' | head -1)
    if [[ -n $bytes ]]; then
      total_bytes=$(( total_bytes + bytes ))
      # Pretty-format this model's contribution (KB/MB/GB/TB).
      local _model_size
      _model_size=$(python3 - "$bytes" <<'PYEOF'
import sys
b = int(sys.argv[1])
if b >= 1_000_000_000_000:
    print(f"{b/1_000_000_000_000:.2f} TB")
elif b >= 1_000_000_000:
    print(f"{b/1_000_000_000:.2f} GB")
elif b >= 1_000_000:
    print(f"{b/1_000_000:.2f} MB")
else:
    print(f"{b/1_000:.1f} KB")
PYEOF
      )
      per_model_lines+=("    ${_model_size}  ${model_name}"$'\n'"      sql: ${sql_file}")
    else
      failed_models+=("$model_name (could not parse bytes from: $dry_out) — compiled SQL: $sql_file")
    fi
  done

  # Format total size and cost via python3 (avoids zsh float issues)
  local _py_out size_label cost_dollars
  _py_out=$(python3 - "$total_bytes" <<'PYEOF'
import sys
b = int(sys.argv[1])
if b >= 1_000_000_000_000:
    size = f"{b/1_000_000_000_000:.2f} TB"
elif b >= 1_000_000_000:
    size = f"{b/1_000_000_000:.2f} GB"
elif b >= 1_000_000:
    size = f"{b/1_000_000:.2f} MB"
else:
    size = f"{b/1_000:.1f} KB"
cost = b / 1e12 * 6.25
print(f"{size}|${cost:.4f}")
PYEOF
  )
  size_label="${_py_out%%|*}"
  cost_dollars="${_py_out##*|}"

  print ""
  print "  Models building locally : $count_local"
  print "  Data processed estimate : $size_label"
  print "  Cost estimate           : $cost_dollars  (@ \$6.25/TB)"
  if (( ${#per_model_lines[@]} )); then
    print "  Per-model breakdown (path printed so you can dry-run it manually):"
    local line
    for line in "${per_model_lines[@]}"; do
      print -- "$line"
    done
  fi
  if (( ${#failed_models[@]} )); then
    print "  Warnings (excluded from estimate):"
    for m in "${failed_models[@]}"; do
      print "    - $m"
    done
  fi
  print ""
}

if ! (( list_only )); then
  _dbt_cmd_cost_estimate
  print -n "Proceed? [Y/n] "
  local answer
  read -r answer
  case ${answer:-Y} in
    [Yy]*|'') ;;
    *) print "Aborted."; return 1 ;;
  esac
  print ""
fi
if (( list_only )); then
  print "Resolving relations (this may take a moment) …"

  # Capture system python3 before any poetry subshell can shadow it
  local system_python3
  system_python3=$(whence -p python3)

  local tmp_local tmp_all
  tmp_local=$(mktemp)
  tmp_all=$(mktemp)

  # Run both dbt ls calls in parallel (MONITOR off to suppress job notifications)
  setopt LOCAL_OPTIONS
  unsetopt MONITOR
  (
    cd "$dbt_root" && poetry run dbt ls \
      -s "$selector" \
      "${resource_args[@]}" \
      --defer --state "$state_dir" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --output name --quiet 2>/dev/null \
    | sort >| "$tmp_local"
  ) &
  local pid_local=$!

  (
    cd "$dbt_root" && poetry run dbt ls \
      -s "+${selector}" \
      "${resource_args[@]}" \
      --profiles-dir "$profiles_dir" \
      --target "$dbt_target" \
      --output name --quiet 2>/dev/null \
    | sort >| "$tmp_all"
  ) &
  local pid_all=$!

  wait $pid_local $pid_all

  # Nodes in all-upstream but not in the deferred-local set → read from prod
  local -a local_nodes deferred_nodes
  local_nodes=("${(@f)$(cat "$tmp_local")}")
  deferred_nodes=("${(@f)$(comm -23 "$tmp_all" "$tmp_local")}")

  rm -f "$tmp_local" "$tmp_all"

  # filter empty strings (empty array quirk when dbt ls returns nothing)
  local count_local=${#local_nodes[@]}
  [[ ${local_nodes[1]:-} == '' ]] && count_local=0
  local count_def=${#deferred_nodes[@]}
  [[ ${deferred_nodes[1]:-} == '' ]] && count_def=0

  local dev_project="$DBT_DEV_PROJECT"
  local dev_dataset="$DBT_DATASET_PREFIX"

  # Build fzf input: "TAG|dbt_name|bq_ref" per line
  # TAG: LOCAL or PROD
  # bq_ref: project:dataset.table (bq CLI format, derived from relation_name)
  local tmp_fzf
  tmp_fzf=$(mktemp)

  if (( count_local )); then
    for node in "${local_nodes[@]}"; do
      local model_name="${node##*.}"
      printf 'LOCAL|%s|%s:%s.%s\n' \
        "$node" "$dev_project" "$dev_dataset" "$model_name" >> "$tmp_fzf"
    done
  fi

  if (( count_def )); then
    # Parse all deferred relations from prod manifest in one python3 call.
    # Write script to a temp file so stdin is free for the node list pipe.
    local tmp_py tmp_rel
    tmp_py=$(mktemp -t dbt-cmd-rel.XXXXXX)
    tmp_rel=$(mktemp -t dbt-cmd-rel.XXXXXX)
    cat >| "$tmp_py" <<'PYEOF'
import json, sys
manifest_path = sys.argv[1]
with open(manifest_path) as f:
    nodes = json.load(f)['nodes']
idx = {}
for k, v in nodes.items():
    if v.get('resource_type') in ('model', 'seed'):
        idx[v['name']] = v.get('relation_name', '')
for line in sys.stdin:
    node_name = line.strip()
    if not node_name:
        continue
    model_name = node_name.split('.')[-1]
    rel = idx.get(model_name) or ''
    # relation_name is `project`.`dataset`.`table` — convert to project:dataset.table
    parts = [p.strip('`') for p in rel.split('`.`')]
    if len(parts) == 3:
        bq_ref = f"{parts[0]}:{parts[1]}.{parts[2]}"
    else:
        bq_ref = ''
    print(f"{node_name}|{bq_ref}")
PYEOF
    printf '%s\n' "${deferred_nodes[@]}" \
      | "$system_python3" "$tmp_py" "$manifest" >| "$tmp_rel"
    while IFS='|' read -r node bq_ref; do
      printf 'PROD|%s|%s\n' "$node" "$bq_ref" >> "$tmp_fzf"
    done < "$tmp_rel"
    rm -f "$tmp_py" "$tmp_rel"
  fi

  fzf --read0 \
      --prompt="${label} -n > " \
      --height=80% \
      --no-mouse \
      --reverse \
      --no-sort \
      --with-nth='1,2' \
      --delimiter='|' \
      --preview='
        line={}
        tag=${line%%|*}
        rest=${line#*|}
        dbt_name=${rest%%|*}
        bq_ref=${rest##*|}
        printf "node   : %s\n" "$dbt_name"
        printf "source : %s\n" "$tag"
        printf "bq_ref : %s\n" "$bq_ref"
        printf "\n"
        if [ -z "$bq_ref" ]; then
          echo "(relation unknown — node not found in prod manifest)"
        else
          "$HOME/bin/bq-preview" "$bq_ref" 2>&1 || echo "(not yet materialized in BigQuery)"
        fi
      ' \
      --preview-window=bottom:40%:wrap \
      --bind='ctrl-p:change-preview-window(bottom:70%:wrap|bottom:40%:wrap|hidden)' \
      < <(tr '\n' '\0' < "$tmp_fzf")

  rm -f "$tmp_fzf"
  return 0
fi

print "$ ${dbt_cmd[*]}"
print ""

"${dbt_cmd[@]}"
